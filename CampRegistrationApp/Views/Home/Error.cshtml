@model ErrorViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<div class="min-h-screen bg-camp-dark-grey text-white font-cairo" dir="rtl">
    <div class="container mx-auto px-4 py-16 flex flex-col items-center justify-center text-center">
        <div class="max-w-2xl w-full space-y-8">
            <!-- Status Code Badge -->
            <div class="mb-2">
                <span class="inline-block text-8xl font-bold tracking-wider @(Model.StatusCode >= 500 ? "text-red-500" : Model.StatusCode == 403 ? "text-orange-500" : Model.StatusCode == 404 ? "text-yellow-500" : "text-gray-400")" style="line-height:1">
                    @Model.StatusCode
                </span>
            </div>

            <!-- Icon -->
            <div class="flex justify-center mb-6">
                @if (Model.IconType == "not-found")
                {
                    <div class="p-5 rounded-full bg-yellow-900/20 border-2 border-yellow-500/50">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                }
                else if (Model.IconType == "forbidden")
                {
                    <div class="p-5 rounded-full bg-orange-900/20 border-2 border-orange-500/50">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                        </svg>
                    </div>
                }
                else if (Model.IconType == "unauthorized")
                {
                    <div class="p-5 rounded-full bg-gray-900/20 border-2 border-gray-500/50">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m0 0v2m0-2h2m-2 0H10m9.364-7.364A9 9 0 115.636 5.636a9 9 0 0112.728 0z" />
                        </svg>
                    </div>
                }
                else if (Model.IconType == "bad-request")
                {
                    <div class="p-5 rounded-full bg-gray-900/20 border-2 border-gray-500/50">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                }
                else
                {
                    <div class="p-5 rounded-full bg-red-900/20 border-2 border-red-500/50">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.173 4.631c-1.541-1.333-3.645-1.333-5.183 0L3.132 16c-0.77 1.333.194 3 1.732 3z" />
                        </svg>
                    </div>
                }
            </div>

            <!-- Title -->
            <h1 class="text-3xl md:text-4xl font-bold @(Model.StatusCode >= 500 ? "text-red-400" : Model.StatusCode == 403 ? "text-orange-400" : Model.StatusCode == 404 ? "text-yellow-400" : "text-gray-300") mb-4">
                @Model.Title
            </h1>

            <!-- Message -->
            <p class="text-lg text-gray-300 mb-8 leading-relaxed">@Model.Message</p>

            <!-- Request ID (for server errors) -->
            @if (Model.ShowRequestId && Model.StatusCode >= 500)
            {
                <div class="bg-camp-accent-grey p-5 rounded-lg border-r-4 border-camp-gold shadow-xl mb-8 inline-block">
                    <p class="text-xs text-gray-400 mb-1">معرف الطلب (Request ID):</p>
                    <code class="text-camp-gold font-mono text-base">@Model.RequestId</code>
                </div>
            }

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                @if (Model.ShowHomeButton)
                {
                    <a href="/" class="px-8 py-3 rounded bg-camp-gold text-camp-dark-grey font-bold hover:bg-yellow-600 transition-colors text-lg">
                        العودة للرئيسية
                    </a>
                }
                @if (Model.ShowReportButton)
                {
                    <button onclick="reportIssue()" class="px-8 py-3 rounded border border-gray-600 text-gray-400 hover:text-white hover:border-camp-gold transition-colors text-lg">
                        إبلاغ عن المشكلة
                    </button>
                }
            </div>
        </div>
    </div>

    @if (Model.ShowReportButton)
    {
        <script>
            function reportIssue() {
                const requestId = '@Model.RequestId';
                alert('شكراً لتواصلك معنا. يرجى إرسال معرف الطلب (' + requestId + ') إلى الدعم الفني عبر واتساب أو البريد الإلكتروني.');
            }
        </script>
    }
</div>
