@{
    ViewData["Title"] = "الرئيسية";
}

<!-- Hero -->
<section class="relative overflow-hidden rounded-lg mb-12" dir="rtl">
    <div class="bg-gradient-to-br from-camp-accent-grey to-camp-dark-grey p-8 md:p-16 rounded-lg border-r-4 border-camp-gold">
        <div class="max-w-3xl">
            <h1 class="text-4xl md:text-6xl font-bold text-camp-gold mb-4">مخيم السلام</h1>
            <p class="text-xl md:text-2xl text-white mb-6">معاً لدعم العائلات المتضررة وتوفير سبل العيش الكريم</p>
            <p class="text-gray-400 mb-8 text-lg">نسعى لتسجيل الأسر المتضررة وتقديم المساعدات الغذائية والطبية والإيوائية للأسر الأكثر احتياجاً</p>
            <div class="flex gap-4">
                <a asp-controller="Registration" asp-action="Index" class="bg-camp-gold text-camp-dark-grey px-8 py-3 rounded font-bold hover:bg-yellow-600 transition-colors text-lg">
                    تسجيل عائلة جديدة
                </a>
                <a asp-controller="Record" asp-action="Login" class="border border-camp-gold text-camp-gold px-8 py-3 rounded font-bold hover:bg-camp-gold hover:text-camp-dark-grey transition-colors text-lg">
                    تسجيل الدخول لتعديل البيانات
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Slider -->
<section class="mb-12" dir="rtl">
    <h2 class="text-2xl font-bold text-camp-gold mb-6 text-center">لحظات من مخيم السلام</h2>
    <div class="relative overflow-hidden rounded-lg h-64 md:h-[500px]" id="slider" dir="ltr">
        <div class="flex h-full transition-transform duration-500 ease-in-out" id="sliderTrack">
            <div class="w-full flex-shrink-0 h-full relative">
                <img src="@Url.Content("~/img_landing/1.jpeg")" alt="توزيع الخيام" class="w-full h-full object-cover absolute inset-0">
                @* <div class="absolute inset-0 z-10 bg-gradient-to-tr from-blue-900/80 to-blue-700/80 flex items-center justify-center p-12 md:p-20 text-center">
                    <div>
                        <h3 class="text-2xl font-bold text-white mb-2">توزيع الخيام</h3>
                        <p class="text-blue-200">توزيع أكثر من 500 خيمة على الأسر المتضررة</p>
                    </div>
                </div> *@
            </div>
            <div class="w-full flex-shrink-0 h-full relative">
                <img src="@Url.Content("~/img_landing/2.jpeg")" alt="المساعدات الغذائية" class="w-full h-full object-cover absolute inset-0">
                @* <div class="absolute inset-0 z-10 bg-gradient-to-tr from-green-900/80 to-green-700/80 flex items-center justify-center p-12 md:p-20 text-center">
                    <div>
                        <h3 class="text-2xl font-bold text-white mb-2">المساعدات الغذائية</h3>
                        <p class="text-green-200">توزيع السلال الغذائية للأسر المسجلة شهرياً</p>
                    </div>
                </div> *@
            </div>
            <div class="w-full flex-shrink-0 h-full relative">
                <img src="@Url.Content("~/img_landing/3.jpeg")" alt="الدعم الطبي" class="w-full h-full object-cover absolute inset-0">
                @* <div class="absolute inset-0 z-10 bg-gradient-to-tr from-red-900/80 to-red-700/80 flex items-center justify-center p-12 md:p-20 text-center">
                    <div>
                        <h3 class="text-2xl font-bold text-white mb-2">الدعم الطبي</h3>
                        <p class="text-red-200">توفير الأدوية والعلاج للحالات الحرجة</p>
                    </div>
                </div> *@
            </div>
            <div class="w-full flex-shrink-0 h-full relative">
                <img src="@Url.Content("~/img_landing/4.jpeg")" alt="التعليم" class="w-full h-full object-cover absolute inset-0">
                @* <div class="absolute inset-0 z-10 bg-gradient-to-tr from-purple-900/80 to-purple-700/80 flex items-center justify-center p-12 md:p-20 text-center">
                    <div>
                        <h3 class="text-2xl font-bold text-white mb-2">التعليم</h3>
                        <p class="text-purple-200">دعم تعليم الأطفال وتوفير القرطاسية والحقائب المدرسية</p>
                    </div>
                </div> *@
            </div>
        </div>

        <!-- Slider controls -->
        <button onclick="slidePrev()" class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/50 text-white w-10 h-10 rounded-full hover:bg-black/70 transition-colors text-xl">❮</button>
        <button onclick="slideNext()" class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/50 text-white w-10 h-10 rounded-full hover:bg-black/70 transition-colors text-xl">❯</button>

        <!-- Dots -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2" id="sliderDots">
            <span class="w-3 h-3 rounded-full bg-camp-gold cursor-pointer" onclick="slideTo(0)"></span>
            <span class="w-3 h-3 rounded-full bg-white/50 cursor-pointer" onclick="slideTo(1)"></span>
            <span class="w-3 h-3 rounded-full bg-white/50 cursor-pointer" onclick="slideTo(2)"></span>
            <span class="w-3 h-3 rounded-full bg-white/50 cursor-pointer" onclick="slideTo(3)"></span>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12" dir="rtl">
    <div class="bg-camp-accent-grey p-6 rounded-lg text-center border-t-2 border-camp-gold">
        <div class="text-3xl font-bold text-camp-gold">١٢٠٠+</div>
        <div class="text-gray-400 text-sm mt-1">عائلة مسجلة</div>
    </div>
    <div class="bg-camp-accent-grey p-6 rounded-lg text-center border-t-2 border-green-500">
        <div class="text-3xl font-bold text-green-500">٤٥٠٠+</div>
        <div class="text-gray-400 text-sm mt-1">فرد مستفيد</div>
    </div>
    <div class="bg-camp-accent-grey p-6 rounded-lg text-center border-t-2 border-blue-500">
        <div class="text-3xl font-bold text-blue-500">٣٠٠+</div>
        <div class="text-gray-400 text-sm mt-1">خيمة موزعة</div>
    </div>
    <div class="bg-camp-accent-grey p-6 rounded-lg text-center border-t-2 border-red-500">
        <div class="text-3xl font-bold text-red-500">١٠٠٠+</div>
        <div class="text-gray-400 text-sm mt-1">سلة غذائية</div>
    </div>
</section>

<!-- About -->
<section class="bg-camp-accent-grey p-8 rounded-lg border-r-4 border-camp-gold mb-12" dir="rtl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
            <h2 class="text-2xl font-bold text-camp-gold mb-4">من نحن</h2>
            <p class="text-gray-300 leading-relaxed mb-4">
                مخيم السلام هو مبادرة إنسانية تهدف إلى دعم العائلات المتضررة والنازحة. نعمل على تسجيل الأسر
                وتقييم احتياجاتهم بدقة لتقديم المساعدات المناسبة لكل حالة.
            </p>
            <p class="text-gray-400 leading-relaxed">
                نؤمن بأن لكل عائلة الحق في حياة كريمة، لذلك نحرص على توفير الدعم الغذائي والطبي
                والإيوائي والتعليمي للأسر الأكثر احتياجاً.
            </p>
        </div>
        <div class="bg-camp-dark-grey p-6 rounded-lg">
            <h3 class="text-xl font-bold text-camp-gold mb-4">مجالات الدعم</h3>
            <ul class="space-y-3">
                <li class="flex items-center gap-3 text-gray-300">
                    <span class="text-camp-gold">●</span> المساعدات الغذائية الشهرية
                </li>
                <li class="flex items-center gap-3 text-gray-300">
                    <span class="text-camp-gold">●</span> الرعاية الصحية والدواء
                </li>
                <li class="flex items-center gap-3 text-gray-300">
                    <span class="text-camp-gold">●</span> توفير الخيام والمأوى
                </li>
                <li class="flex items-center gap-3 text-gray-300">
                    <span class="text-camp-gold">●</span> دعم التعليم للأطفال
                </li>
                <li class="flex items-center gap-3 text-gray-300">
                    <span class="text-camp-gold">●</span> الملابس والبطانيات الشتوية
                </li>
            </ul>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="text-center py-8" dir="rtl">
    <h2 class="text-2xl font-bold text-camp-gold mb-4">انضم إلينا في دعم العائلات</h2>
    <p class="text-gray-400 mb-6">سجل عائلتك الآن لتحصل على الدعم الذي تستحقه</p>
    <a asp-controller="Registration" asp-action="Index" class="bg-camp-gold text-camp-dark-grey px-10 py-3 rounded font-bold hover:bg-yellow-600 transition-colors text-lg inline-block">
        تسجيل عائلة جديدة
    </a>
</section>

<!-- Landing Page Notification Modal -->
<div id="landing-modal" class="fixed inset-0 z-50 bg-black/70 hidden items-center justify-center" onclick="if(event.target===this)closeLandingModal()">
    <div class="bg-camp-accent-grey rounded-lg border-r-4 border-camp-gold shadow-xl p-8 max-w-lg mx-4 w-full">
        <div class="text-center mb-6">
            <div class="text-5xl text-camp-gold mb-4">📢</div>
            <h3 class="text-2xl font-bold text-camp-gold">تنبيه هام</h3>
        </div>
        <div class="text-gray-200 text-lg leading-relaxed text-center mb-8 space-y-4">
            <p>هذا النظام لمخيم السلام لتحديث البيانات.</p>
            <p>اليوم يتم إدراج الأسماء في النظام، وهذا النظام الذي ستعتمد عليه في ترشيح الأسماء للمساعدات.</p>
            <p class="text-camp-gold font-bold text-xl">يجب على الجميع التحديث.</p>
        </div>
        <div class="text-center">
            <button onclick="closeLandingModal()" class="px-10 py-3 rounded bg-camp-gold text-camp-dark-grey font-bold hover:bg-yellow-600 transition-colors text-lg">
                حسناً
            </button>
        </div>
    </div>
</div>

<script>
    let currentSlide = 0;
    const totalSlides = 4;

    function slideTo(index) {
        currentSlide = index;
        const track = document.getElementById('sliderTrack');
        track.style.transform = `translateX(-${index * 100}%)`;

        document.querySelectorAll('#sliderDots span').forEach((dot, i) => {
            dot.className = i === index ? 'w-3 h-3 rounded-full bg-camp-gold cursor-pointer' : 'w-3 h-3 rounded-full bg-white/50 cursor-pointer';
        });
    }

    function slideNext() {
        slideTo((currentSlide + 1) % totalSlides);
    }

    function slidePrev() {
        slideTo((currentSlide - 1 + totalSlides) % totalSlides);
    }

    // Auto-slide every 5 seconds
    setInterval(slideNext, 5000);

    function closeLandingModal() {
        document.getElementById('landing-modal').classList.add('hidden');
        document.getElementById('landing-modal').classList.remove('flex');
    }

    document.addEventListener('DOMContentLoaded', function () {
        const modal = document.getElementById('landing-modal');
        if (modal) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
    });
</script>
