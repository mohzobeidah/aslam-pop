                <!-- Navigation -->
                <div class="flex justify-between pt-6">
                    <button type="button" id="prevBtn" onclick="prevStep()" class="px-6 py-2 rounded border border-camp-gold text-camp-gold hover:bg-camp-gold hover:text-camp-dark-grey transition-colors hidden">
                        السابق
                    </button>
                    <div id="navSpacer"></div>
                    <button type="button" id="nextBtn" onclick="nextStep()" class="px-8 py-2 rounded bg-camp-gold text-camp-dark-grey font-bold hover:bg-yellow-600 transition-colors">
                        التالي
                    </button>
                    <button type="submit" id="submitBtn" onclick="return submitForm()" class="px-8 py-2 rounded bg-green-600 text-white font-bold hover:bg-green-700 transition-colors hidden">
                        تأكيد وإرسال
                    </button>
