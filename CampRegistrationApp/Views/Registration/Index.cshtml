        function addMember() {
            addMemberWithData(null);
        }

        function removeMember(btn) {
            btn.closest('.member-card').remove();
            if (document.querySelectorAll('.member-card').length === 0) {
                document.getElementById('no-members-msg')?.classList.remove('hidden');
            }
            saveToLocalStorage();
