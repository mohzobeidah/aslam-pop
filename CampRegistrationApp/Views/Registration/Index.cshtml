            </form>
        </div>
    </div>

    <style>
        .field-error { border-color: #ef4444 !important; }
        .field-error:focus { border-color: #ef4444 !important; box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.3); }
        .id-error { display: block; margin-top: 4px; }
        .id-error.hidden { display: none; }
        .phone-error { display: block; margin-top: 4px; }
        .phone-error.hidden { display: none; }
        .wallet-error { display: block; margin-top: 4px; }
        .wallet-error.hidden { display: none; }
    </style>

    <script>
        // ========== LOOKUP DATA FROM DB ==========
        const HEALTH_STATUSES = @Html.Raw(Json.Serialize(((List<CampRegistrationApp.Models.HealthStatus>)ViewBag.HealthStatuses).Select(h => h.Name)));
        const CHRONIC_DISEASES = @Html.Raw(Json.Serialize(((List<CampRegistrationApp.Models.ChronicDisease>)ViewBag.ChronicDiseases).Select(c => c.Name)));
        const DISABILITY_TYPES = @Html.Raw(Json.Serialize(((List<CampRegistrationApp.Models.DisabilityType>)ViewBag.DisabilityTypes).Select(d => d.Name)));
        const DESIRES = @Html.Raw(Json.Serialize(((List<CampRegistrationApp.Models.Desire>)ViewBag.Desires).Select(d => new { d.Id, d.Name })));

        // ========== LOCALSTORAGE ==========
        const STORAGE_KEY = 'campRegistration';

        // ========== VALIDATION HELPERS (early definition for on* handlers in HTML) ==========

        function validatePalestinianId(id) {
            if (!/^\d{9}$/.test(id)) return false;
            var weights = [1, 2, 1, 2, 1, 2, 1, 2];
            var sum = 0;
            for (var i = 0; i < 8; i++) {
                var product = parseInt(id[i]) * weights[i];
                sum += product >= 10 ? Math.floor(product / 10) + (product % 10) : product;
            }
            var checkDigit = (10 - (sum % 10)) % 10;
            return checkDigit === parseInt(id[8]);
        }

        function validateIdField(el) {
            const val = el.value.trim();
            const errorSpan = el.parentElement.querySelector('.id-error');
            if (!errorSpan) return true;
            if (val && !validatePalestinianId(val)) {
                errorSpan.classList.remove('hidden');
                el.classList.add('field-error');
                return false;
            }
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
            return true;
        }

        function clearIdError(el) {
            const errorSpan = el.parentElement.querySelector('.id-error');
            if (!errorSpan) return;
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
        }

        function validateMotherIdField(el) {
            const val = el.value.trim();
            const errorSpan = el.parentElement.querySelector('.mother-id-error');
            if (!errorSpan) return true;
            if (val && !validatePalestinianId(val)) {
                errorSpan.classList.remove('hidden');
                el.classList.add('field-error');
                return false;
            }
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
            return true;
        }

        function clearMotherIdError(el) {
            const errorSpan = el.parentElement.querySelector('.mother-id-error');
            if (!errorSpan) return;
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
        }

        function clearDuplicateWarning(el) {
            const warnSpan = el.parentElement.querySelector('.dup-warning');
            if (warnSpan) {
                warnSpan.classList.add('hidden');
                warnSpan.innerHTML = '';
            }
        }

        function clearPhoneError(el) {
            const errorSpan = el.parentElement.querySelector('.phone-error');
            if (!errorSpan) return;
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
        }

        function clearWalletError(el) {
            const errorSpan = el.parentElement.querySelector('.wallet-error');
            if (!errorSpan) return;
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
        }

        function validatePhoneField(el) {
            const val = el.value.trim();
            const errorSpan = el.parentElement.querySelector('.phone-error');
            if (!errorSpan) return true;
            if (val && !/^(\+972|05|00972)\d{8,9}$/.test(val)) {
                errorSpan.classList.remove('hidden');
                el.classList.add('field-error');
                return false;
            }
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
            return true;
        }

        function validateWalletField(el) {
            const val = el.value.trim();
            const errorSpan = el.parentElement.querySelector('.wallet-error');
            if (!errorSpan) return true;
            if (val && !/^\d{8,15}$/.test(val)) {
                errorSpan.classList.remove('hidden');
                el.classList.add('field-error');
                return false;
            }
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
            return true;
        }

        function checkDuplicateId(el) {
            const val = el.value.trim();
            const warningSpan = el.parentElement.querySelector('.dup-warning');
            if (!val || val.length !== 9 || !warningSpan) return;
            fetch(`/Registration/CheckId?id=${encodeURIComponent(val)}`)
                .then(r => r.json())
                .then(data => {
                    if (data.exists) {
                        warningSpan.textContent = '⚠ هذا الرقم مسجل مسبقاً. تسجيل الدخول لتعديل بياناتك';
                        warningSpan.classList.remove('hidden');
                    } else {
                        warningSpan.classList.add('hidden');
                        warningSpan.innerHTML = '';
                    }
                })
                .catch(() => {});
        }

        function saveToLocalStorage() {
            // Collect all form data into the hidden members container first
            collectMembersToHidden();

            const form = document.getElementById('registrationForm');
            const data = {};

            // Collect regular inputs/selects/textareas with data-ls attribute
            form.querySelectorAll('[data-ls]').forEach(el => {
                if (el.type === 'radio') {
                    if (el.checked) {
                        data[el.getAttribute('data-ls')] = el.value;
                    }
                } else if (el.type === 'checkbox') {
                    if (el.name.endsWith('ChronicDiseases') || el.name.endsWith('DisabilityTypes')) {
                        const key = el.getAttribute('data-ls');
                        if (!data[key]) data[key] = [];
                        if (el.checked) data[key].push(el.value);
                    } else {
                        data[el.getAttribute('data-ls')] = el.checked;
                    }
                } else {
                    data[el.getAttribute('data-ls')] = el.value;
                }
            });

            // Collect members from member cards
            const memberCards = document.querySelectorAll('.member-card');
            const members = [];
            memberCards.forEach((card, idx) => {
                const m = {};
                card.querySelectorAll('[name]').forEach(el => {
                    const name = el.getAttribute('name');
                    const key = name.replace(`Members[${idx}].`, '');
                    if (el.type === 'radio') {
                        if (el.checked) m[key] = el.value;
                    } else if (el.type === 'checkbox' && !el.name.includes('ChronicDiseases') && !el.name.includes('DisabilityTypes')) {
                        m[key] = el.checked;
                    } else if (el.type === 'checkbox' && (el.name.includes('ChronicDiseases') || el.name.includes('DisabilityTypes'))) {
                        const arrKey = key;
                        if (!m[arrKey]) m[arrKey] = [];
                        if (el.checked) m[arrKey].push(el.value);
                    } else {
                        m[key] = el.value;
                    }
                });
                members.push(m);
            });
            data['Members'] = members;

            // Save desire IDs from the hidden input
            const desireInput = document.getElementById('desireIdsInput');
            if (desireInput && desireInput.value) {
                data['DesireIds'] = desireInput.value;
            }

            localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        }

        function loadFromLocalStorage() {
            const saved = localStorage.getItem(STORAGE_KEY);
            if (!saved) return;

            let data;
            try { data = JSON.parse(saved); } catch { return; }

            // Restore regular fields
            Object.keys(data).forEach(key => {
                if (key === 'Members') return;
                const el = document.querySelector(`[data-ls="${key}"]`);
                if (!el) return;

                const val = data[key];
                if (el.type === 'radio') {
                    const radio = document.querySelector(`[data-ls="${key}"][value="${val}"]`);
                    if (radio) radio.checked = true;
                    if (key.includes('HealthStatus')) triggerEvent(radio, 'change');
                    if (key.includes('LivesInTent')) triggerEvent(radio, 'change');
                    if (key.includes('HasBathroom')) triggerEvent(radio, 'change');
                } else if (el.type === 'checkbox') {
                    if (Array.isArray(val)) {
                        val.forEach(v => {
                            const cb = document.querySelector(`[data-ls="${key}"][value="${v}"]`);
                            if (cb) cb.checked = true;
                        });
                    } else {
                        el.checked = val === true || val === 'true';
                        if (key.includes('HasInjury')) triggerEvent(el, 'change');
                        if (key.includes('IsPregnant')) triggerEvent(el, 'change');
                        if (key.includes('IsNursing')) triggerEvent(el, 'change');
                        if (key.includes('IsChildHeaded')) triggerEvent(el, 'change');
                        if (key.includes('IsFemaleHeaded')) triggerEvent(el, 'change');
                        if (key.includes('SupportsOutsidePerson')) triggerEvent(el, 'change');
                        if (key.includes('IsHouseDestroyed')) triggerEvent(el, 'change');
                    }
                } else {
                    el.value = val || '';
                }
            });

            // Restore members
            if (data.Members && Array.isArray(data.Members)) {
                data.Members.forEach((m, i) => {
                    addMemberWithData(m);
                });
            }

            // Restore desires
            if (data.DesireIds) {
                const desireInput = document.getElementById('desireIdsInput');
                if (desireInput) desireInput.value = data.DesireIds;
            }

            // Step indicator
            restoreStepUI();
        }

        function triggerEvent(el, eventName) {
            if (el) {
                const event = new Event(eventName, { bubbles: true });
                el.dispatchEvent(event);
            }
        }

        // ========== STEP NAVIGATION ==========
        let currentStep = 1;

        function goToStep(step) {
            if (step < 1 || step > 4) return;
            currentStep = step;

            document.querySelectorAll('.step').forEach(s => s.classList.add('hidden'));
            document.getElementById(`step-${step}`).classList.remove('hidden');

            for (let i = 1; i <= 4; i++) {
                const indicator = document.getElementById(`step-indicator-${i}`);
                const label = document.getElementById(`step-label-${i}`);
                if (i === step) {
                    indicator.className = 'w-10 h-10 rounded-full flex items-center justify-center border-2 border-camp-gold bg-camp-gold text-camp-dark-grey transition-colors';
                    label.className = 'text-xs mt-2 text-camp-gold';
                } else if (i < step) {
                    indicator.className = 'w-10 h-10 rounded-full flex items-center justify-center border-2 border-green-500 bg-green-500 text-white transition-colors';
                    label.className = 'text-xs mt-2 text-green-500';
                } else {
                    indicator.className = 'w-10 h-10 rounded-full flex items-center justify-center border-2 border-gray-600 text-gray-500 transition-colors';
                    label.className = 'text-xs mt-2 text-gray-500';
                }
            }

            document.getElementById('prevBtn').classList.toggle('hidden', step === 1);
            document.getElementById('nextBtn').classList.toggle('hidden', step === 4);
            document.getElementById('submitBtn').classList.toggle('hidden', step !== 4);

            if (step === 3) renderDesires();
            if (step === 4) renderReview();
        }

        // ========== DESIRES (DYNAMIC RANKING) ==========
        function renderDesires() {
            const container = document.getElementById('desires-container');
            if (!container) return;

            // Clear container to allow re-rendering
            container.innerHTML = '';

            console.log('Rendering desires with data:', DESIRES);

            const selected = getSavedDesireIds();
            const RANK_COUNT = 5;

            if (!DESIRES || DESIRES.length === 0) {
                container.innerHTML = '<p class="text-gray-500 text-center col-span-full">لا توجد رغبات متاحة حالياً</p>';
                return;
            }

            for (let i = 1; i <= RANK_COUNT; i++) {
                const order = i;
                const wrapper = document.createElement('div');
                wrapper.className = 'flex items-center gap-3 p-2 bg-camp-dark-grey/50 rounded border border-gray-700';
                wrapper.id = `desire-wrapper-${order}`;

                const label = document.createElement('label');
                label.className = 'text-sm text-gray-300 min-w-fit';
                label.textContent = `الرغبة ${order}:`;
                wrapper.appendChild(label);

                const select = document.createElement('select');
                select.className = 'w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none text-white desire-select';
                select.setAttribute('data-order', order);
                select.name = `Desires[${i-1}]`;

                const blank = document.createElement('option');
                blank.value = '';
                blank.textContent = 'اختر الرغبة...';
                select.appendChild(blank);

                DESIRES.forEach(d2 => {
                    const id = d2.Id !== undefined ? d2.Id : d2.id;
                    const name = d2.Name !== undefined ? d2.Name : d2.name;

                    const opt = document.createElement('option');
                    opt.value = id;
                    opt.textContent = name;
                    select.appendChild(opt);
                });

                // Restore saved selection
                if (selected.length >= i && selected[i-1]) {
                    select.value = selected[i-1];
                }

                select.addEventListener('change', function () {
                    updateDesireOptions();
                    saveDesireIds();
                });

                wrapper.appendChild(select);
                container.appendChild(wrapper);
            }

            updateDesireOptions();
        }

        function updateDesireOptions() {
            const selects = document.querySelectorAll('.desire-select');

            selects.forEach((sel, index) => {
                const curOrder = parseInt(sel.getAttribute('data-order'));

                // First, check if the current value is already selected in an earlier rank
                // If so, reset this select to blank to prevent duplicates
                if (sel.value !== '') {
                    const duplicateInEarlier = Array.from(selects).some(s => {
                        const sOrder = parseInt(s.getAttribute('data-order'));
                        return sOrder < curOrder && s.value === sel.value;
                    });
                    if (duplicateInEarlier) {
                        sel.value = '';
                    }
                }

                // Then, update all options based on earlier selections
                Array.from(sel.options).forEach(opt => {
                    if (opt.value === '') return;

                    const isSelectedInEarlier = Array.from(selects).some(s => {
                        const sOrder = parseInt(s.getAttribute('data-order'));
                        return sOrder < curOrder && s.value === opt.value;
                    });

                    opt.disabled = isSelectedInEarlier;
                    opt.hidden = isSelectedInEarlier;
                });
            });
        }

        function getSavedDesireIds() {
            const input = document.getElementById('desireIdsInput');
            if (input && input.value) {
                return input.value.split(',').map(s => parseInt(s.trim())).filter(n => !isNaN(n) && n > 0);
            }
            return [];
        }

        function saveDesireIds() {
            const selects = document.querySelectorAll('.desire-select');
            const ids = [];
            selects.forEach(sel => {
                if (sel.value) ids.push(sel.value);
            });
            const input = document.getElementById('desireIdsInput');
            if (input) input.value = ids.join(',');
            saveToLocalStorage();
        }

        function nextStep() {
            tryGoToStep(currentStep + 1);
        }

        function prevStep() {
            saveToLocalStorage();
            goToStep(currentStep - 1);
        }

        function tryGoToStep(step) {
            if (step === currentStep) return;
            if (step > currentStep) {
                for (let s = currentStep; s < step; s++) {
                    if (s === 1 && !validateStep1()) { goToStep(1); return false; }
                    if (s === 2 && !validateStep2()) { goToStep(2); return false; }
                    if (s === 3 && !validateStep3()) { goToStep(3); return false; }
                }
            }
            saveToLocalStorage();
            goToStep(step);
            return true;
        }

        function restoreStepUI() {
            // Default to step 1 on fresh load
            goToStep(1);
        }

        // ========== VALIDATION ==========

        function validateStep1() {
            const fieldLabels = {
                'Head.FirstName': 'الاسم الأول',
                'Head.SecondName': 'الاسم الثاني',
                'Head.ThirdName': 'الاسم الثالث',
                'Head.LastName': 'اسم العائلة',
                'Head.IdNumber': 'رقم الهوية',
                'Head.Sector': 'القاطع',
                'Head.DateOfBirth': 'تاريخ الميلاد',
                'Head.PhoneNumber': 'رقم الهاتف',
                'Head.Wallet': 'المحفظة',
                'Head.OriginalGovernorate': 'مكان السكن الأصلي',
                'Head.MaritalStatus': 'الحالة الاجتماعية',
                'Head.EmploymentStatus': 'الوظيفة',
                'Head.EducationLevel': 'المستوى التعليمي'
            };
            let valid = true;
            let missingFields = [];
            for (const [key, label] of Object.entries(fieldLabels)) {
                const el = document.querySelector(`[data-ls="${key}"]`);
                if (!el || !el.value.trim()) {
                    highlightError(el);
                    missingFields.push(label);
                    valid = false;
                } else {
                    clearHighlight(el);
                }
            }
            // Validate Gender radio
            const genderChecked = document.querySelector('[name="Head.Gender"]:checked');
            if (!genderChecked) {
                const genderRadios = document.querySelectorAll('[name="Head.Gender"]');
                genderRadios.forEach(r => highlightError(r.parentElement));
                missingFields.push('الجنس');
                valid = false;
            } else {
                document.querySelectorAll('[name="Head.Gender"]').forEach(r => clearHighlight(r.parentElement));
            }
            // Validate HealthStatus radio
            const healthChecked = document.querySelector('[name="Head.HealthStatus"]:checked');
            if (!healthChecked) {
                const healthRadios = document.querySelectorAll('[name="Head.HealthStatus"]');
                healthRadios.forEach(r => highlightError(r.parentElement));
                missingFields.push('الحالة الصحية');
                valid = false;
            } else {
                document.querySelectorAll('[name="Head.HealthStatus"]').forEach(r => clearHighlight(r.parentElement));
            }
            // Validate ID format
            const idEl = document.querySelector('[data-ls="Head.IdNumber"]');
            if (idEl && idEl.value && !validateIdField(idEl)) {
                valid = false;
            }
            // Validate phone format
            const phoneEl = document.querySelector('[data-ls="Head.PhoneNumber"]');
            if (phoneEl && phoneEl.value && !validatePhoneField(phoneEl)) {
                missingFields.push('رقم الهاتف (صيغة غير صحيحة)');
                valid = false;
            }
            // Validate wallet format
            const walletEl = document.querySelector('[data-ls="Head.Wallet"]');
            if (walletEl && walletEl.value && !validateWalletField(walletEl)) {
                missingFields.push('المحفظة (صيغة غير صحيحة)');
                valid = false;
            }
            // Validate: if sick, require chronic disease or disability
            const healthRadios = document.querySelectorAll('[name="Head.HealthStatus"]');
            let isSick = false;
            healthRadios.forEach(r => { if (r.checked && r.value !== 'سليم') isSick = true; });
            if (isSick) {
                const diseases = document.querySelectorAll('[name="Head.ChronicDiseases"]:checked');
                const disabilities = document.querySelectorAll('[name="Head.DisabilityTypes"]:checked');
                if (diseases.length === 0 && disabilities.length === 0) {
                    alert('الحالة الصحية مريض، يرجى اختيار مرض مزمن أو نوع إعاقة على الأقل');
                    valid = false;
                }
            }
            if (!valid && missingFields.length > 0) {
                alert('الحقول التالية مطلوبة:\n- ' + missingFields.join('\n- '));
            }
            return valid;
        }

        function validateStep2() {
            const cards = document.querySelectorAll('.member-card');
            if (cards.length === 0) return true;
            let valid = true;
            const memberLabels = ['الاسم الأول', 'رقم الهوية', 'صلة القرابة', 'الجنس', 'تاريخ الميلاد'];
            const memberKeys = ['.FirstName', '.IdNumber', '.RelationshipToHead', '.Gender', '.DateOfBirth'];
            cards.forEach((card, idx) => {
                let memberMissing = [];
                memberKeys.forEach((key, ki) => {
                    const el = card.querySelector(`[name$="${key}"]`);
                    if (!el || !el.value.trim()) {
                        highlightError(el);
                        memberMissing.push(memberLabels[ki]);
                        valid = false;
                    } else {
                        clearHighlight(el);
                    }
                });
                // Validate member ID format
                const idEl = card.querySelector('[name$=".IdNumber"]');
                if (idEl && idEl.value && !validateIdField(idEl)) {
                    valid = false;
                }
                // Validate: if sick, require disease/disability
                const healthRadios = card.querySelectorAll('[name$=".HealthStatus"]');
                let isSick = false;
                healthRadios.forEach(r => { if (r.checked && r.value !== 'سليم') isSick = true; });
                if (isSick) {
                    const diseases = card.querySelectorAll('[name$=".ChronicDiseases"]:checked');
                    const disabilities = card.querySelectorAll('[name$=".DisabilityTypes"]:checked');
                    if (diseases.length === 0 && disabilities.length === 0) {
                        alert(`الفرد رقم ${idx + 1}: الحالة الصحية مريض، يرجى اختيار مرض مزمن أو نوع إعاقة على الأقل`);
                        valid = false;
                    }
                }
                if (memberMissing.length > 0) {
                    alert(`الفرد رقم ${idx + 1}: الحقول التالية مطلوبة:\n- ` + memberMissing.join('\n- '));
                }
            });

            // Validate: no duplicate ID numbers among members and head
            const allIdEls = [document.querySelector('[name="Head.IdNumber"]'), ...Array.from(cards).map(c => c.querySelector('[name$=".IdNumber"]'))];
            const idValues = allIdEls.map(el => el?.value?.trim()).filter(v => v);
            if (new Set(idValues).size !== idValues.length) {
                alert('يوجد تكرار في أرقام الهوية. يجب أن يكون لكل شخص رقم هوية فريد.');
                valid = false;
            }

            // Validate: if married, require a wife member
            const maritalRadios = document.querySelectorAll('[name="Head.MaritalStatus"]');
            let isMarried = false;
            maritalRadios.forEach(r => { if (r.checked && r.value === 'متزوج') isMarried = true; });
            if (isMarried) {
                const hasWife = Array.from(cards).some(card => {
                    const rel = card.querySelector('[name$=".RelationshipToHead"]');
                    return rel && rel.value === 'زوجة';
                });
                if (!hasWife) {
                    alert('بما أن الحالة الاجتماعية متزوج، يجب إضافة فرد بصفة زوجة');
                    valid = false;
                }
            }

            return valid;
        }

        function highlightError(el) {
            if (!el) return;
            el.classList.add('field-error');
        }

        function clearHighlight(el) {
            if (!el) return;
            el.classList.remove('field-error');
        }

        function validateStep3() {
            let valid = true;

            // Validate desires (all must be selected)
            const selects = document.querySelectorAll('.desire-select');
            let allSelected = true;
            selects.forEach(sel => {
                if (!sel.value) allSelected = false;
            });
            if (!allSelected) {
                alert('يرجى ترتيب جميع الرغبات (اختيار قيمة لكل رغبة)');
                valid = false;
            }

            // Validate LivesInTent radio
            const livesInTentYes = document.querySelector('[name="LivesInTent"][value="true"]');
            if (livesInTentYes && livesInTentYes.checked) {
                const tentType = document.querySelector('[name="TentType"]');
                if (!tentType || !tentType.value) {
                    highlightError(tentType);
                    alert('يرجى اختيار نوع الخيمة');
                    valid = false;
                } else {
                    clearHighlight(tentType);
                }
            }

            // Validate HasBathroom radio -> requires BathroomType + BathroomStatus
            const hasBathroomYes = document.querySelector('[name="HasBathroom"][value="true"]');
            if (hasBathroomYes && hasBathroomYes.checked) {
                const bathroomTypeChecked = document.querySelector('[name="BathroomType"]:checked');
                if (!bathroomTypeChecked) {
                    document.querySelectorAll('[name="BathroomType"]').forEach(r => highlightError(r.parentElement));
                    alert('يرجى اختيار نوع الحمام');
                    valid = false;
                } else {
                    document.querySelectorAll('[name="BathroomType"]').forEach(r => clearHighlight(r.parentElement));
                }
                const bathStatus = document.querySelector('[data-ls="Head.BathroomStatus"]');
                if (!bathStatus || !bathStatus.value) {
                    highlightError(bathStatus);
                    alert('يرجى اختيار حالة الحمام');
                    valid = false;
                } else {
                    clearHighlight(bathStatus);
                }
            }

            return valid;
        }

