                                <label class="block text-sm mb-1">تأكيد كلمة المرور</label>
                                <input type="password" id="regConfirmPassword" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
