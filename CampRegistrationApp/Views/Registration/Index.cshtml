@model CampRegistrationApp.Models.ViewModels.RegistrationViewModel
@{
    Layout = "_Layout";
}

<div class="min-h-screen bg-camp-dark-grey text-white font-cairo" dir="rtl">
    <div class="container mx-auto px-4 py-8">
        <header class="text-center mb-12">
            <h1 class="text-4xl font-bold text-camp-gold mb-2">نموذج تسجيل العائلات</h1>
            <p class="text-gray-400">يتم حفظ البيانات تلقائياً في المتصفح</p>
        </header>

        <div class="max-w-4xl mx-auto">
            <!-- Messages -->
            @if (TempData["Success"] is string successMsg)
            {
                <div class="bg-green-900/50 text-green-300 p-4 rounded-lg mb-4 text-sm border border-green-700">@Html.Raw(successMsg)</div>
            }
            @if (TempData["Error"] is string errorMsg)
            {
                <div class="bg-red-900/50 text-red-300 p-4 rounded-lg mb-4 text-sm border border-red-700">@Html.Raw(errorMsg)</div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-900/50 text-red-300 p-4 rounded-lg mb-4 text-sm border border-red-700">
                    <ul class="list-disc list-inside">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@Html.Raw(err.ErrorMessage)</li>
                        }
                    </ul>
                </div>
            }

            <!-- Stepper -->
            <div class="flex justify-between mb-8">
                <div class="flex flex-col items-center flex-1 cursor-pointer" onclick="tryGoToStep(1)">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center border-2 transition-colors" id="step-indicator-1">
                        1
                    </div>
                    <span class="text-xs mt-2" id="step-label-1">رب الأسرة</span>
                </div>
                <div class="flex flex-col items-center flex-1 cursor-pointer" onclick="tryGoToStep(2)">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center border-2 transition-colors" id="step-indicator-2">
                        2
                    </div>
                    <span class="text-xs mt-2" id="step-label-2">أفراد الأسرة</span>
                </div>
                <div class="flex flex-col items-center flex-1 cursor-pointer" onclick="tryGoToStep(3)">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center border-2 transition-colors" id="step-indicator-3">
                        3
                    </div>
                    <span class="text-xs mt-2" id="step-label-3">السكن</span>
                </div>
                <div class="flex flex-col items-center flex-1 cursor-pointer" onclick="tryGoToStep(4)">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center border-2 transition-colors" id="step-indicator-4">
                        4
                    </div>
                    <span class="text-xs mt-2" id="step-label-4">المراجعة</span>
                </div>
            </div>

            <form id="registrationForm" asp-action="Submit" method="post" class="space-y-6" enctype="multipart/form-data">
                <!-- ============ STEP 1: FAMILY HEAD ============ -->
                <div class="step bg-camp-accent-grey p-6 rounded-lg border-r-4 border-camp-gold shadow-xl" id="step-1">
                    <h2 class="text-2xl font-semibold text-camp-gold mb-6">بيانات رب الأسرة</h2>

                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                        <div>
                            <label class="block text-sm mb-1">الاسم الأول</label>
                            <input name="Head.FirstName" data-ls="Head.FirstName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الاسم الثاني</label>
                            <input name="Head.SecondName" data-ls="Head.SecondName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الاسم الثالث</label>
                            <input name="Head.ThirdName" data-ls="Head.ThirdName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">اسم العائلة</label>
                            <input name="Head.LastName" data-ls="Head.LastName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                        <div>
                            <label class="block text-sm mb-1">رقم الهوية</label>
                            <input name="Head.IdNumber" data-ls="Head.IdNumber" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required onblur="checkDuplicateId(this)" oninput="clearIdError(this); clearDuplicateWarning(this)" />
                            <span class="id-error text-red-500 text-xs hidden">رقم الهوية يجب أن يتكون من 9 أرقام</span>
                            <span class="dup-warning text-yellow-500 text-xs hidden"></span>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">القاطع</label>
                            <select name="Head.Sector" data-ls="Head.Sector" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>
                                <option value="">اختر القاطع...</option>
                                @foreach (var s in ViewBag.Sectors)
                                {
                                    <option value="@s.Name">@s.Name</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">تاريخ الميلاد</label>
                            <input name="Head.DateOfBirth" data-ls="Head.DateOfBirth" type="date" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الجنس</label>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="Head.Gender" data-ls="Head.Gender" value="ذكر" checked class="accent-camp-gold" onchange="saveToLocalStorage()" /> ذكر
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="Head.Gender" data-ls="Head.Gender" value="أنثى" class="accent-camp-gold" onchange="saveToLocalStorage()" /> أنثى
                                </label>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">رقم الهاتف</label>
                            <input name="Head.PhoneNumber" data-ls="Head.PhoneNumber" pattern="^(059|056)\d{7}$" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required oninput="clearPhoneError(this)" />
                            <span class="phone-error text-red-500 text-xs hidden">رقم الهاتف يجب أن يتكون من 10 أرقام ويبدأ بـ 059 أو 056</span>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">المحفظة</label>
                            <input name="Head.Wallet" data-ls="Head.Wallet" pattern="^(059|056)\d{7}$" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required oninput="clearWalletError(this)" />
                            <span class="wallet-error text-red-500 text-xs hidden">رقم المحفظة يجب أن يتكون من 10 أرقام ويبدأ بـ 059 أو 056</span>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">مكان السكن الأصلي</label>
                            <select name="Head.OriginalGovernorate" data-ls="Head.OriginalGovernorate" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>
                                <option value="">اختر المنطقة...</option>
                                <option value="غزة">غزة</option>
                                <option value="خانيونيس">خانيونيس</option>
                                <option value="شمال غزة">شمال غزة</option>
                                <option value="رفح">رفح</option>
                                <option value="دير البلح">دير البلح</option>
                                <option value="النصيرات">النصيرات</option>
                                <option value="المغازي">المغازي</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الحالة الاجتماعية</label>
                            <select name="Head.MaritalStatus" data-ls="Head.MaritalStatus" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>
                                <option value="">اختر الحالة...</option>
                                <option value="متزوج">متزوج</option>
                                <option value="أعزب">أعزب</option>
                                <option value="أرمل">أرمل</option>
                                <option value="مطلق">مطلق</option>
                                <option value="منفصل">منفصل</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الوظيفة</label>
                            <input name="Head.EmploymentStatus" data-ls="Head.EmploymentStatus" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">المستوى التعليمي</label>
                            <select name="Head.EducationLevel" data-ls="Head.EducationLevel" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>
                                <option value="">اختر...</option>
                                <option value="بدون">بدون</option>
                                <option value="ابتدائي">ابتدائي</option>
                                <option value="إعدادي">إعدادي</option>
                                <option value="ثانوي">ثانوي</option>
                                <option value="جامعي">جامعي</option>
                                <option value="دراسات عليا">دراسات عليا</option>
                            </select>
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="checkbox" name="Head.IsHouseDestroyed" data-ls="Head.IsHouseDestroyed" value="true" class="accent-camp-gold" onchange="saveToLocalStorage()" />
                            <label class="text-sm">المنزل مدمر</label>
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="checkbox" name="Head.IsPrisoner" data-ls="Head.IsPrisoner" value="true" class="accent-camp-gold" onchange="saveToLocalStorage()" />
                            <label class="text-sm">أسير</label>
                        </div>
                    </div>

                    <!-- Head ID Image -->
                    <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700 mb-6">
                        <label class="text-lg">صورة الهوية</label>
                        <input type="file" id="headIdFile" accept="image/*" onchange="uploadFile(this, 'IDImage', 'headIdPath')" class="text-sm text-gray-400" />
                        <input type="hidden" name="Head.HeadIdImagePath" id="headIdPath" data-ls="Head.HeadIdImagePath" />
                        <span id="headIdFile-name" class="text-xs text-camp-gold hidden"></span>
                    </div>

                    <div class="mt-8 border-t border-gray-700 pt-6">
                        <h3 class="text-xl font-semibold text-camp-gold mb-4">الحالة الصحية</h3>
                        <div class="flex gap-6 mb-6">
                            @{
                                var hsList = (List<CampRegistrationApp.Models.HealthStatus>)ViewBag.HealthStatuses;
                                var firstHealth = true;
                            }
                            @foreach (var hs in hsList)
                            {
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="Head.HealthStatus" data-ls="Head.HealthStatus" value="@hs.Name" @(firstHealth ? "checked" : "") class="accent-camp-gold" onchange="toggleHealthSection(this, 'head-health-details'); saveToLocalStorage()" /> @hs.Name
                                </label>
                                firstHealth = false;
                            }
                        </div>

                        <div id="head-health-details" class="hidden space-y-6">
                            <div class="p-4 bg-camp-dark-grey rounded border border-gray-700 mb-4">
                                <label class="block text-sm mb-1">إرفاق تقارير طبية أو صور</label>
                                <input type="file" id="headMedicalFile" accept="image/*,application/pdf" onchange="uploadFile(this, 'MedicalReport', 'headMedicalPath')" class="text-sm text-gray-400" />
                                <input type="hidden" name="Head.MedicalImagePath" id="headMedicalPath" data-ls="Head.MedicalImagePath" />
                                <span id="headMedicalFile-name" class="text-xs text-camp-gold hidden"></span>
                            </div>
                            <div>
                                <label class="block text-sm mb-2">الأمراض المزمنة</label>
                                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                                    @foreach (var disease in ViewBag.ChronicDiseases)
                                    {
                                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                                            <input type="checkbox" name="Head.ChronicDiseases" data-ls="Head.ChronicDiseases" value="@disease.Name" class="accent-camp-gold" onchange="saveToLocalStorage()" /> @disease.Name
                                        </label>
                                    }
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm mb-2">أنواع الإعاقة</label>
                                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                                    @foreach (var disability in ViewBag.DisabilityTypes)
                                    {
                                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                                            <input type="checkbox" name="Head.DisabilityTypes" data-ls="Head.DisabilityTypes" value="@disability.Name" class="accent-camp-gold" onchange="saveToLocalStorage()" /> @disability.Name
                                        </label>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Injury Section (always visible) -->
                        <div class="mt-6 border-t border-gray-700 pt-6">
                            <div class="flex items-center gap-2 mb-4">
                                <input type="checkbox" name="Head.HasInjury" data-ls="Head.HasInjury" value="true" class="accent-camp-gold" onchange="toggleInjurySection(this, 'head-injury-details'); saveToLocalStorage()" />
                                <label class="text-lg">هل تعرض لإصابة؟</label>
                            </div>
                            <div id="head-injury-details" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm mb-1">تاريخ الإصابة</label>
                                    <input type="date" name="Head.InjuryDate" data-ls="Head.InjuryDate" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                                </div>
                                <div>
                                    <label class="block text-sm mb-1">تفاصيل الإصابة</label>
                                    <textarea name="Head.InjuryDetails" data-ls="Head.InjuryDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" rows="2"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Female-specific fields -->
                        <div class="flex items-center gap-2 mt-4">
                            <input type="checkbox" name="Head.IsPregnant" data-ls="Head.IsPregnant" value="true" class="accent-camp-gold" onchange="toggleSectionCheckbox(this, 'head-pregnancy-details'); saveToLocalStorage()" />
                            <label class="text-sm">حامل</label>
                        </div>
                        <div id="head-pregnancy-details" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div>
                                <label class="block text-sm mb-1">شهر الحمل</label>
                                <select name="Head.PregnancyMonth" data-ls="Head.PregnancyMonth" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none">
                                    <option value="">اختر الشهر...</option>
                                    @for (int m = 1; m <= 9; m++)
                                    {
                                        <option value="@m">@m</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="flex items-center gap-2 mt-4">
                            <input type="checkbox" name="Head.IsNursing" data-ls="Head.IsNursing" value="true" class="accent-camp-gold" onchange="toggleSectionCheckbox(this, 'head-nursing-details'); saveToLocalStorage()" />
                            <label class="text-sm">مرضع</label>
                        </div>
                        <div id="head-nursing-details" class="hidden grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
                            <div>
                                <label class="block text-sm mb-1">اسم الطفل</label>
                                <input name="Head.NursingInfantName" data-ls="Head.NursingInfantName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                            </div>
                            <div>
                                <label class="block text-sm mb-1">تاريخ ميلاد الطفل</label>
                                <input type="date" name="Head.NursingInfantDOB" data-ls="Head.NursingInfantDOB" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                            </div>
                            <div>
                                <label class="block text-sm mb-1">رقم هوية الطفل</label>
                                <input name="Head.NursingInfantID" data-ls="Head.NursingInfantID" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ============ STEP 2: FAMILY MEMBERS ============ -->
                <div class="step hidden bg-camp-accent-grey p-6 rounded-lg border-r-4 border-camp-gold shadow-xl" id="step-2">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-2xl font-semibold text-camp-gold">أفراد الأسرة</h2>
                        <button type="button" onclick="addMember()" class="bg-camp-gold text-camp-dark-grey px-4 py-2 rounded font-bold hover:bg-yellow-600 transition-colors">
                            + إضافة فرد
                        </button>
                    </div>

                    <div id="members-container" class="space-y-6">
                        <!-- Members rendered by JS -->
                    </div>
                    <p id="no-members-msg" class="text-gray-500 text-center py-8">لم يتم إضافة أفراد بعد. اضغط على "إضافة فرد" للبدء.</p>
                </div>

                <!-- ============ STEP 3: HOUSING & SPECIAL ============ -->
                <div class="step hidden bg-camp-accent-grey p-6 rounded-lg border-r-4 border-camp-gold shadow-xl" id="step-3">
                    <h2 class="text-2xl font-semibold text-camp-gold mb-6">السكن والحالات الخاصة</h2>
                    <div class="space-y-6">
                        <!-- Child Headed -->
                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="IsChildHeaded" data-ls="IsChildHeaded" value="true" class="accent-camp-gold" onchange="toggleSectionCheckbox(this, 'child-headed-details'); saveToLocalStorage()" />
                            <label class="text-lg">رب الأسرة طفل (أقل من 18 سنة)</label>
                        </div>
                        <div id="child-headed-details" class="hidden p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <label class="block text-sm mb-1">تفاصيل</label>
                            <textarea name="ChildHeadedDetails" data-ls="ChildHeadedDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" rows="2"></textarea>
                        </div>

                        <!-- Female Headed -->
                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="IsFemaleHeaded" data-ls="IsFemaleHeaded" value="true" class="accent-camp-gold" onchange="toggleSectionCheckbox(this, 'female-headed-details'); saveToLocalStorage()" />
                            <label class="text-lg">ربة الأسرة امرأة (أرملة / مطلقة / زوجها غائب)</label>
                        </div>
                        <div id="female-headed-details" class="hidden p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <label class="block text-sm mb-1">تفاصيل</label>
                            <textarea name="FemaleHeadedDetails" data-ls="FemaleHeadedDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" rows="2"></textarea>
                        </div>

                        <!-- Husband Abroad -->
                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="IsHusbandAbroad" data-ls="IsHusbandAbroad" value="true" class="accent-camp-gold" onchange="saveToLocalStorage()" />
                            <label class="text-lg">الزوج خارج البلاد</label>
                        </div>

                        <!-- Outside Person -->
                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="SupportsOutsidePerson" data-ls="SupportsOutsidePerson" value="true" class="accent-camp-gold" onchange="toggleSectionCheckbox(this, 'outside-person-details'); saveToLocalStorage()" />
                            <label class="text-lg">هناك شخص خارج الأسرة مشمول في الكفالة</label>
                        </div>
                        <div id="outside-person-details" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <div>
                                <label class="block text-sm mb-1">الاسم</label>
                                <input name="OutsidePersonName" data-ls="OutsidePersonName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                            </div>
                            <div>
                                <label class="block text-sm mb-1">صلة القرابة</label>
                                <input name="OutsidePersonRelation" data-ls="OutsidePersonRelation" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                            </div>
                        </div>

                        <!-- Tent -->
                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <label class="text-lg">هل تسكن العائلة في خيمة؟</label>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="LivesInTent" data-ls="LivesInTent" value="true" class="accent-camp-gold" onchange="toggleSection(this, 'tent-details'); saveToLocalStorage()" /> نعم
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="LivesInTent" data-ls="LivesInTent" value="false" checked class="accent-camp-gold" onchange="toggleSection(this, 'tent-details'); saveToLocalStorage()" /> لا
                                </label>
                            </div>
                        </div>

                        <div id="tent-details" class="hidden p-4 bg-camp-dark-grey rounded border border-gray-700 space-y-4">
                            <label class="block text-sm mb-1">نوع الخيمة</label>
                            <select name="TentType" data-ls="TentType" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none">
                                <option value="">اختر النوع...</option>
                                <option value="Installation">تركيب</option>
                                <option value="Dome">قبة</option>
                                <option value="Emirati">إماراتية</option>
                                <option value="Qatari">قطرية</option>
                                <option value="Other">أخرى</option>
                            </select>
                            <input name="OtherTentType" data-ls="OtherTentType" placeholder="يرجى تحديد النوع الآخر" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                        </div>

                        <!-- Diapers -->
                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="NeedsDiapers" data-ls="NeedsDiapers" value="true" class="accent-camp-gold" onchange="toggleSectionCheckbox(this, 'diaper-details'); saveToLocalStorage()" />
                            <label class="text-lg">هل تحتاج العائلة حفائظ (لكبار السن أو آخرين)؟</label>
                        </div>
                        <div id="diaper-details" class="hidden p-4 bg-camp-dark-grey rounded border border-gray-700">
