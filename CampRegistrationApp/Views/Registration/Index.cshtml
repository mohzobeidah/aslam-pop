                                <div>
                                    <label class="block text-sm mb-1">حالة الحمام</label>
                                    <select name="Head.BathroomStatus" data-ls="Head.BathroomStatus" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none">
                                        <option value="">اختر...</option>
                                        <option value="جيد">جيد</option>
                                        <option value="متوسط">متوسط</option>
