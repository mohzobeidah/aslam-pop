                        <!-- Refugee Desires (رتب احتياجاتك) -->
                        <div class="p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <h3 class="text-lg font-semibold text-camp-gold mb-4">الرغبات (رتب احتياجاتك حسب الأهمية)</h3>
                            <div id="desires-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                                <!-- Filled by JS -->
                            </div>
                            <input type="hidden" name="DesireIds" id="desireIdsInput" value="" />
