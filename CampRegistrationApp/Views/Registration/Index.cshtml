                    <h4 class="text-md font-semibold text-camp-gold mb-3">الحالة الصحية</h4>
                    <div class="flex gap-4 mb-4">
                        ${HEALTH_STATUSES.map((hs, hi) =>
                            `<label class="flex items-center gap-2 cursor-pointer text-xs">
                                <input type="radio" name="Members[${idx}].HealthStatus" value="${hs}" class="accent-camp-gold" onchange="toggleMemberHealth(${idx})" ${(!data?.HealthStatus && hi === 0) || data?.HealthStatus === hs ? 'checked' : ''} /> ${hs}
                            </label>`
                        ).join('')}
                    </div>

                    <div id="member-health-${idx}" class="${data?.HealthStatus === 'مريض' ? '' : 'hidden'} space-y-4">
                        <div class="p-3 bg-camp-dark-grey rounded border border-gray-700">
                            <label class="block text-xs mb-1">إرفاق تقارير طبية أو صور</label>
                            <input type="file" id="memberMedicalFile_${idx}" accept="image/*,application/pdf" onchange="uploadFile(this, 'MedicalReport', 'memberMedicalPath_${idx}')" class="text-sm text-gray-400 w-full" />
                            <input type="hidden" name="Members[${idx}].MedicalImagePath" id="memberMedicalPath_${idx}" />
                            <span id="memberMedicalPath_${idx}-name" class="text-xs text-camp-gold hidden"></span>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs mb-1">الأمراض المزمنة</label>
                                <div class="grid grid-cols-2 gap-2">
                                    ${CHRONIC_DISEASES.map(d =>
                                        `<label class="flex items-center gap-1 text-xs">
                                            <input type="checkbox" name="Members[${idx}].ChronicDiseases" value="${d}" class="accent-camp-gold" ${(data?.ChronicDiseases || []).includes(d) ? 'checked' : ''} /> ${d}
                                        </label>`
                                    ).join('')}
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs mb-1">أنواع الإعاقة</label>
                                <div class="grid grid-cols-2 gap-2">
                                    ${DISABILITY_TYPES.map(d =>
                                        `<label class="flex items-center gap-1 text-xs">
                                            <input type="checkbox" name="Members[${idx}].DisabilityTypes" value="${d}" class="accent-camp-gold" ${(data?.DisabilityTypes || []).includes(d) ? 'checked' : ''} /> ${d}
                                        </label>`
                                    ).join('')}
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Injury Section (always visible for member) -->
                    <div class="border-t border-gray-700 pt-4 mt-4">
                        <div class="flex items-center gap-2 mb-4">
                            <input type="checkbox" name="Members[${idx}].HasInjury" value="true" class="accent-camp-gold" ${data?.HasInjury === true || data?.HasInjury === 'true' ? 'checked' : ''} onchange="toggleMemberInjury(${idx})" />
                            <label class="text-lg">هل تعرض لإصابة؟</label>
                        </div>
                        <div id="member-injury-${idx}" class="${data?.HasInjury === true || data?.HasInjury === 'true' ? '' : 'hidden'} grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs mb-1">تاريخ الإصابة</label>
                                <input type="date" name="Members[${idx}].InjuryDate" value="${data?.InjuryDate || ''}" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                            </div>
                            <div>
                                <label class="block text-xs mb-1">تفاصيل الإصابة</label>
                                <textarea name="Members[${idx}].InjuryDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" rows="2">${data?.InjuryDetails || ''}</textarea>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            // Add onchange save handlers to all inputs in the card
            card.querySelectorAll('input, select').forEach(el => {
                el.addEventListener('change', saveToLocalStorage);
                el.addEventListener('input', saveToLocalStorage);
            });

            container.appendChild(card);
            document.getElementById('no-members-msg')?.classList.add('hidden');
            saveToLocalStorage();
        }

        function addMember() {
            addMemberWithData(null);
        }

        function removeMember(btn) {
            btn.closest('.member-card').remove();
            if (document.querySelectorAll('.member-card').length === 0) {
                document.getElementById('no-members-msg')?.classList.remove('hidden');
            }
            saveToLocalStorage();
        }

        function toggleMemberHealth(idx) {
            const radios = document.querySelectorAll(`[name="Members[${idx}].HealthStatus"]`);
            let show = false;
            radios.forEach((r, i) => { if (r.checked && i > 0) show = true; });
            const section = document.getElementById(`member-health-${idx}`);
            if (section) section.classList.toggle('hidden', !show);
        }

        function toggleMemberInjury(idx) {
            const section = document.getElementById(`member-injury-${idx}`);
            if (section) section.classList.toggle('hidden');
        }

        function toggleMemberSection(idx, type) {
            const section = document.getElementById(`member-${type}-${idx}`);
            if (section) section.classList.toggle('hidden');
        }

        function collectMembersToHidden() {
            // This function exists to ensure member data is captured by saveToLocalStorage
            // Member inputs are already part of the form, so they are captured naturally
        }

        // ========== FILE UPLOAD ==========
        async function uploadFile(input, fileType, hiddenId) {
            if (!input.files || !input.files[0]) return;

            const formData = new FormData();
            formData.append('file', input.files[0]);

            // Show file name
            const fileNameSpan = document.getElementById(hiddenId + '-name');
            if (fileNameSpan) {
                fileNameSpan.textContent = input.files[0].name;
                fileNameSpan.classList.remove('hidden');
            }

            try {
                const response = await fetch('/Registration/UploadFile?personId=-1&fileType=' + fileType, {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();
                document.getElementById(hiddenId).value = result.path;
                saveToLocalStorage();
            } catch (error) {
                console.error('Error uploading file:', error);
                alert('حدث خطأ أثناء رفع الملف');
            }
        }

        // ========== TOGGLE FUNCTIONS ==========
        function toggleHealthSection(el, sectionId) {
            const section = document.getElementById(sectionId);
            const radios = document.querySelectorAll(`[name="${el.name}"]`);
            let isFirst = true;
            radios.forEach((r, i) => { if (r === el && i === 0) isFirst = true; if (r === el && i > 0) isFirst = false; });
            if (section) section.classList.toggle('hidden', isFirst);
        }

        function toggleInjurySection(el, sectionId) {
            const section = document.getElementById(sectionId);
            if (section) section.classList.toggle('hidden', !el.checked);
        }

        function toggleSection(el, sectionId) {
            const section = document.getElementById(sectionId);
            if (section) section.classList.toggle('hidden', el.value === 'false');
        }

        function toggleSectionCheckbox(el, sectionId) {
            const section = document.getElementById(sectionId);
            if (section) section.classList.toggle('hidden', !el.checked);
        }

        // ========== SUBMIT ==========
        function submitForm() {
            // Validate password
            const password = document.getElementById('regPassword').value;
            const confirm = document.getElementById('regConfirmPassword').value;
            const acceptResp = document.getElementById('acceptResponsibility').checked;

            let valid = true;

            if (!password || password.length < 4) {
                document.getElementById('passwordError').textContent = 'كلمة المرور يجب أن تكون 4 أحرف على الأقل';
                document.getElementById('passwordError').classList.remove('hidden');
                valid = false;
            } else if (password !== confirm) {
                document.getElementById('passwordError').textContent = 'كلمة المرور غير متطابقة';
                document.getElementById('passwordError').classList.remove('hidden');
                valid = false;
            } else {
                document.getElementById('passwordError').classList.add('hidden');
            }

            if (!acceptResp) {
                document.getElementById('responsibilityError').classList.remove('hidden');
                valid = false;
            } else {
                document.getElementById('responsibilityError').classList.add('hidden');
            }

            if (!valid) return false;

            // Validate all IDs before submit
            if (!validateStep1() || !validateStep2() || !validateStep3()) return false;

            saveToLocalStorage();

            const form = document.getElementById('registrationForm');

            // Add password fields as hidden inputs
            let pw = form.querySelector('input[type="hidden"][name="Password"]');
            if (!pw) {
                pw = document.createElement('input');
                pw.type = 'hidden';
                pw.name = 'Password';
                form.appendChild(pw);
            }
            pw.value = password;

            // Snapshot all visible input/select/textarea values into hidden inputs
            // to ensure they survive any browser quirks with steps inside display:none.
            form.querySelectorAll('input:not([type="checkbox"]):not([type="radio"]):not([type="hidden"]), select, textarea').forEach(el => {
                if (el.name) {
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = el.name;
                    hidden.value = el.value;
                    form.appendChild(hidden);
                }
            });

            // Disable ALL checkboxes + radios so only hidden inputs submit values
            form.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.disabled = true);
            form.querySelectorAll('input[type="radio"]').forEach(r => r.disabled = true);

            // Head radio values (Gender, HealthStatus)
            ['Head.Gender', 'Head.HealthStatus'].forEach(field => {
                const checked = document.querySelector(`[name="${field}"]:checked`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = field;
                hidden.value = checked?.value || '';
                form.appendChild(hidden);
            });

            // Members radio values (HealthStatus)
            document.querySelectorAll('.member-card').forEach((card, idx) => {
                const checked = card.querySelector(`[name="Members[${idx}].HealthStatus"]:checked`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = `Members[${idx}].HealthStatus`;
                hidden.value = checked?.value || '';
                form.appendChild(hidden);
            });

            // Registration radio values (LivesInTent, HasBathroom, BathroomType)
            ['LivesInTent', 'HasBathroom', 'BathroomType'].forEach(field => {
                const checked = document.querySelector(`[name="${field}"]:checked`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = field;
                hidden.value = checked?.value || 'false';
                form.appendChild(hidden);
            });

            // Head multi-value: ChronicDiseases, DisabilityTypes
            [['Head.ChronicDiseases'], ['Head.DisabilityTypes']].forEach(([name]) => {
                const checked = Array.from(form.querySelectorAll(`[name="${name}"]:checked`)).map(cb => cb.value);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = name;
                hidden.value = checked.join('، ');
                form.appendChild(hidden);
            });

            // Members multi-value + bools
            document.querySelectorAll('.member-card').forEach((card, idx) => {
                ['ChronicDiseases', 'DisabilityTypes'].forEach(field => {
                    const checked = Array.from(card.querySelectorAll(`[name="Members[${idx}].${field}"]:checked`)).map(cb => cb.value);
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = `Members[${idx}].${field}`;
                    hidden.value = checked.join('، ');
                    form.appendChild(hidden);
                });
                ['HasInjury', 'IsPregnant', 'IsNursing', 'IsPrisoner'].forEach(field => {
                    const cb = card.querySelector(`[name="Members[${idx}].${field}"]`);
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = `Members[${idx}].${field}`;
                    hidden.value = cb?.checked ? 'true' : 'false';
                    form.appendChild(hidden);
                });
            });

            // Head bools
            ['Head.IsHouseDestroyed', 'Head.IsPrisoner', 'Head.HasInjury', 'Head.IsPregnant', 'Head.IsNursing'].forEach(field => {
                const cb = form.querySelector(`[name="${field}"]`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = field;
                hidden.value = cb?.checked ? 'true' : 'false';
                form.appendChild(hidden);
            });

            // Registration-level bools
            ['NeedsDiapers', 'HasMultipleFamiliesInTent', 'IsChildHeaded', 'IsFemaleHeaded', 'SupportsOutsidePerson', 'IsHusbandAbroad'].forEach(field => {
                const cb = form.querySelector(`[name="${field}"]`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = field;
                hidden.value = cb?.checked ? 'true' : 'false';
                form.appendChild(hidden);
            });

            // Sync desires from dropdowns to hidden input before submission
            saveDesireIds();

            // Convert single comma-separated DesireIds input to indexed inputs for model binding
            const desireInput = document.getElementById('desireIdsInput');
            if (desireInput && desireInput.value) {
                const ids = desireInput.value.split(',').filter(Boolean);
                desireInput.remove();
                ids.forEach((id, i) => {
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = `DesireIds[${i}]`;
                    hidden.value = id.trim();
                    form.appendChild(hidden);
                });
            }

            // Block if any duplicate ID warnings exist
            const dupWarnings = document.querySelectorAll('.dup-warning:not(.hidden)');
            if (dupWarnings.length > 0) {
                dupWarnings[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
                return false;
            }

            return true;
        }

        // ========== INIT ==========
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-save on any input change (debounced)
            let saveTimer;
            document.addEventListener('input', function() {
                clearTimeout(saveTimer);
                saveTimer = setTimeout(saveToLocalStorage, 500);
            });
            document.addEventListener('change', function() {
                clearTimeout(saveTimer);
                saveTimer = setTimeout(saveToLocalStorage, 200);
            });

            loadFromLocalStorage();
        });
    </script>
</div>
