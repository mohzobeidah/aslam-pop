@model string
@{
    Layout = "_Layout";
}

<div class="min-h-screen bg-camp-dark-grey text-white font-cairo flex items-center justify-center" dir="rtl">
    <div class="text-center p-8 bg-camp-accent-grey rounded-lg border-t-4 border-camp-gold shadow-2xl max-w-md w-full">
        <div class="text-6xl text-camp-gold mb-4">✓</div>
        <h1 class="text-3xl font-bold text-camp-gold mb-4">تم التسجيل بنجاح</h1>
        <p class="text-gray-400 mb-2">شكراً لك، لقد تم حفظ بيانات العائلة بنجاح.</p>
        <p class="text-yellow-400 mb-6 text-sm">⏳ طلب التسجيل قيد المراجعة والموافقة من قبل المسؤول. سيتمكن الدخول للتعديل بعد الموافقة.</p>

        <div class="bg-camp-dark-grey p-4 rounded border border-gray-700 mb-8">
            <label class="block text-sm text-gray-500 mb-1">معرف التسجيل الخاص بك</label>
            <div class="text-3xl font-mono font-bold text-white tracking-widest">@Model</div>
        </div>

        <p class="text-xs text-gray-500">يرجى الاحتفاظ بهذا الرقم لمراجعة أو تعديل البيانات لاحقاً.</p>

        <div class="mt-8">
            <a href="@Url.Action("Index", "Registration")" class="bg-camp-gold text-camp-dark-grey px-6 py-2 rounded font-bold hover:bg-yellow-600 transition-colors">
                تسجيل عائلة أخرى
            </a>
        </div>
    </div>
</div>
