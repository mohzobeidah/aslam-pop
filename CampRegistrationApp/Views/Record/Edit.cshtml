        function reindexMembers() {
            const cards = document.querySelectorAll('.member-card');
            cards.forEach((card, idx) => {
                card.setAttribute('data-index', idx);
                const inputs = card.querySelectorAll('input, select, textarea');
                inputs.forEach(input => {
                    const name = input.name;
                    if (name && name.includes('Members[')) {
                        const newName = name.replace(/Members\[\d+\]/, `Members[${idx}]`);
                        input.name = newName;
                    }
                });
                const healthSection = card.querySelector(`[id^="member-health-"]`);
                if (healthSection) healthSection.id = `member-health-${idx}`;
                const injurySection = card.querySelector(`[id^="member-injury-"]`);
                if (injurySection) injurySection.id = `member-injury-${idx}`;
                const radios = card.querySelectorAll('input[type="radio"][name*=".HealthStatus"]');
                radios.forEach(r => r.name = `Members[${idx}].HealthStatus`);
                const checkboxes = card.querySelectorAll('input[type="checkbox"]');
                checkboxes.forEach(cb => {
                    const name = cb.name;
                    if (name && name.includes('Members[')) {
                        cb.name = name.replace(/Members\[\d+\]/, `Members[${idx}]`);
                    }
                });
            });
        }

        function removeMember(btn) {
            btn.closest('.member-card').remove();
            reindexMembers();
            if (document.querySelectorAll('.member-card').length === 0) {
                document.getElementById('no-members-msg')?.classList.remove('hidden');
            }
        }

        function toggleMemberHealth(idx) {
            const radios = document.querySelectorAll(`[name="Members[${idx}].HealthStatus"]`);
            let show = false;
            radios.forEach((r, i) => { if (r.checked && i > 0) show = true; });
            const section = document.getElementById(`member-health-${idx}`);
            if (section) section.classList.toggle('hidden', !show);
        }

        function toggleMemberInjury(idx) {
            const section = document.getElementById(`member-injury-${idx}`);
            if (section) section.classList.toggle('hidden');
        }

        function toggleFemaleFields(select, idx) {
            const label = document.querySelector(`.female-only-${idx}`);
