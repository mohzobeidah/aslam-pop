                        </div>
                        <div id="outside-person-details" class="@(Model.SupportsOutsidePerson ? "" : "hidden") grid grid-cols-1 md:grid-cols-2 gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <div><label class="block text-sm mb-1">الاسم</label><input name="OutsidePersonName" value="@Model.OutsidePersonName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" /></div>
                            <div><label class="block text-sm mb-1">صلة القرابة</label><input name="OutsidePersonRelation" value="@Model.OutsidePersonRelation" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" /></div>
                        </div>

                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <label>هل تسكن العائلة في خيمة؟</label>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="LivesInTent" value="true" class="accent-camp-gold" @(Model.LivesInTent ? "checked" : "") onchange="toggleSection(this, 'tent-details')" /> نعم
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="LivesInTent" value="false" class="accent-camp-gold" @(!Model.LivesInTent ? "checked" : "") onchange="toggleSection(this, 'tent-details')" /> لا
                                </label>
                            </div>
                        </div>
                        <div id="tent-details" class="@(Model.LivesInTent ? "" : "hidden") p-4 bg-camp-dark-grey rounded border border-gray-700 space-y-4">
                            <select name="TentType" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none">
                                <option value="">اختر النوع...</option>
                                @foreach (var t in new[] { "تركيب خشب وشوادر", "حديد وشوادر", "قبة", "إماراتية", "قطرية", "خيمة صينية", "خيمة قماش وخشب", "أخرى" })
                                {
                                    <option value="@t" selected="@(Model.TentType == t )">@t</option>
                                }
                            </select>
                            <input name="OtherTentType" value="@Model.OtherTentType" placeholder="يرجى تحديد النوع الآخر" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                        </div>

                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="NeedsDiapers" value="true" class="accent-camp-gold" @(Model.NeedsDiapers ? "checked" : "") onchange="toggleSection(this, 'diaper-details')" />
                            <label>هل تحتاج العائلة حفائظ (لكبار السن أو آخرين)؟</label>
                        </div>
                        <div id="diaper-details" class="@(Model.NeedsDiapers ? "" : "hidden") p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <textarea name="DiaperDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" rows="2">@Model.DiaperDetails</textarea>
                        </div>

                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="HasMultipleFamiliesInTent" value="true" class="accent-camp-gold" @(Model.HasMultipleFamiliesInTent ? "checked" : "") onchange="toggleSection(this, 'multiple-families-details')" />
                            <label>هل يوجد أكثر من عائلة تسكن في نفس الخيمة؟</label>
                        </div>
                        <div id="multiple-families-details" class="@(Model.HasMultipleFamiliesInTent ? "" : "hidden") p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <select name="AdditionalFamiliesCount" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none">
                                <option value="">اختر...</option>
                                @for (int af = 1; af <= 5; af++)
                                {
                                    <option value="@af" selected="@(Model.AdditionalFamiliesCount == af )">@af</option>
                                }
                                <option value="6" selected="@(Model.AdditionalFamiliesCount == 6 )">أكثر من 5</option>
                            </select>
                        </div>
                </div>
            </div>

            <!-- Bathroom -->
            <div class="mt-6 p-4 bg-camp-dark-grey rounded border border-gray-700">
                <h3 class="text-lg font-semibold text-camp-gold mb-3">الحمام</h3>
                <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                    <label>هل يوجد حمام؟</label>
                    <div class="flex gap-4">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="HasBathroom" value="true" class="accent-camp-gold" @(Model.HasBathroom ? "checked" : "") onchange="toggleSection(this, 'bathroom-details-edit')" /> نعم
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="HasBathroom" value="false" class="accent-camp-gold" @(!Model.HasBathroom ? "checked" : "") onchange="toggleSection(this, 'bathroom-details-edit')" /> لا
                        </label>
                    </div>
                </div>
                <div id="bathroom-details-edit" class="@(Model.HasBathroom ? "" : "hidden") space-y-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                    <div>
                        <label class="block text-sm mb-1">نوع الحمام</label>
                        <div class="flex gap-4">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="BathroomType" value="Private" class="accent-camp-gold" @(Model.BathroomType is "Private" or "خاص" ? "checked" : "") /> خاص
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="BathroomType" value="Shared" class="accent-camp-gold" @(Model.BathroomType is "Shared" or "مشترك" ? "checked" : "") /> مشترك
                            </label>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm mb-1">حالة الحمام</label>
                        <select name="Head.BathroomStatus" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none">
                            <option value="">اختر...</option>
                            <option value="جيد" selected="@(Model.Head.BathroomStatus == "جيد")">جيد</option>
                            <option value="متوسط" selected="@(Model.Head.BathroomStatus == "متوسط")">متوسط</option>
                            <option value="سيء" selected="@(Model.Head.BathroomStatus == "سيء")">سيء</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Refugee Desires -->
            <div class="mt-6 p-4 bg-camp-dark-grey rounded border border-gray-700">
                <h3 class="text-lg font-semibold text-camp-gold mb-3">الرغبات (رتب احتياجاتك حسب الأهمية)</h3>
                <div id="desires-container" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Filled by JS -->
                </div>
                <input type="hidden" name="DesireIds" id="desireIdsInput" value="@string.Join(",", Model.DesireIds)" />
            </div>

            <!-- Attachments -->
            <div class="mt-6 p-4 bg-camp-dark-grey rounded border border-gray-700">
                <h3 class="text-lg font-semibold text-camp-gold mb-3">المرفقات</h3>
                @{
                    var headAttachments = ViewBag.HeadAttachments as ICollection<CampRegistrationApp.Models.Attachment> ?? new List<CampRegistrationApp.Models.Attachment>();
                }
                @if (headAttachments.Any())
                {
                    <div class="flex flex-wrap gap-3">
                        @foreach (var att in headAttachments)
                        {
                            var label = att.FileType == "IDImage" ? "صورة الهوية" : "تقرير طبي";
                            <a href="/File/Download?path=@Uri.EscapeDataString(att.FilePath)" target="_blank" class="bg-camp-accent-grey border border-gray-600 rounded px-4 py-2 text-sm text-camp-gold hover:text-yellow-500 hover:border-camp-gold transition">
                                @label
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 text-sm">لا توجد مرفقات</p>
                }
            </div>

            <!-- Status Notes -->
            <div class="mt-6 p-4 bg-camp-dark-grey rounded border border-gray-700">
                <label class="block text-sm mb-2 text-camp-gold font-semibold">ملاحظات حول الحالة</label>
                <textarea name="StatusNotes" class="w-full p-3 rounded bg-camp-dark-grey border border-gray-600 outline-none" rows="3" placeholder="أي ملاحظات إضافية عن حالة العائلة...">@Model.StatusNotes</textarea>
            </div>

            <!-- Submit -->
            <div class="flex gap-4 justify-center pt-4">
                    <button type="submit" onclick="return submitEditForm()" class="px-10 py-3 rounded bg-green-600 text-white font-bold hover:bg-green-700 transition-colors text-lg">
                        حفظ التعديلات
                    </button>
                    <button type="button" onclick="confirmLogout()" class="px-6 py-3 rounded border border-gray-600 text-gray-400 hover:text-white hover:border-gray-400 transition-colors">
                        خروج
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (mustChangePassword)
{
    <div id="force-password-modal" class="fixed inset-0 z-[60] bg-black/80 flex items-center justify-center p-4">
        <div class="bg-camp-accent-grey rounded-lg border-r-4 border-red-500 shadow-2xl p-8 max-w-md w-full pointer-events-auto" role="dialog" aria-modal="true" aria-labelledby="force-password-title">
            <div class="text-center mb-6">
                <div class="text-4xl mb-3">🔒</div>
                <h3 id="force-password-title" class="text-2xl font-bold text-camp-gold">تغيير كلمة المرور مطلوب</h3>
                <p class="text-gray-300 mt-3 text-sm leading-relaxed">
                    كلمة المرور الحالية هي نفس رقم الهوية. لأسباب أمنية، يجب تعيين كلمة مرور جديدة مختلفة عن رقم الهوية قبل تعديل بيانات العائلة.
                </p>
            </div>

            @if (TempData["PasswordChangeError"] is string pwdErr)
            {
                <div class="bg-red-900/50 border border-red-500 text-red-300 p-3 rounded mb-4 text-sm text-center">@pwdErr</div>
            }

            <form method="post" asp-action="ChangePassword" asp-controller="Record" class="space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="force" value="true" />
                <div>
                    <label class="block text-sm mb-1">كلمة المرور الجديدة</label>
                    <input type="password" name="newPassword" id="forceNewPassword" required minlength="4" autocomplete="new-password"
                           class="w-full p-3 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                </div>
                <div>
                    <label class="block text-sm mb-1">تأكيد كلمة المرور الجديدة</label>
                    <input type="password" name="confirmPassword" id="forceConfirmPassword" required autocomplete="new-password"
                           class="w-full p-3 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                </div>
                <button type="submit" class="w-full py-3 rounded bg-camp-gold text-camp-dark-grey font-bold hover:bg-yellow-600 transition-colors">
                    حفظ كلمة المرور والمتابعة
                </button>
            </form>
            <form method="post" asp-action="Logout" asp-controller="Record" class="mt-4 text-center">
                @Html.AntiForgeryToken()
                <button type="submit" class="text-gray-400 text-sm hover:text-white underline">تسجيل الخروج</button>
            </form>
        </div>
    </div>
}



    <style>
        .field-error { border-color: #ef4444 !important; }
        .field-error:focus { border-color: #ef4444 !important; box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.3); }
        .id-error { display: block; margin-top: 4px; }
        .id-error.hidden { display: none; }
        .phone-error { display: block; margin-top: 4px; }
        .phone-error.hidden { display: none; }
        .wallet-error { display: block; margin-top: 4px; }
        .wallet-error.hidden { display: none; }
    </style>

    <script>
        // ========== LOOKUP DATA FROM DB ==========
        @{
            var hsList = ViewBag.HealthStatuses as List<CampRegistrationApp.Models.HealthStatus> ?? new();
            var cdList = ViewBag.ChronicDiseases as List<CampRegistrationApp.Models.ChronicDisease> ?? new();
            var dtList = ViewBag.DisabilityTypes as List<CampRegistrationApp.Models.DisabilityType> ?? new();
            var dList = ViewBag.Desires as List<CampRegistrationApp.Models.Desire> ?? new();
        }
        const HEALTH_STATUSES = @Html.Raw(Json.Serialize(hsList.Select(h => h.Name)));
        const CHRONIC_DISEASES = @Html.Raw(Json.Serialize(cdList.Select(c => c.Name)));
        const DISABILITY_TYPES = @Html.Raw(Json.Serialize(dtList.Select(d => d.Name)));
        const DESIRES = @Html.Raw(Json.Serialize(dList.Select(d => new { d.Id, d.Name })));

        let memberIdx = @Model.Members.Count;

        // ========== VALIDATION HELPERS ==========

        function highlightError(el) { if (el) { el.classList.add('field-error'); } }
        function clearHighlight(el) { if (el) { el.classList.remove('field-error'); } }

        function validatePalestinianId(id) {
            if (!/^\d{9}$/.test(id)) return false;
            var weights = [1, 2, 1, 2, 1, 2, 1, 2];
            var sum = 0;
            for (var i = 0; i < 8; i++) {
                var product = parseInt(id[i]) * weights[i];
                sum += product >= 10 ? Math.floor(product / 10) + (product % 10) : product;
            }
            var checkDigit = (10 - (sum % 10)) % 10;
            return checkDigit === parseInt(id[8]);
        }

        function validateIdField(el) {
            const val = el.value.trim();
            const errorSpan = el.parentElement.querySelector('.id-error');
            if (!errorSpan) return true;
            if (val && !validatePalestinianId(val)) {
                errorSpan.classList.remove('hidden');
                el.classList.add('field-error');
                return false;
            }
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
            return true;
        }

        function clearIdError(el) {
            const errorSpan = el.parentElement.querySelector('.id-error');
            if (!errorSpan) return;
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
        }

        function validateMotherIdField(el) {
            const val = el.value.trim();
            const errorSpan = el.parentElement.querySelector('.mother-id-error');
            if (!errorSpan) return true;
            if (val && !validatePalestinianId(val)) {
                errorSpan.classList.remove('hidden');
                el.classList.add('field-error');
                return false;
            }
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
            return true;
        }

        function clearMotherIdError(el) {
            const errorSpan = el.parentElement.querySelector('.mother-id-error');
            if (!errorSpan) return;
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
        }

        function clearPhoneError(el) {
            const errorSpan = el.parentElement.querySelector('.phone-error');
            if (!errorSpan) return;
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
        }

        function clearWalletError(el) {
            const errorSpan = el.parentElement.querySelector('.wallet-error');
            if (!errorSpan) return;
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
        }

        function validatePhoneField(el) {
            const val = el.value.trim();
            const errorSpan = el.parentElement.querySelector('.phone-error');
            if (!errorSpan) return true;
            const pattern = /^(059|056)\d{7}$/;
            if (!pattern.test(val)) {
                errorSpan.classList.remove('hidden');
                el.classList.add('field-error');
                return false;
            }
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
            return true;
        }

        function validateWalletField(el) {
            const val = el.value.trim();
            const errorSpan = el.parentElement.querySelector('.wallet-error');
            if (!errorSpan) return true;
            if (!val) {
                errorSpan.classList.add('hidden');
                el.classList.remove('field-error');
                return true;
            }
            const pattern = /^(059|056)\d{7}$/;
            if (!pattern.test(val)) {
                errorSpan.classList.remove('hidden');
                el.classList.add('field-error');
                return false;
            }
            errorSpan.classList.add('hidden');
            el.classList.remove('field-error');
            return true;
        }

        // ========== FILE UPLOAD ==========
        async function uploadFile(input, fileType, hiddenId) {
            if (!input.files || !input.files[0]) return;

            const formData = new FormData();
            formData.append('file', input.files[0]);

            // Show file name with compression indicator
            const fileNameSpan = document.getElementById(hiddenId + '-name');
            if (fileNameSpan) {
                fileNameSpan.textContent = '⏳ ' + input.files[0].name + ' (جاري الضغط...)';
                fileNameSpan.classList.remove('hidden');
            }

            try {
                const response = await fetch('/Record/UploadFile?personId=-1&fileType=' + fileType, {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();
                document.getElementById(hiddenId).value = result.path;
                if (fileNameSpan) {
                    fileNameSpan.textContent = input.files[0].name + ' ✅ (تم الضغط)';
                }
            } catch (error) {
                console.error('Error uploading file:', error);
                if (fileNameSpan) {
                    fileNameSpan.textContent = input.files[0].name + ' ❌ فشل الرفع';
                }
                alert('حدث خطأ أثناء رفع الملف');
            }
        }

