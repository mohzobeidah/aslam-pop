        function getMemberDisplayName(card) {
            const parts = ['FirstName', 'SecondName', 'ThirdName', 'LastName']
                .map(f => card.querySelector(`[name$=".${f}"]`)?.value?.trim() || '')
                .filter(Boolean);
            return parts.length ? parts.join(' ') : '';
