@model CampRegistrationApp.Models.ViewModels.RegistrationViewModel
@{
    Layout = "_Layout";
    var mustChangePassword = ViewBag.MustChangePassword == true;
}

<div class="min-h-screen bg-camp-dark-grey text-white font-cairo" dir="rtl">
    <div class="container mx-auto px-4 py-8">
            <header class="text-center mb-12">
                <h1 class="text-4xl font-bold text-camp-gold mb-2">تعديل بيانات العائلة</h1>
                <p class="text-gray-400">معرف التسجيل: <span class="font-mono text-camp-gold">@Model.RecordId</span></p>
                @if (!mustChangePassword)
                {
                    <div class="mt-4">
                        <a href="@Url.Action("ChangePassword")" class="inline-block px-6 py-2 rounded bg-camp-gold text-camp-dark-grey font-bold hover:bg-yellow-600 transition-colors text-sm">
                            تغيير كلمة المرور
                        </a>
                    </div>
                }
            </header>

        <div class="max-w-4xl mx-auto">
            @if (TempData["Success"] != null)
            {
                <div class="bg-green-900/50 border border-green-500 text-green-300 p-4 rounded mb-6 text-center">
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="bg-red-900/50 border border-red-500 text-red-300 p-4 rounded mb-6 text-center">
                    @TempData["Error"]
                </div>
            }

            <div class="text-red-500 text-sm text-center mb-4">
                @Html.ValidationSummary(false, "", new { @class = "text-red-500 text-sm" })
            </div>

            <form id="editForm" asp-action="@(ViewBag.FormAction ?? "Update")" asp-controller="@(ViewBag.FormController ?? "Record")" method="post" class="space-y-8 novalidate @(mustChangePassword ? "pointer-events-none opacity-40 select-none" : "")">
                <input type="hidden" name="Id" value="@Model.Id" />
                <input type="hidden" name="RecordId" value="@Model.RecordId" />
                <input type="hidden" name="CurrentStep" value="1" />
                <!-- ============ HEAD OF FAMILY ============ -->
                <div class="bg-camp-accent-grey p-6 rounded-lg border-r-4 border-camp-gold shadow-xl">
                    <h2 class="text-2xl font-semibold text-camp-gold mb-6">بيانات رب الأسرة</h2>

                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                        <div>
                            <label class="block text-sm mb-1">الاسم الأول</label>
                            <input name="Head.FirstName" value="@Model.Head.FirstName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الاسم الثاني</label>
                            <input name="Head.SecondName" value="@Model.Head.SecondName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الاسم الثالث</label>
                            <input name="Head.ThirdName" value="@Model.Head.ThirdName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">اسم العائلة</label>
                            <input name="Head.LastName" value="@Model.Head.LastName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                        <div>
                            <label class="block text-sm mb-1">رقم الهوية</label>
                            <input name="Head.IdNumber" value="@Model.Head.IdNumber" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required onblur="validateIdField(this)" oninput="clearIdError(this)" />
                            <span class="id-error text-red-500 text-xs hidden">رقم الهوية يجب أن يتكون من 9 أرقام</span>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">القاطع</label>
                            <select name="SectorId" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>
                                <option value="">اختر القاطع...</option>
                                @foreach (var s in ViewBag.Sectors)
                                {
                                    <option value="@s.Id" selected="@(Model.SectorId == s.Id)">@s.Name</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">تاريخ الميلاد</label>
                            <input name="Head.DateOfBirth" type="date" value="@Model.Head.DateOfBirth.ToString("yyyy-MM-dd")" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الجنس</label>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="Head.Gender" value="ذكر" @(Model.Head.Gender == "ذكر" ? "checked" : "") class="accent-camp-gold" /> ذكر
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="Head.Gender" value="أنثى" @(Model.Head.Gender == "أنثى" ? "checked" : "") class="accent-camp-gold" /> أنثى
                                </label>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">رقم الهاتف</label>
                            <input name="PhoneNumber" value="@Model.PhoneNumber" pattern="^(059|056)\d{7}$" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required oninput="clearPhoneError(this)" />
                            <span class="phone-error text-red-500 text-xs hidden">رقم الهاتف يجب أن يتكون من 10 أرقام ويبدأ بـ 059 أو 056</span>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">المحفظة</label>
                            <input name="Wallet" value="@Model.Wallet" pattern="^(059|056)\d{7}$" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required oninput="clearWalletError(this)" />
                            <span class="wallet-error text-red-500 text-xs hidden">رقم المحفظة يجب أن يتكون من 10 أرقام ويبدأ بـ 059 أو 056</span>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">نوع المحفظة</label>
                            <select name="WalletType" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none">
                                <option value="">اختر نوع المحفظة...</option>
                                <option value="بنك" selected="@(Model.WalletType == "بنك")">بنك</option>
                                <option value="بال بي" selected="@(Model.WalletType == "بال بي")">بال بي</option>
                                <option value="جوال بي" selected="@(Model.WalletType == "جوال بي")">جوال بي</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">مكان السكن الأصلي</label>
                            <select name="Head.OriginalGovernorate" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>
                                <option value="">اختر المنطقة...</option>
                                @foreach (var g in new[] { "غزة", "خانيونيس", "شمال غزة", "رفح", "دير البلح", "النصيرات", "المغازي" })
                                {
                                    <option value="@g" selected="@(Model.Head.OriginalGovernorate == g )">@g</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الحالة الاجتماعية</label>
                            <select name="Head.MaritalStatus" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>
                                <option value="">اختر الحالة...</option>
                                @foreach (var s in new[] { "متزوج", "أعزب", "أرمل", "مطلق", "منفصل" })
                                {
                                    <option value="@s" selected="@(Model.Head.MaritalStatus == s )">@s</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm mb-1">الوظيفة</label>
                            <input name="Head.EmploymentStatus" value="@Model.Head.EmploymentStatus" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm mb-1">المستوى التعليمي</label>
                            <select name="Head.EducationLevel" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>
                                <option value="">اختر...</option>
                                @foreach (var e in new[] { "بدون", "ابتدائي", "إعدادي", "ثانوي", "جامعي", "دراسات عليا" })
                                {
                                    <option value="@e" selected="@(Model.Head.EducationLevel == e )">@e</option>
                                }
                            </select>
                        </div>
                        <div class="flex items-center gap-4">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" name="Head.IsHouseDestroyed" value="true" @(Model.Head.IsHouseDestroyed ? "checked" : "") class="accent-camp-gold" />
                                <span class="text-sm">المنزل مدمر</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" name="Head.IsPrisoner" value="true" @(Model.Head.IsPrisoner ? "checked" : "") class="accent-camp-gold" />
                                <span class="text-sm">أسير</span>
                            </label>
                        </div>
                    </div>

                    <!-- Health Section -->
                    <div class="border-t border-gray-700 pt-6">
                        <h3 class="text-xl font-semibold text-camp-gold mb-4">الحالة الصحية</h3>
                        <div class="flex gap-6 mb-6">
                            @foreach (var hs in ViewBag.HealthStatuses)
                            {
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="Head.HealthStatus" value="@hs.Name" @(Model.Head.HealthStatus == hs.Name ? "checked" : "") class="accent-camp-gold" onchange="toggleHealth(this, 'head-health-details')" /> @hs.Name
                                </label>
                            }
                        </div>

                        <div id="head-health-details" class="@(Model.Head.HealthStatus == "مريض" ? "" : "hidden") space-y-6">
                            <div>
                                <label class="block text-sm mb-2">الأمراض المزمنة</label>
                                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                                    @foreach (var d in ViewBag.ChronicDiseases)
                                    {
                                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                                            <input type="checkbox" name="Head.ChronicDiseases" value="@d.Name" class="accent-camp-gold" @(Model.Head.ChronicDiseases?.Contains(d.Name) == true ? "checked" : "") /> @d.Name
                                        </label>
                                    }
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm mb-2">أنواع الإعاقة</label>
                                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                                    @foreach (var dis in ViewBag.DisabilityTypes)
                                    {
                                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                                            <input type="checkbox" name="Head.DisabilityTypes" value="@dis.Name" class="accent-camp-gold" @(Model.Head.DisabilityTypes?.Contains(dis.Name) == true ? "checked" : "") /> @dis.Name
                                        </label>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Injury Section (always visible) -->
                        <div class="border-t border-gray-700 pt-6 mt-6">
                            <div class="flex items-center gap-2 mb-4">
                                <input type="checkbox" name="Head.HasInjury" value="true" class="accent-camp-gold" @(Model.Head.HasInjury ? "checked" : "") onchange="toggleSection(this, 'head-injury-details')" />
                                <label class="text-lg">هل تعرض لإصابة؟</label>
                            </div>
                            <div id="head-injury-details" class="@(Model.Head.HasInjury ? "" : "hidden") grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm mb-1">تاريخ الإصابة</label>
                                    <input type="date" name="Head.InjuryDate" value="@(Model.Head.InjuryDate?.ToString("yyyy-MM-dd"))" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                                </div>
                                <div>
                                    <label class="block text-sm mb-1">تفاصيل الإصابة</label>
                                    <textarea name="Head.InjuryDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" rows="2">@Model.Head.InjuryDetails</textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Attachments Upload -->
                        <div class="border-t border-gray-700 pt-6 mt-6 space-y-4">
                            <h3 class="text-xl font-semibold text-camp-gold mb-4">المرفقات</h3>
                            <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                                <label class="text-lg">صورة الهوية</label>
                                <input type="file" id="headIdFile" accept="image/*" onchange="uploadFile(this, 'IDImage', 'headIdPath')" class="text-sm text-gray-400" />
                                <input type="hidden" name="Head.HeadIdImagePath" id="headIdPath" value="@Model.Head.HeadIdImagePath" />
                                <span id="headIdPath-name" class="text-xs text-camp-gold hidden"></span>
                            </div>
                            <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                                <label class="text-lg">تقرير طبي</label>
                                <input type="file" id="headMedicalFile" accept="image/*,application/pdf" onchange="uploadFile(this, 'MedicalReport', 'headMedicalPath')" class="text-sm text-gray-400" />
                                <input type="hidden" name="Head.MedicalImagePath" id="headMedicalPath" value="@Model.Head.MedicalImagePath" />
                                <span id="headMedicalPath-name" class="text-xs text-camp-gold hidden"></span>
                            </div>
                        </div>

                        <!-- Female-specific -->
                        <div class="flex items-center gap-2 mt-4">
                            <input type="checkbox" name="Head.IsPregnant" value="true" class="accent-camp-gold" @(Model.Head.IsPregnant == true ? "checked" : "") onchange="toggleSection(this, 'head-pregnancy-details')" />
                            <label class="text-sm">حامل</label>
                        </div>
                        <div id="head-pregnancy-details" class="@(Model.Head.IsPregnant == true ? "" : "hidden") grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div>
                                <label class="block text-sm mb-1">شهر الحمل</label>
                                <select name="Head.PregnancyMonth" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none">
                                    <option value="">اختر الشهر...</option>
                                    @for (int m = 1; m <= 9; m++)
                                    {
                                        <option value="@m" selected="@(Model.Head.PregnancyMonth == m )">@m</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="flex items-center gap-2 mt-4">
                            <input type="checkbox" name="Head.IsNursing" value="true" class="accent-camp-gold" @(Model.Head.IsNursing == true ? "checked" : "") onchange="toggleSection(this, 'head-nursing-details')" />
                            <label class="text-sm">مرضع</label>
                        </div>
                        <div id="head-nursing-details" class="@(Model.Head.IsNursing == true ? "" : "hidden") grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
                            <div>
                                <label class="block text-sm mb-1">اسم الطفل</label>
                                <input name="Head.NursingInfantName" value="@Model.Head.NursingInfantName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                            </div>
                            <div>
                                <label class="block text-sm mb-1">تاريخ ميلاد الطفل</label>
                                <input type="date" name="Head.NursingInfantDOB" value="@(Model.Head.NursingInfantDOB?.ToString("yyyy-MM-dd"))" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                            </div>
                            <div>
                                <label class="block text-sm mb-1">رقم هوية الطفل</label>
                                <input name="Head.NursingInfantID" value="@Model.Head.NursingInfantID" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ============ FAMILY MEMBERS ============ -->
                <div class="bg-camp-accent-grey p-6 rounded-lg border-r-4 border-camp-gold shadow-xl">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-2xl font-semibold text-camp-gold">أفراد الأسرة</h2>
                        <button type="button" onclick="addMember()" class="bg-camp-gold text-camp-dark-grey px-4 py-2 rounded font-bold hover:bg-yellow-600 transition-colors">
                            + إضافة فرد
                        </button>
                    </div>

                    @{
                        var healthStatusList = ViewBag.HealthStatuses as List<CampRegistrationApp.Models.HealthStatus> ?? new List<CampRegistrationApp.Models.HealthStatus>();
                        var firstHealthName = healthStatusList.FirstOrDefault()?.Name ?? "";
                    }
                    <div id="members-container" class="space-y-6">
                        @for (int i = 0; i < Model.Members.Count; i++)
                        {
                            var m = Model.Members[i];
                            <div class="member-card bg-camp-dark-grey p-4 rounded border border-gray-700 relative mb-4" data-index="@i">
                                <button type="button" onclick="removeMember(this)" class="absolute top-2 left-2 text-red-500 hover:text-red-700 text-xl">✕</button>
                                <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-4">
                                    <div>
                                        <label class="block text-xs mb-1">الاسم الأول</label>
                                        <input name="Members[@i].FirstName" value="@m.FirstName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                    </div>
                                    <div>
                                        <label class="block text-xs mb-1">الاسم الثاني</label>
                                        <input name="Members[@i].SecondName" value="@m.SecondName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                    </div>
                                    <div>
                                        <label class="block text-xs mb-1">الاسم الثالث</label>
                                        <input name="Members[@i].ThirdName" value="@m.ThirdName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                    </div>
                                    <div>
                                        <label class="block text-xs mb-1">اسم العائلة</label>
                                        <input name="Members[@i].LastName" value="@m.LastName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                    </div>
                                    <div>
                                        <label class="block text-xs mb-1">رقم الهوية</label>
                                        <input name="Members[@i].IdNumber" value="@m.IdNumber" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" onblur="validateIdField(this)" oninput="clearIdError(this)" />
                                        <span class="id-error text-red-500 text-xs hidden">رقم الهوية يجب أن يتكون من 9 أرقام</span>
                                    </div>
                                    <div>
                                        <label class="block text-xs mb-1">تاريخ الميلاد</label>
                                        <input type="date" name="Members[@i].DateOfBirth" value="@m.DateOfBirth.ToString("yyyy-MM-dd")" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                    </div>
                                    <div>
                                        <label class="block text-xs mb-1">الجنس</label>
                                        <select name="Members[@i].Gender" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" onchange="toggleFemaleFields(this, @i)">
                                            <option value="ذكر" selected="@(m.Gender == "ذكر" )">ذكر</option>
                                            <option value="أنثى" selected="@(m.Gender == "أنثى" )">أنثى</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-xs mb-1">صلة القرابة</label>
                    <select name="Members[@i].RelationshipToHead" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none">
                        <option value="">اختر...</option>
                        @foreach (var rel in new[] { "زوج", "زوجة", "ابن", "ابنة", "أم", "أب", "أخ", "أخت", "جدة/جد", "حفيد/حفيدة", "أخ غير شقيق", "أخت غير شقيقة", "Other" })
                        {
                            <option value="@rel" selected="@(m.RelationshipToHead == rel )">@rel</option>
                        }
                    </select>
                                    </div>
                                    <div>
                                        <label class="block text-xs mb-1">الحالة الاجتماعية <span class="text-red-500">*</span></label>
                                        <select name="Members[@i].MaritalStatus" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" onchange="clearMemberMaritalError(this)">
                                            <option value="">اختر...</option>
                                            <option value="متزوج" selected="@(m.MaritalStatus == "متزوج")">متزوج</option>
                                            <option value="أعزب" selected="@(m.MaritalStatus == "أعزب")">أعزب</option>
                                            <option value="أرمل" selected="@(m.MaritalStatus == "أرمل")">أرمل</option>
                                            <option value="مطلق" selected="@(m.MaritalStatus == "مطلق")">مطلق</option>
                                            <option value="منفصل" selected="@(m.MaritalStatus == "منفصل")">منفصل</option>
                                        </select>
                                        <span class="marital-status-error text-red-500 text-xs hidden">الحالة الاجتماعية مطلوبة</span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-4 mt-2">
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input type="checkbox" name="Members[@i].IsPrisoner" value="true" class="accent-camp-gold" @(m.IsPrisoner ? "checked" : "") />
                                        <span class="text-xs">أسير</span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer female-only-@i @(m.Gender == "أنثى" ? "" : "hidden")">
                                        <input type="checkbox" name="Members[@i].IsHusbandPrisoner" value="true" class="accent-camp-gold" @(m.IsHusbandPrisoner ? "checked" : "") />
                                        <span class="text-xs">زوجها مسجون</span>
                                    </label>
                                </div>

                                <!-- Member Health -->
                                <div class="border-t border-gray-700 pt-4">
                                    <h4 class="text-md font-semibold text-camp-gold mb-3">الحالة الصحية</h4>
                                    <div class="flex gap-4 mb-4">
                                        @foreach (var hs in ViewBag.HealthStatuses)
                                        {
                                            var isChecked = m.HealthStatus == hs.Name || (string.IsNullOrEmpty(m.HealthStatus) && hs.Name == firstHealthName);
                                            <label class="flex items-center gap-2 cursor-pointer text-xs">
                                                <input type="radio" name="Members[@i].HealthStatus" value="@hs.Name" class="accent-camp-gold" onchange="toggleMemberHealth(@i)" @(isChecked ? "checked" : "") /> @hs.Name
                                            </label>
                                        }
                                    </div>
                                    <div id="member-health-@i" class="@(m.HealthStatus != firstHealthName && !string.IsNullOrEmpty(m.HealthStatus) ? "" : "hidden") space-y-4">
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <label class="block text-xs mb-1">الأمراض المزمنة</label>
                                                <div class="grid grid-cols-2 gap-2">
                                                    @foreach (var d in ViewBag.ChronicDiseases)
                                                    {
                                                        <label class="flex items-center gap-1 text-xs">
                                                            <input type="checkbox" name="Members[@i].ChronicDiseases" value="@d.Name" class="accent-camp-gold" @(m.ChronicDiseases?.Contains(d.Name) == true ? "checked" : "") /> @d.Name
                                                        </label>
                                                    }
                                                </div>
                                            </div>
                                            <div>
                                                <label class="block text-xs mb-1">أنواع الإعاقة</label>
                                                <div class="grid grid-cols-2 gap-2">
                                                    @foreach (var dis in ViewBag.DisabilityTypes)
                                                    {
                                                        <label class="flex items-center gap-1 text-xs">
                                                            <input type="checkbox" name="Members[@i].DisabilityTypes" value="@dis.Name" class="accent-camp-gold" @(m.DisabilityTypes?.Contains(dis.Name) == true ? "checked" : "") /> @dis.Name
                                                        </label>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                            <div class="flex items-center gap-2">
                                                <input type="checkbox" name="Members[@i].IsPregnant" value="true" class="accent-camp-gold" @(m.IsPregnant == true ? "checked" : "") onchange="toggleMemberSection(@i, 'pregnancy')" />
                                                <label class="text-xs">حامل</label>
                                            </div>
                                            <div id="member-pregnancy-@i" class="@(m.IsPregnant == true ? "" : "hidden") md:col-span-2">
                                                <label class="block text-xs mb-1">شهر الحمل</label>
                                                <select name="Members[@i].PregnancyMonth" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none">
                                                    <option value="">اختر الشهر...</option>
                                                    @for (int pm = 1; pm <= 9; pm++)
                                                    {
                                                        <option value="@pm" selected="@(m.PregnancyMonth == pm )">@pm</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                            <div class="flex items-center gap-2">
                                                <input type="checkbox" name="Members[@i].IsNursing" value="true" class="accent-camp-gold" @(m.IsNursing == true ? "checked" : "") onchange="toggleMemberSection(@i, 'nursing')" />
                                                <label class="text-xs">مرضع</label>
                                            </div>
                                            <div id="member-nursing-@i" class="@(m.IsNursing == true ? "" : "hidden") md:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-3">
                                                <div>
                                                    <label class="block text-xs mb-1">اسم الطفل</label>
                                                    <input name="Members[@i].NursingInfantName" value="@m.NursingInfantName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                                </div>
                                                <div>
                                                    <label class="block text-xs mb-1">تاريخ ميلاد الطفل</label>
                                                    <input type="date" name="Members[@i].NursingInfantDOB" value="@(m.NursingInfantDOB?.ToString("yyyy-MM-dd"))" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                                </div>
                                                <div>
                                                    <label class="block text-xs mb-1">رقم هوية الطفل</label>
                                                    <input name="Members[@i].NursingInfantID" value="@m.NursingInfantID" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Injury Section (always visible for member) -->
                                    <div class="border-t border-gray-700 pt-4 mt-4">
                                        <div class="flex items-center gap-2 mb-4">
                                            <input type="checkbox" name="Members[@i].HasInjury" value="true" class="accent-camp-gold" @(m.HasInjury ? "checked" : "") onchange="toggleMemberInjury(@i)" />
                                            <label class="text-lg">هل تعرض لإصابة؟</label>
                                        </div>
                                        <div id="member-injury-@i" class="@(m.HasInjury ? "" : "hidden") grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <label class="block text-xs mb-1">تاريخ الإصابة</label>
                                                <input type="date" name="Members[@i].InjuryDate" value="@(m.InjuryDate?.ToString("yyyy-MM-dd"))" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" />
                                            </div>
                                            <div>
                                                <label class="block text-xs mb-1">تفاصيل الإصابة</label>
                                                <textarea name="Members[@i].InjuryDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" rows="2">@m.InjuryDetails</textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <p id="no-members-msg" class="text-gray-500 text-center py-8 @(Model.Members.Count > 0 ? "hidden" : "")">لم يتم إضافة أفراد بعد. اضغط على "إضافة فرد" للبدء.</p>
                </div>

                <!-- ============ HOUSING & SPECIAL ============ -->
                <div class="bg-camp-accent-grey p-6 rounded-lg border-r-4 border-camp-gold shadow-xl">
                    <h2 class="text-2xl font-semibold text-camp-gold mb-6">السكن والحالات الخاصة</h2>
                    <div class="space-y-6">
                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="IsChildHeaded" value="true" class="accent-camp-gold" @(Model.IsChildHeaded ? "checked" : "") onchange="toggleSection(this, 'child-headed-details')" />
                            <label>رب الأسرة طفل (أقل من 18 سنة)</label>
                        </div>
                        <div id="child-headed-details" class="@(Model.IsChildHeaded ? "" : "hidden") p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <label class="block text-sm mb-1">تفاصيل</label>
                            <textarea name="ChildHeadedDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" rows="2">@Model.ChildHeadedDetails</textarea>
                        </div>

                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="IsFemaleHeaded" value="true" class="accent-camp-gold" @(Model.IsFemaleHeaded ? "checked" : "") onchange="toggleSection(this, 'female-headed-details')" />
                            <label>ربة الأسرة امرأة</label>
                        </div>
                        <div id="female-headed-details" class="@(Model.IsFemaleHeaded ? "" : "hidden") p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <label class="block text-sm mb-1">تفاصيل</label>
                            <textarea name="FemaleHeadedDetails" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none" rows="2">@Model.FemaleHeadedDetails</textarea>
                        </div>

                        <div class="flex items-center gap-4 p-4 bg-camp-dark-grey rounded border border-gray-700">
                            <input type="checkbox" name="SupportsOutsidePerson" value="true" class="accent-camp-gold" @(Model.SupportsOutsidePerson ? "checked" : "") onchange="toggleSection(this, 'outside-person-details')" />
