            radios.forEach((r, i) => { if (r === el && i === 0) isFirst = true; if (r === el && i > 0) isFirst = false; });
            document.getElementById(sectionId).classList.toggle('hidden', isFirst);
        }

        function toggleSection(el, sectionId) {
            const section = document.getElementById(sectionId);
