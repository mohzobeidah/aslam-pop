        function clearMemberMaritalError(select) {
            const card = select.closest('.member-card');
            if (!card) return;
            const errorSpan = card.querySelector('.marital-status-error');
            if (errorSpan) errorSpan.classList.add('hidden');
            clearHighlight(select);
        }

        function validateMemberMaritalStatus(card, idx) {
            const select = card.querySelector('[name$=".MaritalStatus"]');
            if (!select) return true;
            const name = getMemberDisplayName(card) || `رقم ${idx + 1}`;
            const errorSpan = card.querySelector('.marital-status-error');
            if (!select.value.trim()) {
                highlightError(select);
                if (errorSpan) {
                    errorSpan.textContent = `يرجى اختيار الحالة الاجتماعية للفرد: ${name}`;
                    errorSpan.classList.remove('hidden');
                }
                return false;
            }
            clearMemberMaritalError(select);
            return true;
        }

        function submitEditForm() {
            if (document.getElementById('force-password-modal')) {
                alert('يجب تغيير كلمة المرور أولاً');
                return false;
            }
            let valid = true;

            // Validate IDs
            document.querySelectorAll('[name$=".IdNumber"], [name="Head.IdNumber"]').forEach(el => {
                if (!validateIdField(el)) valid = false;
            });

            // Validate phone
            const phoneEl = document.querySelector('[name="PhoneNumber"]');
            if (phoneEl && !validatePhoneField(phoneEl)) { highlightError(phoneEl); valid = false; }

            // Validate wallet if provided
            const walletEl = document.querySelector('[name="Wallet"]');
            if (walletEl && walletEl.value.trim() && !validateWalletField(walletEl)) { highlightError(walletEl); valid = false; }

            const fieldLabels = {
                'Head.FirstName': 'الاسم الأول',
                'Head.SecondName': 'الاسم الثاني',
                'Head.ThirdName': 'الاسم الثالث',
                'Head.LastName': 'اسم العائلة',
                'Head.IdNumber': 'رقم الهوية',
                'SectorId': 'القاطع',
                'Head.DateOfBirth': 'تاريخ الميلاد',
                'PhoneNumber': 'رقم الهاتف',
                'Wallet': 'المحفظة',
                'WalletType': 'نوع المحفظة',
                'Head.OriginalGovernorate': 'مكان السكن الأصلي',
                'Head.MaritalStatus': 'الحالة الاجتماعية',
                'Head.EmploymentStatus': 'الوظيفة',
                'Head.EducationLevel': 'المستوى التعليمي'
            };
            let missingFields = [];
            for (const [key, label] of Object.entries(fieldLabels)) {
                const el = document.querySelector(`[name="${key}"]`);
                if (!el || !el.value.trim()) {
                    highlightError(el);
                    missingFields.push(label);
                    valid = false;
                } else {
                    clearHighlight(el);
                }
            }
            // Validate Gender radio
            const genderChecked = document.querySelector('[name="Head.Gender"]:checked');
            if (!genderChecked) {
                document.querySelectorAll('[name="Head.Gender"]').forEach(r => highlightError(r.parentElement));
                missingFields.push('الجنس');
                valid = false;
            } else {
                document.querySelectorAll('[name="Head.Gender"]').forEach(r => clearHighlight(r.parentElement));
            }
            // Validate HealthStatus radio
            const healthChecked = document.querySelector('[name="Head.HealthStatus"]:checked');
            if (!healthChecked) {
                document.querySelectorAll('[name="Head.HealthStatus"]').forEach(r => highlightError(r.parentElement));
                missingFields.push('الحالة الصحية');
                valid = false;
            } else {
                document.querySelectorAll('[name="Head.HealthStatus"]').forEach(r => clearHighlight(r.parentElement));
            }

            if (!valid) {
                alert('الحقول التالية مطلوبة:\n- ' + missingFields.join('\n- '));
                return false;
            }

            // Validate: if married, require a wife member
            const maritalStatus = document.querySelector('[name="Head.MaritalStatus"]');
            if (maritalStatus && maritalStatus.value === 'متزوج') {
                const hasWife = Array.from(document.querySelectorAll('.member-card')).some(card => {
                    const rel = card.querySelector('[name$=".RelationshipToHead"]');
                    return rel && rel.value === 'زوجة';
                });
                if (!hasWife) {
                    alert('بما أن الحالة الاجتماعية متزوج، يجب إضافة فرد بصفة زوجة');
                    return false;
                }
            }

            // Validate: if head is sick, require disease/disability
            const headHealth = document.querySelector('[name="Head.HealthStatus"]:checked');
            if (headHealth && headHealth.value !== 'سليم') {
                const diseases = document.querySelectorAll('[name="Head.ChronicDiseases"]:checked');
                const disabilities = document.querySelectorAll('[name="Head.DisabilityTypes"]:checked');
                if (diseases.length === 0 && disabilities.length === 0) {
                    alert('بما أن الحالة الصحية مريض، يجب اختيار مرض مزمن أو نوع إعاقة على الأقل لرب الأسرة');
                    return false;
                }
            }
            // Validate: سليم cannot have diseases
            if (headHealth && headHealth.value === 'سليم') {
                const diseases = document.querySelectorAll('[name="Head.ChronicDiseases"]:checked');
                const disabilities = document.querySelectorAll('[name="Head.DisabilityTypes"]:checked');
                if (diseases.length > 0 || disabilities.length > 0) {
                    alert('لا يمكن أن تكون الحالة الصحية سليماً مع وجود أمراض مزمنة أو إعاقات');
                    return false;
                }
            }

            // Validate member required fields
            const memberFields = ['FirstName', 'IdNumber', 'RelationshipToHead', 'Gender', 'DateOfBirth'];
            document.querySelectorAll('.member-card').forEach((card, idx) => {
                let memberMissing = [];
                memberFields.forEach(field => {
                    const el = card.querySelector(`[name$=".${field}"]`);
                    if (!el || !el.value.trim()) {
                        highlightError(el);
                        memberMissing.push(field === 'FirstName' ? 'الاسم الأول' : field === 'IdNumber' ? 'رقم الهوية' : field === 'RelationshipToHead' ? 'صلة القرابة' : field === 'Gender' ? 'الجنس' : 'تاريخ الميلاد');
                        valid = false;
                    } else {
                        clearHighlight(el);
                    }
                });
                if (memberMissing.length > 0) {
                    alert(`الفرد رقم ${idx + 1}: الحقول التالية مطلوبة:\n- ` + memberMissing.join('\n- '));
                }
                if (!validateMemberMaritalStatus(card, idx)) {
                    const name = getMemberDisplayName(card) || `رقم ${idx + 1}`;
                    alert(`يرجى اختيار الحالة الاجتماعية للفرد: ${name}`);
                    valid = false;
                }
            });

            // Validate: no duplicate ID numbers among members and head
            const allIdEls = [document.querySelector('[name="Head.IdNumber"]'), ...Array.from(document.querySelectorAll('.member-card')).map(c => c.querySelector('[name$=".IdNumber"]'))];
            const idValues = allIdEls.map(el => el?.value?.trim()).filter(v => v);
            if (new Set(idValues).size !== idValues.length) {
                alert('يوجد تكرار في أرقام الهوية. يجب أن يكون لكل شخص رقم هوية فريد.');
                valid = false;
            }

            if (!valid) return false;

            // Validate: if member is sick, require disease/disability
            document.querySelectorAll('.member-card').forEach((card, idx) => {
                const healthRadios = card.querySelectorAll('[name$=".HealthStatus"]');
                let isSick = false;
                healthRadios.forEach(r => { if (r.checked && r.value !== 'سليم') isSick = true; });
                if (isSick) {
                    const diseases = card.querySelectorAll('[name$=".ChronicDiseases"]:checked');
                    const disabilities = card.querySelectorAll('[name$=".DisabilityTypes"]:checked');
                    if (diseases.length === 0 && disabilities.length === 0) {
                        alert(`الفرد رقم ${idx + 1}: الحالة الصحية مريض، يرجى اختيار مرض مزمن أو نوع إعاقة على الأقل`);
                        valid = false;
                    }
                }
                // Validate: سليم cannot have diseases
                if (!isSick) {
                    const diseases = card.querySelectorAll('[name$=".ChronicDiseases"]:checked');
                    const disabilities = card.querySelectorAll('[name$=".DisabilityTypes"]:checked');
                    if (diseases.length > 0 || disabilities.length > 0) {
                        alert(`الفرد رقم ${idx + 1}: لا يمكن أن تكون الحالة الصحية سليماً مع وجود أمراض مزمنة أو إعاقات`);
                        valid = false;
                    }
                }
            });

            if (!valid) return false;

            // Validate desires
            const desireSelects = document.querySelectorAll('.desire-select');
            let allDesiresSelected = true;
            desireSelects.forEach(sel => { if (!sel.value) allDesiresSelected = false; });
            if (!allDesiresSelected) {
                alert('يرجى ترتيب جميع الرغبات (اختيار قيمة لكل رغبة)');
                return false;
            }

            const form = document.getElementById('editForm');

            // Capture housing radio values before disabling
            const livesInTentValue = document.querySelector('[name="LivesInTent"]:checked')?.value || 'false';
            const hasBathroomValue = document.querySelector('[name="HasBathroom"]:checked')?.value || 'false';
            const bathroomTypeValue = document.querySelector('[name="BathroomType"]:checked')?.value || '';

            // Disable ALL checkboxes + radios so only hidden inputs submit values
            form.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.disabled = true);
            form.querySelectorAll('input[type="radio"]').forEach(r => r.disabled = true);

            // Head radio values (Gender, HealthStatus) — captured before radios are disabled
            ['Head.Gender', 'Head.HealthStatus'].forEach(field => {
                const checked = document.querySelector(`[name="${field}"]:checked`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = field;
                hidden.value = checked?.value || '';
                form.appendChild(hidden);
            });

            // Members radio values (HealthStatus)
            document.querySelectorAll('.member-card').forEach((card, idx) => {
                const checked = card.querySelector(`[name="Members[${idx}].HealthStatus"]:checked`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = `Members[${idx}].HealthStatus`;
                hidden.value = checked?.value || '';
                form.appendChild(hidden);
            });

            // Head multi-value: ChronicDiseases, DisabilityTypes
            [['Head.ChronicDiseases'], ['Head.DisabilityTypes']].forEach(([name]) => {
                const checked = Array.from(form.querySelectorAll(`[name="${name}"]:checked`)).map(cb => cb.value);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = name;
                hidden.value = checked.join('، ');
                form.appendChild(hidden);
            });

            // Members multi-value + bools
            document.querySelectorAll('.member-card').forEach((card, idx) => {
                ['ChronicDiseases', 'DisabilityTypes'].forEach(field => {
                    const checked = Array.from(card.querySelectorAll(`[name="Members[${idx}].${field}"]:checked`)).map(cb => cb.value);
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = `Members[${idx}].${field}`;
                    hidden.value = checked.join('، ');
                    form.appendChild(hidden);
                });
                ['HasInjury', 'IsPregnant', 'IsNursing', 'IsPrisoner', 'IsHusbandPrisoner'].forEach(field => {
                    const cb = card.querySelector(`[name="Members[${idx}].${field}"]`);
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = `Members[${idx}].${field}`;
                    hidden.value = cb?.checked ? 'true' : 'false';
                    form.appendChild(hidden);
                });
            });

            // Head bools
            ['Head.IsHouseDestroyed', 'Head.IsPrisoner'].forEach(field => {
                const cb = form.querySelector(`[name="${field}"]`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = field;
                hidden.value = cb?.checked ? 'true' : 'false';
                form.appendChild(hidden);
            });

            // Registration-level bools + housing radios
            [
                ['LivesInTent', livesInTentValue],
                ['HasBathroom', hasBathroomValue],
                ['BathroomType', bathroomTypeValue]
            ].forEach(([name, value]) => {
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = name;
                hidden.value = value;
                form.appendChild(hidden);
            });
            ['NeedsDiapers', 'HasMultipleFamiliesInTent', 'IsChildHeaded', 'IsFemaleHeaded', 'SupportsOutsidePerson'].forEach(field => {
                const el = form.querySelector(`[name="${field}"]`);
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = field;
                hidden.value = el?.checked ? 'true' : 'false';
                form.appendChild(hidden);
            });

            // Sync desires from dropdowns to hidden input before submission
            saveDesireIds();

            // Convert single comma-separated DesireIds input to indexed inputs for model binding
            const desireInput = document.getElementById('desireIdsInput');
            if (desireInput && desireInput.value) {
                const ids = desireInput.value.split(',').filter(Boolean);
                desireInput.remove();
                ids.forEach((id, i) => {
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = `DesireIds[${i}]`;
                    hidden.value = id.trim();
                    form.appendChild(hidden);
                });
            }

            return true;
        }

        function confirmLogout() {
            if (confirm('هل تريد تسجيل الخروج؟')) {
                const form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("Logout")';
                document.body.appendChild(form);
                form.submit();
            }
        }

        // ========== DESIRES (DYNAMIC RANKING) ==========
        function renderDesires() {
            const container = document.getElementById('desires-container');
            if (!container) return;

            const selected = getSavedDesireIds();
            const RANK_COUNT = Math.max(5, selected.length);

            if (!DESIRES || DESIRES.length === 0) {
                container.innerHTML = '<p class="text-gray-500 text-center col-span-full">لا توجد رغبات متاحة حالياً</p>';
                return;
            }

            for (let i = 1; i <= RANK_COUNT; i++) {
                const order = i;
                const wrapper = document.createElement('div');
                wrapper.className = 'flex items-center gap-3 p-2 bg-camp-dark-grey/50 rounded border border-gray-700';
                wrapper.id = `desire-wrapper-${order}`;

                const label = document.createElement('label');
                label.className = 'text-sm text-gray-300 min-w-fit';
                label.textContent = `الرغبة ${order}:`;
                wrapper.appendChild(label);

                const select = document.createElement('select');
                select.className = 'w-full p-2 rounded bg-camp-dark-grey border border-gray-600 outline-none text-white desire-select';
                select.setAttribute('data-order', order);
                select.name = `Desires[${i - 1}]`;

                const blank = document.createElement('option');
                blank.value = '';
                blank.textContent = 'اختر الرغبة...';
                select.appendChild(blank);

                DESIRES.forEach(d2 => {
                    const id = d2.Id !== undefined ? d2.Id : d2.id;
                    const name = d2.Name !== undefined ? d2.Name : d2.name;
                    const opt = document.createElement('option');
                    opt.value = id;
                    opt.textContent = name;
                    select.appendChild(opt);
                });

                // Restore saved selection
                if (selected.length >= i && selected[i - 1]) {
                    select.value = selected[i - 1];
                }

                select.addEventListener('change', function () {
                    updateDesireOptions();
                    saveDesireIds();
                });

                wrapper.appendChild(select);
                container.appendChild(wrapper);
            }

            updateDesireOptions();
        }

        function updateDesireOptions() {
            const selects = document.querySelectorAll('.desire-select');
            const selectedValues = [];

            selects.forEach(sel => {
                const val = sel.value;
                selectedValues.push(val);

                Array.from(sel.options).forEach(opt => {
                    if (opt.value === '') return;
                    if (opt.value === val) {
                        opt.disabled = false;
                        opt.hidden = false;
                        return;
                    }
                    const alreadySelectedInEarlier = Array.from(selects).some(s => {
                        const sOrder = parseInt(s.getAttribute('data-order'));
                        const curOrder = parseInt(sel.getAttribute('data-order'));
                        return sOrder < curOrder && s.value === opt.value;
                    });
                    opt.disabled = alreadySelectedInEarlier;
                    opt.hidden = alreadySelectedInEarlier;
                });
            });
        }

        function getSavedDesireIds() {
            const input = document.getElementById('desireIdsInput');
            if (input && input.value) {
                return input.value.split(',').map(s => parseInt(s.trim())).filter(n => !isNaN(n) && n > 0);
            }
            return [];
        }

        function saveDesireIds() {
            const selects = document.querySelectorAll('.desire-select');
            const ids = [];
            selects.forEach(sel => {
                if (sel.value) ids.push(sel.value);
            });
            const input = document.getElementById('desireIdsInput');
            if (input) input.value = ids.join(',');
        }



        document.addEventListener('DOMContentLoaded', function () {
            renderDesires();
        });
    </script>
</div>

