@model RefugeeComplaintCreate
@{
    ViewData["Title"] = "شكوى جديدة";
    var headName = ViewBag.HeadName as string;
    var headPhone = ViewBag.HeadPhone as string;
}

<div class="min-h-screen bg-camp-dark-grey text-white font-cairo" dir="rtl">
    <div class="container mx-auto px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="text-center mb-8">
                <h1 class="text-3xl text-camp-gold font-bold">شكوى جديدة</h1>
                <p class="text-gray-400 mt-2">سيتم إرسال الشكوى باسم: @headName</p>
            </div>

            @if (TempData["Error"] is string errorMsg)
            {
                <div class="bg-red-900/50 text-red-300 p-3 rounded-lg mb-4 text-sm text-center">@errorMsg</div>
            }

            <form method="post" class="bg-camp-accent-grey p-6 rounded-xl border border-gray-700 space-y-4">
                @Html.AntiForgeryToken()

                <div class="text-xs text-gray-400 bg-camp-dark-grey p-3 rounded mb-2">
                    <span>مقدم الشكوى: @headName</span>
                    @if (!string.IsNullOrEmpty(headPhone))
                    {
                        <span class="mr-4">الهاتف: @headPhone</span>
                    }
                </div>

                <div>
                    <label class="block text-sm mb-1">الموضوع <span class="text-red-500">*</span></label>
                    <input asp-for="Subject" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required maxlength="200" />
                    <span asp-validation-for="Subject" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="block text-sm mb-1">الرسالة <span class="text-red-500">*</span></label>
                    <textarea asp-for="Message" rows="6" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required></textarea>
                    <span asp-validation-for="Message" class="text-red-500 text-xs"></span>
                </div>
                <button type="submit" class="w-full bg-camp-gold text-black font-bold py-3 rounded-lg hover:bg-yellow-500 transition text-lg">
                    إرسال الشكوى
                </button>
            </form>

            <div class="text-center mt-6">
                <a asp-action="MyComplaints" class="text-gray-400 hover:text-camp-gold text-sm transition">← العودة للشكاوى</a>
            </div>
        </div>
    </div>
</div>
