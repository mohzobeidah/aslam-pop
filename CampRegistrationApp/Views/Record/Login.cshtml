@{
    Layout = "_Layout";
}

<div class="min-h-screen bg-camp-dark-grey text-white font-cairo flex items-center justify-center" dir="rtl">
    <div class="max-w-md w-full p-8 bg-camp-accent-grey rounded-lg border-t-4 border-camp-gold shadow-2xl">
        <div class="text-center mb-8">
            <div class="text-4xl text-camp-gold mb-4">🔑</div>
            <h1 class="text-2xl font-bold text-camp-gold">تسجيل الدخول</h1>
            <p class="text-gray-400">أدخل رقم الهوية وكلمة المرور لتعديل بيانات العائلة</p>
        </div>

        @if (TempData["Error"] is string errorMsg)
        {
            <div class="bg-yellow-900/50 text-yellow-300 p-3 rounded-lg mb-4 text-sm text-center">@errorMsg</div>
        }

        <form asp-action="Login" method="post" class="space-y-6">
            <div>
                <label class="block text-sm mb-2">رقم هوية رب الأسرة</label>
                <input name="idNumber" class="w-full p-3 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none text-center" placeholder="أدخل رقم الهوية (9 أرقام)" pattern="\d{9}" title="9 أرقام" required />
            </div>
            <div>
                <label class="block text-sm mb-2">كلمة المرور</label>
                <div class="relative">
                    <input type="password" name="password" id="loginPassword" class="w-full p-3 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none text-center pr-3 pl-10" placeholder="أدخل كلمة المرور" required />
                    <button type="button" onclick="togglePassword('loginPassword', this)" class="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-camp-gold transition-colors p-1">
                        <svg class="w-5 h-5 eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        <svg class="w-5 h-5 eye-closed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                    </button>
                </div>
            </div>

            <div class="text-red-500 text-sm text-center">
                @Html.ValidationSummary(false, "", new { @class = "text-red-500 text-sm" })
            </div>

            <button type="submit" class="w-full py-3 rounded bg-camp-gold text-camp-dark-grey font-bold hover:bg-yellow-600 transition-colors">
                دخول للتعديل
            </button>
        </form>

        <div class="mt-6 text-center space-y-2">
            <p class="text-xs text-gray-500">
                لا تملك حساباً؟ <a href="@Url.Action("Index", "Registration")" class="text-camp-gold hover:underline">تسجيل عائلة جديدة</a>
            </p>
        </div>
    </div>
</div>

<script>
    function togglePassword(inputId, btn) {
        const input = document.getElementById(inputId);
        const openIcon = btn.querySelector('.eye-open');
        const closedIcon = btn.querySelector('.eye-closed');
        if (input.type === 'password') {
            input.type = 'text';
            openIcon.classList.add('hidden');
            closedIcon.classList.remove('hidden');
        } else {
            input.type = 'password';
            openIcon.classList.remove('hidden');
            closedIcon.classList.add('hidden');
        }
    }
</script>
