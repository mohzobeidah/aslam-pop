@model List<RefugeeComplaintListItem>
@{
    ViewData["Title"] = "الشكاوى";
    var headName = ViewBag.HeadName as string;
}

<div class="min-h-screen bg-camp-dark-grey text-white font-cairo" dir="rtl">
    <div class="container mx-auto px-4 py-8">
        <div class="text-center mb-8">
            <h1 class="text-3xl text-camp-gold font-bold">الشكاوى</h1>
            <p class="text-gray-400 mt-2">@headName</p>
        </div>

        <div class="max-w-4xl mx-auto">
            @if (TempData["Success"] is string successMsg)
            {
                <div class="bg-green-900/50 border border-green-500 text-green-300 p-4 rounded mb-6 text-center">@successMsg</div>
            }

            <div class="flex justify-between items-center mb-6">
                <p class="text-gray-400 text-sm">عدد الشكاوى: @Model.Count</p>
                <a href="@Url.Action("CreateComplaint")" class="bg-camp-gold text-camp-dark-grey px-5 py-2 rounded-lg font-bold hover:bg-yellow-500 transition text-sm">
                    + شكوى جديدة
                </a>
            </div>

            @if (!Model.Any())
            {
                <div class="bg-camp-accent-grey p-8 rounded-xl border border-gray-700 text-center text-gray-400">
                    <p class="text-lg mb-3">لا توجد شكاوى مقدمة</p>
                    <a href="@Url.Action("CreateComplaint")" class="text-camp-gold hover:text-yellow-500 transition">تقديم شكوى جديدة</a>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full bg-camp-accent-grey rounded-xl border border-gray-700">
                        <thead>
                            <tr class="border-b border-gray-700 text-camp-gold text-sm">
                                <th class="p-3 text-center">رقم التتبع</th>
                                <th class="p-3 text-right">الموضوع</th>
                                <th class="p-3 text-center">الحالة</th>
                                <th class="p-3 text-center">التاريخ</th>
                                <th class="p-3 text-center">عرض</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                var statusColor = c.Status switch
                                {
                                    "Pending" => "bg-yellow-900/50 text-yellow-300",
                                    "InProgress" => "bg-blue-900/50 text-blue-300",
                                    "Resolved" => "bg-green-900/50 text-green-300",
                                    _ => "bg-gray-900/50 text-gray-300"
                                };
                                var statusText = c.Status switch
                                {
                                    "Pending" => "قيد الانتظار",
                                    "InProgress" => "قيد المعالجة",
                                    "Resolved" => "تم الحل",
                                    _ => c.Status
                                };
                                <tr class="border-b border-gray-700 hover:bg-gray-800/50 text-sm">
                                    <td class="p-3 text-center font-mono text-camp-gold" dir="ltr">@c.TicketId</td>
                                    <td class="p-3 text-white font-semibold">@c.Subject</td>
                                    <td class="p-3 text-center">
                                        <span class="@statusColor px-2 py-1 rounded font-semibold text-xs">@statusText</span>
                                    </td>
                                    <td class="p-3 text-center text-gray-400">@c.CreatedAt.ToString("yyyy/MM/dd")</td>
                                    <td class="p-3 text-center">
                                        <a asp-action="MyComplaintDetails" asp-route-ticketId="@c.TicketId" class="text-camp-gold hover:text-yellow-500 transition text-sm">عرض</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="text-center mt-8">
                <a href="@Url.Action("Edit")" class="text-gray-400 hover:text-camp-gold text-sm transition">← العودة للتعديل</a>
            </div>
        </div>
    </div>
</div>
