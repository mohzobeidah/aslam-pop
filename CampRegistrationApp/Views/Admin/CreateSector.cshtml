@model Sector
@{
    ViewData["Title"] = "إضافة قاطع جديد";
}

<div class="max-w-lg mx-auto">
    <h1 class="text-2xl text-camp-gold font-bold mb-6">إضافة قاطع جديد</h1>

    <form method="post" asp-action="CreateSector" class="bg-camp-accent-grey p-6 rounded-2xl border border-gray-700 space-y-4">
        <div>
            <label class="block text-gray-300 text-sm mb-1">اسم القاطع</label>
            <input asp-for="Name" required placeholder="مثال: A, B, C, D"
                   class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            <span asp-validation-for="Name" class="text-red-400 text-xs"></span>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">المخيم</label>
            <input asp-for="Camp" placeholder="اسم المخيم"
                   class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">الإحداثيات</label>
            <input asp-for="Coordinate" placeholder="مثال: 36.1234, 42.5678"
                   class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">المنطقة</label>
            <input asp-for="Area" placeholder="اسم المنطقة"
                   class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
        </div>
        <div class="grid grid-cols-3 gap-3">
            <div>
                <label class="block text-gray-300 text-sm mb-1">خيم تصنيع</label>
                <input asp-for="ManufacturedTentsCount" type="number" min="0" value="0"
                       class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            </div>
            <div>
                <label class="block text-gray-300 text-sm mb-1">خيم يدوي</label>
                <input asp-for="HandmadeTentsCount" type="number" min="0" value="0"
                       class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            </div>
            <div>
                <label class="block text-gray-300 text-sm mb-1">حمامات</label>
                <input asp-for="BathroomsCount" type="number" min="0" value="0"
                       class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-camp-gold text-black font-bold px-6 py-2 rounded-lg hover:bg-yellow-500 transition">حفظ</button>
            <a asp-action="Sectors" class="bg-gray-700 text-gray-300 px-6 py-2 rounded-lg hover:bg-gray-600 transition">إلغاء</a>
        </div>
    </form>
</div>
