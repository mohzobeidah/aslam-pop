@model DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
    var role = ViewBag.AdminRole as string;
    var isSuper = role == "Admin";
    var totalMales = Model.Sectors.Sum(s => s.TotalMales);
    var totalFemales = Model.Sectors.Sum(s => s.TotalFemales);
    var totalPersons = totalMales + totalFemales;
    var totalChildren = Model.Sectors.Sum(s => s.ChildrenUnder18);
    var totalAdults = Model.Sectors.Sum(s => s.Adults18To60);
    var totalElderly = Model.Sectors.Sum(s => s.Elderly);
    var totalFamilies = Model.Sectors.Sum(s => s.TotalFamilies);
    var totalFemaleLed = Model.Sectors.Sum(s => s.FemaleLedFamilies);
    var totalChildLed = Model.Sectors.Sum(s => s.ChildLedFamilies);
    var totalNormalFamilies = totalFamilies - totalFemaleLed - totalChildLed;
    var totalDisabled = Model.Sectors.Sum(s => s.Disabled);
    var totalChronicSick = Model.Sectors.Sum(s => s.ChronicSick);
    var totalApproved = Model.Sectors.Sum(s => s.ApprovedFamilyCount);
}

<div class="flex justify-between items-center mb-6">
    <div>
        <h1 class="text-2xl text-camp-gold font-bold">لوحة التحكم</h1>
        <p class="text-gray-400 text-sm">
            مرحباً، <span class="text-white">@ViewBag.AdminName</span>
            @if (isSuper)
            {
                <span class="bg-camp-gold/20 text-camp-gold text-xs px-2 py-0.5 rounded mr-2">مدير</span>
            }
            else
            {
                <span class="bg-blue-900/50 text-blue-300 text-xs px-2 py-0.5 rounded mr-2">مندوب</span>
            }
        </p>
    </div>
    <div class="flex gap-2">
        <a asp-action="Refugees" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">النازحين</a>
        <a asp-action="Registrations" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">الموافقة على التسجيلات</a>
        <a asp-controller="Complaint" asp-action="Index" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">الشكاوى</a>
        <a asp-controller="Project" asp-action="Index" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">المشاريع</a>
        @if (isSuper)
        {
            <a asp-action="Index" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">إدارة المسؤولين</a>
            <a asp-action="Sectors" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">إدارة القواطع</a>
            <a asp-action="AuditLogs" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">سجل التدقيق</a>
            <a asp-action="DeletedRegistrations" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">المحذوفة</a>
        }
        <form method="post" asp-action="Logout" class="inline">
            <button type="submit" class="bg-red-900/50 text-red-300 px-4 py-2 rounded-lg hover:bg-red-800/50 transition text-sm">تسجيل خروج</button>
        </form>
    </div>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="bg-green-900/50 text-green-300 p-3 rounded-lg mb-4 text-sm">@successMsg</div>
}

<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <div class="text-3xl font-bold text-camp-gold">@Model.TotalRegistrations</div>
        <div class="text-gray-400 text-sm mt-1">إجمالي الأسر المسجلة</div>
    </div>
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <div class="text-3xl font-bold text-green-400">@totalApproved</div>
        <div class="text-gray-400 text-sm mt-1">الأسر المعتمدة</div>
    </div>
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <div class="text-3xl font-bold text-blue-400">@totalPersons</div>
        <div class="text-gray-400 text-sm mt-1">إجمالي الأفراد</div>
    </div>
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <div class="text-3xl font-bold text-camp-gold">@Model.TotalAdmins</div>
        <div class="text-gray-400 text-sm mt-1">إجمالي المسؤولين</div>
    </div>
</div>

@if (isSuper)
{
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700 mb-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl text-camp-gold font-bold">عدد الأسر النازحة حسب القاطع</h2>
            <div class="text-3xl font-bold text-camp-gold">@Model.TotalApprovedRefugees</div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            @foreach (var s in Model.Sectors)
            {
                <div class="bg-gray-800/50 p-3 rounded-lg border border-gray-700">
                    <div class="text-camp-gold font-bold text-lg">@s.SectorName</div>
                    <div class="text-gray-400 text-sm"><span class="text-white font-bold text-xl">@s.ApprovedFamilyCount</span> أسرة</div>
                </div>
            }
        </div>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4 text-center">حالة التسجيلات</h2>
        <div class="relative" style="height: 260px;">
            <canvas id="statusChart"></canvas>
        </div>
    </div>
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4 text-center">توزيع الجنس</h2>
        <div class="relative" style="height: 260px;">
            <canvas id="genderChart"></canvas>
        </div>
    </div>
</div>

<div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700 mb-8">
    <h2 class="text-lg text-camp-gold font-bold mb-4 text-center">إجمالي التسجيلات حسب القاطع</h2>
    <div class="relative" style="height: 300px;">
        <canvas id="registrationsChart"></canvas>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4 text-center">الفئات العمرية</h2>
        <div class="relative" style="height: 260px;">
            <canvas id="ageChart"></canvas>
        </div>
    </div>
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4 text-center">قيادة الأسرة</h2>
        <div class="relative" style="height: 260px;">
            <canvas id="familyChart"></canvas>
        </div>
    </div>
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4 text-center">الصحة والإعاقة</h2>
        <div class="relative" style="height: 260px;">
            <canvas id="healthChart"></canvas>
        </div>
    </div>
</div>

<div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700 mb-8">
    <h2 class="text-lg text-camp-gold font-bold mb-4 text-center">عدد مرات تسجيل دخول المسؤولين</h2>
    <div class="relative" style="height: 300px;">
        <canvas id="loginChart"></canvas>
    </div>
</div>

<h2 class="text-xl text-camp-gold font-bold mb-4">إحصائيات تفصيلية حسب القاطع</h2>

<div class="overflow-x-auto">
    <table class="w-full bg-camp-accent-grey rounded-xl border border-gray-700" style="min-width: 3200px;">
        <thead>
            <tr class="border-b border-gray-700 text-camp-gold text-xs">
                <th colspan="9" class="p-2 text-center border-l border-gray-700">معلومات القاطع</th>
                <th colspan="8" class="p-2 text-center border-l border-gray-700">إحصائيات الأسرة</th>
                <th colspan="6" class="p-2 text-center border-l border-gray-700">تصنيف الأفراد</th>
                <th colspan="3" class="p-2 text-center border-l border-gray-700">أقل من 5 سنوات</th>
                <th colspan="3" class="p-2 text-center border-l border-gray-700">رضع (0-2)</th>
                <th colspan="3" class="p-2 text-center border-l border-gray-700">أطفال (2-5)</th>
                <th colspan="3" class="p-2 text-center border-l border-gray-700">تحت 18 سنة</th>
                <th colspan="3" class="p-2 text-center border-l border-gray-700">بالغين (18-60)</th>
                <th colspan="3" class="p-2 text-center border-l border-gray-700">كبار (>60)</th>
                <th colspan="4" class="p-2 text-center">الصحة</th>
            </tr>
            <tr class="border-b border-gray-700 text-camp-gold text-xs">
                <th class="p-2 text-right">القاطع</th>
                <th class="p-2 text-right">المخيم</th>
                <th class="p-2 text-right">المنطقة</th>
                <th class="p-2 text-center">الإحداثيات</th>
                <th class="p-2 text-center">خيم مصنعة</th>
                <th class="p-2 text-center">خيم يدوية</th>
                <th class="p-2 text-center">حمامات</th>
                <th class="p-2 text-center">مسجلين</th>
                <th class="p-2 text-center border-l border-gray-700">معتمد</th>
                <th class="p-2 text-center">عدد الأفراد</th>
                <th class="p-2 text-center">عدد الأسر</th>
                <th class="p-2 text-center">تقودها امرأة</th>
                <th class="p-2 text-center">يقودها طفل</th>
                <th class="p-2 text-center">رب أسرة</th>
                <th class="p-2 text-center">زوجات</th>
                <th class="p-2 text-center border-l border-gray-700">ذكور</th>
                <th class="p-2 text-center border-l border-gray-700">إناث</th>
                <th class="p-2 text-center">رب أسرة</th>
                <th class="p-2 text-center">زوجة</th>
                <th class="p-2 text-center">ابن</th>
                <th class="p-2 text-center">ابنة</th>
                <th class="p-2 text-center border-l border-gray-700">ذكور</th>
                <th class="p-2 text-center border-l border-gray-700">إناث</th>
                <th class="p-2 text-center">المجموع</th>
                <th class="p-2 text-center">ذكور</th>
                <th class="p-2 text-center border-l border-gray-700">إناث</th>
                <th class="p-2 text-center">المجموع</th>
                <th class="p-2 text-center">ذكور</th>
                <th class="p-2 text-center border-l border-gray-700">إناث</th>
                <th class="p-2 text-center">المجموع</th>
                <th class="p-2 text-center">ذكور</th>
                <th class="p-2 text-center border-l border-gray-700">إناث</th>
                <th class="p-2 text-center">المجموع</th>
                <th class="p-2 text-center">ذكور</th>
                <th class="p-2 text-center border-l border-gray-700">إناث</th>
                <th class="p-2 text-center">المجموع</th>
                <th class="p-2 text-center">ذكور</th>
                <th class="p-2 text-center border-l border-gray-700">إناث</th>
                <th class="p-2 text-center">المجموع</th>
                <th class="p-2 text-center">ذكور</th>
                <th class="p-2 text-center border-l border-gray-700">إناث</th>
                <th class="p-2 text-center">ذوي إعاقة</th>
                <th class="p-2 text-center">ذكور</th>
                <th class="p-2 text-center">إناث</th>
                <th class="p-2 text-center">أمراض مزمنة</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Sectors)
            {
                <tr class="border-b border-gray-700 hover:bg-gray-800/50 text-xs">
                    <td class="p-2 font-bold text-white">@s.SectorName</td>
                    <td class="p-2 text-gray-300">@s.Camp</td>
                    <td class="p-2 text-gray-300">@s.Area</td>
                    <td class="p-2 text-center text-gray-300">@s.Coordinate</td>
                    <td class="p-2 text-center text-gray-300">@s.ManufacturedTents</td>
                    <td class="p-2 text-center text-gray-300">@s.HandmadeTents</td>
                    <td class="p-2 text-center text-gray-300">@s.Bathrooms</td>
                    <td class="p-2 text-center text-camp-gold font-bold">@s.RegistrationCount</td>
                    <td class="p-2 text-center text-green-400 font-bold border-l border-gray-700">@s.ApprovedFamilyCount</td>
                    <td class="p-2 text-center text-camp-gold font-bold">@s.TotalPersons</td>
                    <td class="p-2 text-center text-gray-300">@s.TotalFamilies</td>
                    <td class="p-2 text-center text-gray-300">@s.FemaleLedFamilies</td>
                    <td class="p-2 text-center text-gray-300">@s.ChildLedFamilies</td>
                    <td class="p-2 text-center text-gray-300">@s.HeadCount</td>
                    <td class="p-2 text-center text-gray-300">@s.WifeCount</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.TotalMales</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.TotalFemales</td>
                    <td class="p-2 text-center text-gray-300">@s.HeadCount</td>
                    <td class="p-2 text-center text-gray-300">@s.WifeCount</td>
                    <td class="p-2 text-center text-gray-300">@s.SonCount</td>
                    <td class="p-2 text-center text-gray-300">@s.DaughterCount</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.TotalMales</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.TotalFemales</td>
                    <td class="p-2 text-center text-gray-300">@s.ChildrenUnder5</td>
                    <td class="p-2 text-center text-gray-300">@s.MaleUnder5</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.FemaleUnder5</td>
                    <td class="p-2 text-center text-gray-300">@s.InfantsUnder2</td>
                    <td class="p-2 text-center text-gray-300">@s.MaleInfants</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.FemaleInfants</td>
                    <td class="p-2 text-center text-gray-300">@s.Children2To5</td>
                    <td class="p-2 text-center text-gray-300">@s.Male2To5</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.Female2To5</td>
                    <td class="p-2 text-center text-gray-300">@s.ChildrenUnder18</td>
                    <td class="p-2 text-center text-gray-300">@s.MaleUnder18</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.FemaleUnder18</td>
                    <td class="p-2 text-center text-gray-300">@s.Adults18To60</td>
                    <td class="p-2 text-center text-gray-300">@s.MaleAdults</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.FemaleAdults</td>
                    <td class="p-2 text-center text-gray-300">@s.Elderly</td>
                    <td class="p-2 text-center text-gray-300">@s.MaleElderly</td>
                    <td class="p-2 text-center text-gray-300 border-l border-gray-700">@s.FemaleElderly</td>
                    <td class="p-2 text-center text-yellow-400 font-bold">@s.Disabled</td>
                    <td class="p-2 text-center text-gray-300">@s.MaleDisabled</td>
                    <td class="p-2 text-center text-gray-300">@s.FemaleDisabled</td>
                    <td class="p-2 text-center text-red-400 font-bold">@s.ChronicSick</td>
                </tr>
            }
            @if (!Model.Sectors.Any())
            {
                <tr>
                    <td colspan="47" class="p-6 text-center text-gray-500">لا توجد قواطع بعد</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var gold = '#D4AF37';
            var blue = '#3B82F6';
            var green = '#22C55E';
            var red = '#EF4444';
            var orange = '#F97316';
            var purple = '#A855F7';
            var teal = '#14B8A6';
            var pink = '#EC4899';
            var yellow = '#EAB308';

            new Chart(document.getElementById('statusChart'), {
                type: 'doughnut',
                data: {
                    labels: ['قيد الانتظار', 'معتمد', 'مرفوض'],
                    datasets: [{
                        data: [@Model.PendingCount, @Model.ApprovedCount, @Model.RejectedCount],
                        backgroundColor: [orange, green, red],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#9CA3AF', padding: 16, font: { size: 13 } }
                        }
                    }
                }
            });

            new Chart(document.getElementById('genderChart'), {
                type: 'doughnut',
                data: {
                    labels: ['ذكور', 'إناث'],
                    datasets: [{
                        data: [@totalMales, @totalFemales],
                        backgroundColor: [blue, pink],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#9CA3AF', padding: 16, font: { size: 13 } }
                        }
                    }
                }
            });

            new Chart(document.getElementById('registrationsChart'), {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.Sectors.Select(s => $"'{s.SectorName}'")))],
                    datasets: [{
                        label: 'عدد التسجيلات',
                        data: [@string.Join(",", Model.Sectors.Select(s => s.RegistrationCount))],
                        backgroundColor: gold,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { color: '#9CA3AF', stepSize: 1 },
                            grid: { color: '#374151' }
                        },
                        x: {
                            ticks: { color: '#9CA3AF' },
                            grid: { display: false }
                        }
                    }
                }
            });

            new Chart(document.getElementById('ageChart'), {
                type: 'doughnut',
                data: {
                    labels: ['أطفال (أقل من 18)', 'بالغين (18-60)', 'كبار (>60)'],
                    datasets: [{
                        data: [@totalChildren, @totalAdults, @totalElderly],
                        backgroundColor: [teal, blue, purple],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#9CA3AF', padding: 14, font: { size: 12 } }
                        }
                    }
                }
            });

            new Chart(document.getElementById('familyChart'), {
                type: 'doughnut',
                data: {
                    labels: ['تقودها امرأة', 'يقودها طفل', 'قيادة عادية'],
                    datasets: [{
                        data: [@totalFemaleLed, @totalChildLed, @totalNormalFamilies],
                        backgroundColor: [pink, orange, gold],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#9CA3AF', padding: 14, font: { size: 12 } }
                        }
                    }
                }
            });

            new Chart(document.getElementById('healthChart'), {
                type: 'bar',
                data: {
                    labels: ['ذوي إعاقة', 'أمراض مزمنة', 'أصحاء'],
                    datasets: [{
                        data: [@totalDisabled, @totalChronicSick, @(totalPersons - totalDisabled - totalChronicSick)],
                        backgroundColor: [yellow, red, green],
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            ticks: { color: '#9CA3AF', stepSize: 1 },
                            grid: { color: '#374151' }
                        },
                        y: {
                            ticks: { color: '#9CA3AF' },
                            grid: { display: false }
                        }
                    }
                }
            });

            new Chart(document.getElementById('loginChart'), {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.AdminLoginData.Select(m => $"'{m.Name}'")))],
                    datasets: [{
                        label: 'عدد مرات الدخول',
                        data: [@string.Join(",", Model.AdminLoginData.Select(m => m.LoginCount))],
                        backgroundColor: [@Html.Raw(string.Join(",", Model.AdminLoginData.Select(m => m.Role == "مدير" ? "'#D4AF37'" : "'#3B82F6'")))],
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { color: '#9CA3AF', stepSize: 1 },
                            grid: { color: '#374151' }
                        },
                        x: {
                            ticks: { color: '#9CA3AF' },
                            grid: { display: false }
                        }
                    }
                }
            });
        });
    </script>
}
