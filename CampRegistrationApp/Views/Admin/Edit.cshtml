@model Admin
@{
    ViewData["Title"] = "تعديل بيانات مسؤول";
    var sectors = ViewBag.Sectors as List<Sector> ?? new();
}

<div class="max-w-lg mx-auto">
    <h1 class="text-2xl text-camp-gold font-bold mb-6">تعديل بيانات المسؤول</h1>

    <form method="post" asp-action="Edit" class="bg-camp-accent-grey p-6 rounded-2xl border border-gray-700 space-y-4">
        <input type="hidden" asp-for="Id">

        <div>
            <label class="block text-gray-300 text-sm mb-1">الاسم الكامل</label>
            <input asp-for="Name" required class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            <span asp-validation-for="Name" class="text-red-400 text-xs"></span>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">رقم الهوية</label>
            <input asp-for="NationalId" required class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            <span asp-validation-for="NationalId" class="text-red-400 text-xs"></span>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">رقم الجوال</label>
            <input asp-for="Mobile" required class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            <span asp-validation-for="Mobile" class="text-red-400 text-xs"></span>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">كلمة مرور جديدة (اتركها فارغة إن لم ترد التغيير)</label>
            <div class="relative">
                <input type="password" name="newPassword" id="adminEditPassword" class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 pr-3 pl-10 focus:border-camp-gold focus:outline-none">
                <button type="button" onclick="togglePassword('adminEditPassword', this)" class="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-camp-gold transition-colors p-1">
                    <svg class="w-5 h-5 eye-open" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    <svg class="w-5 h-5 eye-closed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                </button>
            </div>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">الدور</label>
            <select asp-for="Role" class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
                <option value="Mandoob">مندوب</option>
                <option value="Admin">مدير</option>
            </select>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">القاطع</label>
            <select asp-for="SectorId" class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
                <option value="">— بدون —</option>
                @foreach (var s in sectors)
                {
                    <option value="@s.Id" selected="@(s.Id == Model.SectorId)">@s.Name</option>
                }
            </select>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-camp-gold text-black font-bold px-6 py-2 rounded-lg hover:bg-yellow-500 transition">حفظ التغييرات</button>
            <a asp-action="Index" class="bg-gray-700 text-gray-300 px-6 py-2 rounded-lg hover:bg-gray-600 transition">إلغاء</a>
        </div>
    </form>
</div>

<script>
    function togglePassword(inputId, btn) {
        const input = document.getElementById(inputId);
        const openIcon = btn.querySelector('.eye-open');
        const closedIcon = btn.querySelector('.eye-closed');
        if (input.type === 'password') {
            input.type = 'text';
            openIcon.classList.add('hidden');
            closedIcon.classList.remove('hidden');
        } else {
            input.type = 'password';
            openIcon.classList.remove('hidden');
            closedIcon.classList.add('hidden');
        }
    }
</script>
