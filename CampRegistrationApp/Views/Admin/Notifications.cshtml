@model List<Notification>
@{
    ViewData["Title"] = "الإشعارات";
}

<div class="max-w-3xl mx-auto">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl text-camp-gold font-bold">الإشعارات</h1>
        <div class="flex gap-2">
            @if (Model.Any(n => !n.IsRead))
            {
                <form method="post" asp-action="MarkAllNotificationsRead" class="inline">
                    <button type="submit" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">
                        تحديد الكل كمقروء
                    </button>
                </form>
            }
            <a asp-action="Dashboard" class="text-gray-400 hover:text-camp-gold text-sm px-3 py-2">← العودة</a>
        </div>
    </div>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="bg-green-900/50 text-green-300 p-3 rounded-lg mb-4 text-sm">@successMsg</div>
    }

    <div class="space-y-2">
        @foreach (var n in Model)
        {
            <div class="bg-camp-accent-grey p-4 rounded-xl border @(n.IsRead ? "border-gray-700" : "border-camp-gold/50") flex items-start gap-3">
                <div class="flex-1">
                    <div class="flex items-center gap-2">
                        @if (!n.IsRead)
                        {
                            <span class="w-2 h-2 bg-camp-gold rounded-full inline-block"></span>
                        }
                        <span class="@(n.IsRead ? "text-gray-400" : "text-white") text-sm">@n.Message</span>
                    </div>
                    <span class="text-gray-500 text-xs block mt-1">@n.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                </div>
                <div class="flex gap-2 items-center shrink-0">
                    @if (!string.IsNullOrEmpty(n.Link))
                    {
                        <a href="@n.Link" class="text-camp-gold hover:text-yellow-500 transition text-sm">عرض</a>
                    }
                    @if (!n.IsRead)
                    {
                        <form method="post" asp-action="MarkNotificationRead" asp-route-id="@n.Id" class="inline">
                            <button type="submit" class="text-gray-400 hover:text-camp-gold transition text-xs">مقروء</button>
                        </form>
                    }
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="text-center text-gray-500 py-12">لا توجد إشعارات</div>
        }
    </div>
</div>
