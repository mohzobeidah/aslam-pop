@{
    ViewData["Title"] = "تسجيل دخول المسؤولين";
}

<div class="max-w-md mx-auto mt-20">
    <div class="bg-camp-accent-grey p-8 rounded-2xl shadow-xl border border-gray-700">
        <h1 class="text-2xl text-camp-gold text-center font-bold mb-2">نظام إدارة المخيم</h1>
        <p class="text-gray-400 text-center mb-6">تسجيل دخول المسؤولين</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-900/50 text-red-300 p-3 rounded-lg mb-4 text-sm">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" asp-action="Login">
            <div class="mb-4">
                <label class="block text-gray-300 text-sm mb-1">رقم الهوية</label>
                <input type="text" name="nationalId" required
                       class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            </div>
            <div class="mb-6">
                <label class="block text-gray-300 text-sm mb-1">كلمة المرور</label>
                <input type="password" name="password" required
                       class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            </div>
            <button type="submit"
                    class="w-full bg-camp-gold text-black font-bold py-3 rounded-xl hover:bg-yellow-500 transition">
                دخول
            </button>
        </form>

        <div class="text-center mt-4">
            <a asp-controller="Home" asp-action="Index" class="text-gray-400 hover:text-camp-gold text-sm transition">
                ← العودة إلى الرئيسية
            </a>
        </div>
    </div>
</div>
