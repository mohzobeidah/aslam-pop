@model FamilyRegistration
@{
    ViewData["Title"] = "تفاصيل النازح";
    var head = Model.FamilyHead;
}

<div class="mb-6">
    <a asp-action="Refugees" class="text-gray-400 hover:text-camp-gold text-sm transition">← النازحين</a>
    <h1 class="text-2xl text-camp-gold font-bold mt-1">@head.FullName</h1>
    <p class="text-gray-400 text-sm">رقم القيد: @Model.RecordId</p>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="bg-green-900/50 text-green-300 p-3 rounded-lg mb-4 text-sm">@successMsg</div>
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Head Info -->
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4">بيانات رب الأسرة</h2>
        <div class="grid grid-cols-2 gap-3 text-sm">
            <div><span class="text-gray-400">الاسم:</span> <span class="text-white">@head.FullName</span></div>
            <div><span class="text-gray-400">رقم الهوية:</span> <span class="text-white">@head.IdNumber</span></div>
            <div><span class="text-gray-400">القاطع:</span> <span class="text-white">@Model.Sector?.Name</span></div>
            <div><span class="text-gray-400">تاريخ الميلاد:</span> <span class="text-white">@head.DateOfBirth.ToString("yyyy/MM/dd")</span></div>
            <div><span class="text-gray-400">الجنس:</span> <span class="text-white">@head.Gender</span></div>
            <div><span class="text-gray-400">الهاتف:</span> <span class="text-white" dir="ltr">@Model.PhoneNumber</span></div>
            <div><span class="text-gray-400">المحفظة:</span> <span class="text-white" dir="ltr">@Model.Wallet</span></div>
            <div><span class="text-gray-400">نوع المحفظة:</span> <span class="text-white">@Model.WalletType</span></div>
            <div><span class="text-gray-400">الحالة الاجتماعية:</span> <span class="text-white">@head.MaritalStatus</span></div>
            <div><span class="text-gray-400">الوظيفة:</span> <span class="text-white">@head.EmploymentStatus</span></div>
            <div><span class="text-gray-400">المستوى التعليمي:</span> <span class="text-white">@head.EducationLevel</span></div>
            <div><span class="text-gray-400">مكان السكن الأصلي:</span> <span class="text-white">@head.OriginalGovernorate</span></div>
            <div><span class="text-gray-400">المنزل مدمر:</span> <span class="text-white">@(head.IsHouseDestroyed ? "نعم" : "لا")</span></div>
            <div><span class="text-gray-400">أسير:</span> <span class="text-white">@(head.IsPrisoner ? "نعم" : "لا")</span></div>
        </div>
    </div>

    <!-- Health Info -->
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4">الحالة الصحية</h2>
        <div class="grid grid-cols-2 gap-3 text-sm">
            <div><span class="text-gray-400">الحالة الصحية:</span> <span class="text-white">@head.HealthStatus</span></div>
            <div><span class="text-gray-400">الأمراض المزمنة:</span> <span class="text-white">@head.ChronicDiseases</span></div>
            <div><span class="text-gray-400">أنواع الإعاقة:</span> <span class="text-white">@head.DisabilityTypes</span></div>
            <div><span class="text-gray-400">إصابة:</span> <span class="text-white">@(head.HasInjury ? "نعم" : "لا")</span></div>
            @if (head.HasInjury)
            {
                <div><span class="text-gray-400">تاريخ الإصابة:</span> <span class="text-white">@head.InjuryDate?.ToString("yyyy/MM/dd")</span></div>
                <div><span class="text-gray-400">تفاصيل الإصابة:</span> <span class="text-white">@head.InjuryDetails</span></div>
            }
            @if (head.IsPregnant == true)
            {
                <div><span class="text-gray-400">حامل:</span> <span class="text-white">الشهر @head.PregnancyMonth</span></div>
            }
            @if (head.IsNursing == true)
            {
                <div><span class="text-gray-400">مرضع:</span> <span class="text-white">@head.NursingInfantName</span></div>
            }
        </div>
    </div>

    <!-- Attachments -->
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4">المرفقات</h2>
        <div class="grid grid-cols-2 gap-3 text-sm">
            @{
                var attachments = head.Attachments.ToList();
            }
            @if (attachments.Any())
            {
                @foreach (var att in attachments)
                {
                    var label = att.FileType == "IDImage" ? "صورة الهوية" : "تقرير طبي";
                    <div>
                        <span class="text-gray-400">@label:</span>
                        <a href="/File/Download?path=@Uri.EscapeDataString(att.FilePath)" target="_blank" class="text-camp-gold hover:text-yellow-500 underline">تحميل</a>
                    </div>
                }
            }
            else
            {
                <div><span class="text-gray-400">لا توجد مرفقات</span></div>
            }
        </div>
    </div>

    <!-- Housing -->
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4">السكن والحالات الخاصة</h2>
        <div class="grid grid-cols-2 gap-3 text-sm">
            <div><span class="text-gray-400">رب أسرة طفل:</span> <span class="text-white">@(Model.IsChildHeaded ? "نعم" : "لا")</span></div>
            @if (Model.IsChildHeaded) { <div><span class="text-gray-400">تفاصيل:</span> <span class="text-white">@Model.ChildHeadedDetails</span></div> }
            <div><span class="text-gray-400">ربة أسرة امرأة:</span> <span class="text-white">@(Model.IsFemaleHeaded ? "نعم" : "لا")</span></div>
            @if (Model.IsFemaleHeaded) { <div><span class="text-gray-400">تفاصيل:</span> <span class="text-white">@Model.FemaleHeadedDetails</span></div> }
            <div><span class="text-gray-400">الزوج خارج البلاد:</span> <span class="text-white">@(Model.IsHusbandAbroad ? "نعم" : "لا")</span></div>
            <div><span class="text-gray-400">شخص خارجي:</span> <span class="text-white">@(Model.SupportsOutsidePerson ? "نعم" : "لا")</span></div>
            @if (Model.SupportsOutsidePerson) { <div><span class="text-gray-400">اسم الخارجي:</span> <span class="text-white">@Model.OutsidePersonName</span></div> }
            @if (Model.SupportsOutsidePerson) { <div><span class="text-gray-400">صلة القرابة:</span> <span class="text-white">@Model.OutsidePersonRelation</span></div> }
            <div><span class="text-gray-400">يسكن في خيمة:</span> <span class="text-white">@(Model.LivesInTent ? "نعم" : "لا")</span></div>
            @if (Model.LivesInTent) { <div><span class="text-gray-400">نوع الخيمة:</span> <span class="text-white">@Model.TentType @(!string.IsNullOrEmpty(Model.OtherTentType) ? "(" + Model.OtherTentType + ")" : "")</span></div> }
            <div><span class="text-gray-400">حمام:</span> <span class="text-white">@(Model.HasBathroom ? "نعم" : "لا")</span></div>
            @if (Model.HasBathroom) { <div><span class="text-gray-400">نوع الحمام:</span> <span class="text-white">@(Model.BathroomType == "Private" ? "خاص" : Model.BathroomType == "Shared" ? "مشترك" : Model.BathroomType)</span></div> }
            @if (Model.HasBathroom && !string.IsNullOrEmpty(head.BathroomStatus)) { <div><span class="text-gray-400">حالة الحمام:</span> <span class="text-white">@head.BathroomStatus</span></div> }
            <div><span class="text-gray-400">حفائظ:</span> <span class="text-white">@(Model.NeedsDiapers ? "نعم" : "لا")</span></div>
            @if (Model.NeedsDiapers) { <div><span class="text-gray-400">تفاصيل الحفائظ:</span> <span class="text-white">@Model.DiaperDetails</span></div> }
            <div><span class="text-gray-400">أسر بنفس الخيمة:</span> <span class="text-white">@(Model.HasMultipleFamiliesInTent ? "نعم" : "لا")</span></div>
            @if (Model.HasMultipleFamiliesInTent) { <div><span class="text-gray-400">عدد الأسر الإضافية:</span> <span class="text-white">@Model.AdditionalFamiliesCount</span></div> }
        </div>
    </div>

    <!-- Refugee Desires -->
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4">الرغبات (حسب الأهمية)</h2>
        <div class="grid grid-cols-2 gap-3 text-sm">
            @{
                var orderedDesires = Model.FamilyDesires.OrderBy(fd => fd.Order).ToList();
                var labels = new[] { "الأولى", "الثانية", "الثالثة", "الرابعة", "الخامسة", "السادسة", "السابعة", "الثامنة", "التاسعة", "العاشرة" };
            }
            @if (orderedDesires.Any())
            {
                @foreach (var fd in orderedDesires)
                {
                    var label = fd.Order <= labels.Length ? labels[fd.Order - 1] : fd.Order.ToString();
                    <div><span class="text-gray-400">الرغبة @label:</span> <span class="text-white">@fd.Desire.Name</span></div>
                }
            }
            else
            {
                <div><span class="text-gray-400">لم يتم تحديد رغبات</span></div>
            }
        </div>
    </div>

    <!-- Status Notes -->
    @if (!string.IsNullOrEmpty(Model.StatusNotes))
    {
        <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
            <h2 class="text-lg text-camp-gold font-bold mb-4">ملاحظات حول الحالة</h2>
            <p class="text-sm text-white whitespace-pre-wrap">@Model.StatusNotes</p>
        </div>
    }

    <!-- Status -->
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4">حالة التسجيل</h2>
        <div class="grid grid-cols-2 gap-3 text-sm">
            <div>
                <span class="text-gray-400">الحالة:</span>
                <span class="@(Model.ApprovalStatus == RegistrationApprovalStatus.Approved ? "text-green-400" : Model.ApprovalStatus == RegistrationApprovalStatus.Pending ? "text-yellow-400" : "text-red-400") font-bold">
                    @(Model.ApprovalStatus == RegistrationApprovalStatus.Approved ? "مقبول" : Model.ApprovalStatus == RegistrationApprovalStatus.Pending ? "قيد المراجعة" : "مرفوض")
                </span>
            </div>
            <div><span class="text-gray-400">تاريخ التسجيل:</span> <span class="text-white">@Model.RegistrationTimestamp.ToString("yyyy/MM/dd HH:mm")</span></div>
            @if (Model.ApprovedBy != null)
            {
                <div><span class="text-gray-400">تمت الموافقة بواسطة:</span> <span class="text-white">@Model.ApprovedBy.Name</span></div>
                <div><span class="text-gray-400">تاريخ الموافقة:</span> <span class="text-white">@Model.ApprovedAt?.ToString("yyyy/MM/dd HH:mm")</span></div>
            }
            @if (Model.RejectedBy != null)
            {
                <div><span class="text-gray-400">رفض بواسطة:</span> <span class="text-white">@Model.RejectedBy.Name</span></div>
                <div><span class="text-gray-400">تاريخ الرفض:</span> <span class="text-white">@Model.RejectedAt?.ToString("yyyy/MM/dd HH:mm")</span></div>
                @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
                {
                    <div class="col-span-2 mt-1">
                        <span class="text-gray-400">سبب الرفض:</span>
                        <span class="text-white whitespace-pre-wrap">@Model.RejectionReason</span>
                    </div>
                }
            }
        </div>

        <div class="mt-4 pt-4 border-t border-gray-700 flex gap-3 flex-wrap">
            <a asp-action="AdminEditRegistration" asp-route-id="@Model.Id"
               class="bg-camp-gold text-black px-4 py-2 rounded-lg hover:bg-yellow-500 transition text-sm font-bold">
                تعديل البيانات
            </a>
            @if (Model.ApprovalStatus == RegistrationApprovalStatus.Pending)
            {
                <form method="post" asp-action="ApproveRegistration" asp-route-id="@Model.Id" class="inline">
                    <button type="submit" class="bg-green-700 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition text-sm font-bold">موافقة</button>
                </form>
                <button type="button" onclick="showRejectModal(@Model.Id, '@Model.FamilyHead.FullName')"
                        class="bg-red-700 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition text-sm font-bold">
                    رفض
                </button>
            }
            else if (Model.ApprovalStatus == RegistrationApprovalStatus.Rejected)
            {
                <form method="post" asp-action="ApproveRegistration" asp-route-id="@Model.Id" class="inline">
                    <button type="submit" class="bg-green-700 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition text-sm font-bold">إلغاء الرفض وتحويل إلى مقبول</button>
                </form>
            }
            @if (Model.ApprovalStatus == RegistrationApprovalStatus.Approved)
            {
                <button type="button" onclick="resetPassword(@Model.Id, '@Model.FamilyHead.FullName')"
                        class="bg-blue-700 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition text-sm font-bold">
                    إعادة تعيين كلمة المرور
                </button>
                <form method="post" asp-action="RemoveRefugee" asp-route-id="@Model.Id"
                      onsubmit="return confirm('هل أنت متأكد من إزالة @Model.FamilyHead.FullName؟ تم نقل العائلة خارج المخيم؟')">
                    <button type="submit" class="bg-red-700 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition text-sm font-bold">
                        إزالة — انتقل خارج المخيم
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="hidden fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-4">
    <div class="bg-camp-accent-grey rounded-xl border border-gray-700 p-6 w-full max-w-md">
        <h3 class="text-lg text-camp-gold font-bold mb-3">رفض تسجيل: <span id="rejectModalHeadName"></span></h3>
        <form id="rejectForm" method="post" asp-action="RejectRegistration">
            <input type="hidden" name="id" id="rejectModalId" />
            <label class="block text-camp-gold text-sm mb-1">سبب الرفض <span class="text-red-400">*</span></label>
            <textarea name="reason" id="rejectReason" required minlength="3" rows="4"
                      class="w-full bg-gray-800 text-white border border-gray-600 rounded-lg p-2 text-sm focus:border-camp-gold outline-none"
                      placeholder="اكتب سبب الرفض..."></textarea>
            <div class="mt-4 flex gap-2 justify-end">
                <button type="button" onclick="closeRejectModal()" class="bg-gray-700 text-white px-4 py-2 rounded-lg text-sm">إلغاء</button>
                <button type="submit" class="bg-red-700 text-white px-4 py-2 rounded-lg hover:bg-red-600 text-sm font-bold">تأكيد الرفض</button>
            </div>
        </form>
    </div>
</div>

<script>
    function showRejectModal(id, name) {
        document.getElementById('rejectModalId').value = id;
        document.getElementById('rejectModalHeadName').textContent = name;
        document.getElementById('rejectReason').value = '';
        document.getElementById('rejectModal').classList.remove('hidden');
    }
    function closeRejectModal() {
        document.getElementById('rejectModal').classList.add('hidden');
    }
</script>

<!-- Family Members -->
<div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700 mt-6">
    <h2 class="text-lg text-camp-gold font-bold mb-4">أفراد الأسرة (@Model.Members.Count)</h2>
    @if (Model.Members.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-gray-700 text-camp-gold text-sm">
                        <th class="p-2 text-right">الاسم</th>
                        <th class="p-2 text-center">رقم الهوية</th>
                        <th class="p-2 text-center">صلة القرابة</th>
                        <th class="p-2 text-center">الجنس</th>
                        <th class="p-2 text-center">تاريخ الميلاد</th>
                        <th class="p-2 text-center">الحالة الصحية</th>
                        <th class="p-2 text-center">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Members)
                    {
                        var p = m.Person;
                        <tr class="border-b border-gray-700 text-sm hover:bg-gray-800/50">
                            <td class="p-2 text-white font-bold">@p.FullName</td>
                            <td class="p-2 text-center text-gray-300">@p.IdNumber</td>
                            <td class="p-2 text-center text-gray-300">@m.RelationshipToHead</td>
                            <td class="p-2 text-center text-gray-300">@p.Gender</td>
                            <td class="p-2 text-center text-gray-300">@p.DateOfBirth.ToString("yyyy/MM/dd")</td>
                            <td class="p-2 text-center text-gray-300">@p.HealthStatus</td>
                            <td class="p-2 text-center">
                                <button type="button" onclick='showMemberModal(@Html.Raw(Json.Serialize(new {
                                    name = p.FullName,
                                    idNumber = p.IdNumber,
                                    relationship = m.RelationshipToHead,
                                    gender = p.Gender,
                                    dob = p.DateOfBirth.ToString("yyyy/MM/dd"),
                                    maritalStatus = p.MaritalStatus,
                                    healthStatus = p.HealthStatus,
                                    chronicDiseases = p.ChronicDiseases,
                                    disabilityTypes = p.DisabilityTypes,
                                    hasInjury = p.HasInjury,
                                    injuryDate = p.InjuryDate?.ToString("yyyy/MM/dd"),
                                    injuryDetails = p.InjuryDetails,
                                    isPregnant = p.IsPregnant,
                                    pregnancyMonth = p.PregnancyMonth,
                                    isNursing = p.IsNursing,
                                    nursingInfantName = p.NursingInfantName,
                                    nursingInfantDOB = p.NursingInfantDOB?.ToString("yyyy/MM/dd"),
                                    isPrisoner = p.IsPrisoner,
                                    employmentStatus = p.EmploymentStatus,
                                    educationLevel = p.EducationLevel,
                                    originalGovernorate = p.OriginalGovernorate,
                                    bathroomStatus = p.BathroomStatus,
                                    isHouseDestroyed = p.IsHouseDestroyed
                                })))' class="text-camp-gold hover:text-yellow-500 transition text-sm cursor-pointer">
                                    عرض التفاصيل
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-gray-500 text-center py-4">لا يوجد أفراد إضافيون</p>
    }
</div>

<!-- Member Details Modal -->
<div id="memberModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4" onclick="if(event.target===this)closeMemberModal()">
    <div class="bg-camp-accent-grey rounded-xl border border-gray-700 w-full max-w-lg max-h-[90vh] overflow-y-auto shadow-2xl">
        <div class="sticky top-0 bg-camp-accent-grey border-b border-gray-700 p-4 flex justify-between items-center">
            <h2 class="text-lg text-camp-gold font-bold" id="memberModalTitle">تفاصيل العضو</h2>
            <button onclick="closeMemberModal()" class="text-gray-400 hover:text-white text-2xl leading-none">&times;</button>
        </div>
        <div class="p-4" id="memberModalBody"></div>
    </div>
</div>

@Html.AntiForgeryToken()

<!-- Reset Password Modal -->
<div id="resetPasswordModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4" onclick="if(event.target===this)closeResetModal()">
    <div class="bg-camp-accent-grey rounded-xl border border-gray-700 w-full max-w-md shadow-2xl">
        <div class="border-b border-gray-700 p-4 flex justify-between items-center">
            <h2 class="text-lg text-camp-gold font-bold">تم إعادة تعيين كلمة المرور</h2>
            <button onclick="closeResetModal()" class="text-gray-400 hover:text-white text-2xl leading-none">&times;</button>
        </div>
        <div class="p-6 text-center">
            <p class="text-gray-300 mb-2" id="resetPasswordName"></p>
            <div class="bg-gray-800 rounded-lg p-4 mb-4">
                <p class="text-gray-400 text-sm mb-1">كلمة المرور الجديدة</p>
                <p id="resetPasswordValue" class="text-3xl text-camp-gold font-bold font-mono tracking-widest"></p>
            </div>
            <p class="text-gray-500 text-xs">يرجى حفظ كلمة المرور وإرسالها إلى النازح</p>
        </div>
        <div class="border-t border-gray-700 p-4 flex justify-center">
            <button onclick="closeResetModal()" class="bg-camp-gold text-black px-6 py-2 rounded-lg hover:bg-yellow-500 transition font-bold text-sm">حسناً</button>
        </div>
    </div>
</div>

<script>
    function resetPassword(id, headName) {
        if (!confirm('إعادة تعيين كلمة المرور لـ ' + headName + '؟')) return;

        fetch('/Admin/ResetPassword', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: 'id=' + id
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                document.getElementById('resetPasswordName').textContent = headName;
                document.getElementById('resetPasswordValue').textContent = data.newPassword;
                var modal = document.getElementById('resetPasswordModal');
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            }
        })
        .catch(function() { alert('حدث خطأ أثناء إعادة تعيين كلمة المرور'); });
    }

    function closeResetModal() {
        var modal = document.getElementById('resetPasswordModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    function showMemberModal(data) {
        var modal = document.getElementById('memberModal');
        document.getElementById('memberModalTitle').textContent = data.name;
        modal.classList.remove('hidden');
        modal.classList.add('flex');

        var html = '<div class="grid grid-cols-2 gap-3 text-sm">';

        var fields = [
            { label: 'رقم الهوية', value: data.idNumber },
            { label: 'صلة القرابة', value: data.relationship },
            { label: 'الجنس', value: data.gender },
            { label: 'تاريخ الميلاد', value: data.dob },
            { label: 'الحالة الاجتماعية', value: data.maritalStatus || '-' },
            { label: 'الحالة الصحية', value: data.healthStatus },
            { label: 'الأمراض المزمنة', value: data.chronicDiseases || '-' },
            { label: 'أنواع الإعاقة', value: data.disabilityTypes || '-' },
            { label: 'الوظيفة', value: data.employmentStatus || '-' },
            { label: 'المستوى التعليمي', value: data.educationLevel || '-' },
            { label: 'مكان السكن الأصلي', value: data.originalGovernorate || '-' },
            { label: 'حالة الحمام', value: data.bathroomStatus || '-' },
        ];

        fields.forEach(function(f) {
            html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">' + f.label + ':</span> <span class="text-white">' + f.value + '</span></div>';
        });

        // Injury
        html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">إصابة:</span> <span class="text-white">' + (data.hasInjury ? 'نعم' : 'لا') + '</span></div>';
        if (data.hasInjury) {
            html += '<div class="border-b border-gray-800 pb-2 col-span-2"><span class="text-gray-400">تاريخ الإصابة:</span> <span class="text-white">' + (data.injuryDate || '-') + '</span></div>';
            html += '<div class="border-b border-gray-800 pb-2 col-span-2"><span class="text-gray-400">تفاصيل الإصابة:</span> <span class="text-white">' + (data.injuryDetails || '-') + '</span></div>';
        }

        // Pregnancy / Nursing
        if (data.gender === 'female' || data.gender === 'أنثى') {
            html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">حامل:</span> <span class="text-white">' + (data.isPregnant ? 'نعم' : 'لا') + '</span></div>';
            if (data.isPregnant) {
                html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">شهر الحمل:</span> <span class="text-white">' + (data.pregnancyMonth || '-') + '</span></div>';
            }
            html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">مرضع:</span> <span class="text-white">' + (data.isNursing ? 'نعم' : 'لا') + '</span></div>';
            if (data.isNursing) {
                html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">اسم الطفل:</span> <span class="text-white">' + (data.nursingInfantName || '-') + '</span></div>';
                html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">تاريخ ميلاد الطفل:</span> <span class="text-white">' + (data.nursingInfantDOB || '-') + '</span></div>';
            }
        }

        html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">أسير:</span> <span class="text-white">' + (data.isPrisoner ? 'نعم' : 'لا') + '</span></div>';
        html += '<div class="border-b border-gray-800 pb-2"><span class="text-gray-400">منزل مدمر:</span> <span class="text-white">' + (data.isHouseDestroyed ? 'نعم' : 'لا') + '</span></div>';

        html += '</div>';
        document.getElementById('memberModalBody').innerHTML = html;
    }

    function closeMemberModal() {
        var modal = document.getElementById('memberModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }
</script>

<div class="mt-6">
    <a asp-action="Refugees" class="text-gray-400 hover:text-camp-gold text-sm transition">← العودة إلى قائمة النازحين</a>
</div>
