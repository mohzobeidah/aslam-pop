@model RefugeeListPageViewModel
@{
    ViewData["Title"] = "قائمة النازحين";
    var sectors = ViewBag.Sectors as List<string> ?? new();
}

<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl text-camp-gold font-bold">النازحين</h1>
    <span class="text-gray-400 text-sm">إجمالي: @Model.TotalCount</span>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="bg-green-900/50 text-green-300 p-3 rounded-lg mb-4 text-sm">@successMsg</div>
}

<!-- Status Summary Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <a asp-action="Refugees" asp-route-status="Approved" class="block bg-camp-accent-grey p-4 rounded-xl border @(ViewBag.CurrentStatus == "Approved" ? "border-green-500" : "border-gray-700") hover:border-green-500 transition">
        <div class="flex items-center justify-between">
            <span class="text-green-400 font-bold text-lg">@Model.ApprovedCount</span>
            <span class="text-gray-400 text-sm">مقبول</span>
        </div>
    </a>
    <a asp-action="Refugees" asp-route-status="Pending" class="block bg-camp-accent-grey p-4 rounded-xl border @(ViewBag.CurrentStatus == "Pending" ? "border-yellow-500" : "border-gray-700") hover:border-yellow-500 transition">
        <div class="flex items-center justify-between">
            <span class="text-yellow-400 font-bold text-lg">@Model.PendingCount</span>
            <span class="text-gray-400 text-sm">قيد المراجعة</span>
        </div>
    </a>
    <a asp-action="Refugees" asp-route-status="Rejected" class="block bg-camp-accent-grey p-4 rounded-xl border @(ViewBag.CurrentStatus == "Rejected" ? "border-red-500" : "border-gray-700") hover:border-red-500 transition">
        <div class="flex items-center justify-between">
            <span class="text-red-400 font-bold text-lg">@Model.RejectedCount</span>
            <span class="text-gray-400 text-sm">مرفوض</span>
        </div>
    </a>
</div>

<!-- Per-sector approved cards -->
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 mb-6">
    @foreach (var kvp in Model.SectorApprovedCounts.OrderBy(k => k.Key))
    {
        <a asp-action="Refugees" asp-route-sector="@kvp.Key" asp-route-status="Approved"
           class="block bg-camp-accent-grey p-3 rounded-xl border @(ViewBag.CurrentSector == kvp.Key ? "border-camp-gold" : "border-gray-700") hover:border-camp-gold transition text-center">
            <div class="text-2xl font-bold text-camp-gold">@kvp.Value</div>
            <div class="text-gray-400 text-xs">القاطع @kvp.Key</div>
        </a>
    }
</div>

<!-- Filters -->
<div class="bg-camp-accent-grey p-4 rounded-xl border border-gray-700 mb-6">
    <form method="get" class="flex gap-3 items-end">
        <div class="flex-1">
            <label class="block text-camp-gold text-xs mb-1">بحث</label>
            <input type="text" name="search" value="@ViewBag.CurrentSearch" placeholder="رقم الهوية أو الاسم..."
                   class="w-full bg-gray-800 text-white border border-gray-600 rounded-lg p-2 text-sm focus:border-camp-gold outline-none" />
        </div>
        <div>
            <label class="block text-camp-gold text-xs mb-1">القاطع</label>
            <select name="sector" class="bg-gray-800 text-white border border-gray-600 rounded-lg p-2 text-sm focus:border-camp-gold outline-none">
                <option value="">الكل</option>
                @foreach (var s in sectors)
                {
                    <option value="@s" selected="@(ViewBag.CurrentSector == s ? true : null)">@s</option>
                }
            </select>
        </div>
        <div>
            <label class="block text-camp-gold text-xs mb-1">الحالة</label>
            <select name="status" class="bg-gray-800 text-white border border-gray-600 rounded-lg p-2 text-sm focus:border-camp-gold outline-none">
                <option value="">الكل</option>
                <option value="Approved" selected="@(ViewBag.CurrentStatus == "Approved")">مقبول</option>
                <option value="Pending" selected="@(ViewBag.CurrentStatus == "Pending")">قيد المراجعة</option>
                <option value="Rejected" selected="@(ViewBag.CurrentStatus == "Rejected")">مرفوض</option>
            </select>
        </div>
        <button type="submit" class="bg-camp-gold text-black px-4 py-2 rounded-lg hover:bg-yellow-500 transition text-sm font-bold">بحث</button>
        <a asp-action="Refugees" class="text-gray-400 hover:text-camp-gold text-sm px-3 py-2">إلغاء</a>
        <a asp-action="ExportRefugeesToExcel"
           asp-route-sector="@ViewBag.CurrentSector"
           asp-route-search="@ViewBag.CurrentSearch"
           asp-route-status="@ViewBag.CurrentStatus"
           class="bg-green-700 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition text-sm font-bold">
            ⬇ تصدير Excel
        </a>
    </form>
</div>

<div class="overflow-x-auto">
    <table class="w-full bg-camp-accent-grey rounded-xl border border-gray-700">
        <thead>
            <tr class="border-b border-gray-700 text-camp-gold text-sm">
                <th class="p-3 text-right">الاسم</th>
                <th class="p-3 text-center">رقم الهوية</th>
                <th class="p-3 text-center">الهاتف</th>
                <th class="p-3 text-center">القاطع</th>
                <th class="p-3 text-center">الجنس</th>
                <th class="p-3 text-center">عدد الأفراد</th>
                <th class="p-3 text-center">الحالة الصحية</th>
                <th class="p-3 text-center">الحالة</th>
                <th class="p-3 text-center">تاريخ التسجيل</th>
                <th class="p-3 text-center">إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Refugees)
            {
                var statusColor = r.ApprovalStatus switch
                {
                    "Approved" => "text-green-400",
                    "Pending" => "text-yellow-400",
                    "Rejected" => "text-red-400",
                    _ => "text-gray-400"
                };
                var statusText = r.ApprovalStatus switch
                {
                    "Approved" => "مقبول",
                    "Pending" => "قيد المراجعة",
                    "Rejected" => "مرفوض",
                    _ => r.ApprovalStatus
                };
                <tr class="border-b border-gray-700 hover:bg-gray-800/50 text-sm">
                    <td class="p-3 font-bold text-white">@r.HeadName</td>
                    <td class="p-3 text-center text-gray-300">@r.IdNumber</td>
                    <td class="p-3 text-center text-gray-300" dir="ltr">@r.Phone</td>
                    <td class="p-3 text-center text-camp-gold">@r.Sector</td>
                    <td class="p-3 text-center text-gray-300">@r.Gender</td>
                    <td class="p-3 text-center text-gray-300">@r.MemberCount</td>
                    <td class="p-3 text-center text-gray-300">@r.HealthStatus</td>
                    <td class="p-3 text-center"><span class="@statusColor font-bold">@statusText</span></td>
                    <td class="p-3 text-center text-gray-400 text-xs">@r.RegistrationDate.ToString("yyyy/MM/dd")</td>
                    <td class="p-3 text-center">
                        <a asp-action="RefugeeDetails" asp-route-id="@r.Id" class="text-camp-gold hover:text-yellow-500 transition text-sm">عرض</a>
                        @if (r.ApprovalStatus == "Approved")
                        {
                            <form method="post" asp-action="RemoveRefugee" asp-route-id="@r.Id" class="inline mr-2"
                                  onsubmit="return confirm('إزالة @r.HeadName — انتقل خارج المخيم؟')">
                                <button type="submit" class="text-red-400 hover:text-red-300 transition text-xs">إزالة</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Refugees.Any())
            {
                <tr>
                    <td colspan="10" class="p-6 text-center text-gray-500">لا يوجد نازحون بعد</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-4">
    <a asp-action="Dashboard" class="text-gray-400 hover:text-camp-gold text-sm transition">← العودة إلى لوحة التحكم</a>
</div>
