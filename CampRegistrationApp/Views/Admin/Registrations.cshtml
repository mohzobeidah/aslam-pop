@model List<RegistrationApprovalViewModel>
@{
    ViewData["Title"] = "الموافقة على التسجيلات";
    var currentStatus = ViewBag.CurrentStatus as string ?? "Pending";
    var currentSector = ViewBag.CurrentSector as string;
    var isSuper = ViewBag.IsSuperAdmin as bool? ?? false;
}

<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl text-camp-gold font-bold">الموافقة على التسجيلات</h1>
        <div class="flex gap-2">
            <a asp-action="ExportRefugeesToExcel"
               asp-route-sector="@ViewBag.CurrentSector"
               class="bg-green-700 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition text-sm font-bold">
                ⬇ تصدير Excel
            </a>
            <a asp-action="Dashboard" class="bg-camp-accent-grey text-camp-gold px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">
                العودة للوحة التحكم
            </a>
        </div>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="bg-green-900/50 text-green-300 p-3 rounded-lg mb-4 text-sm">@successMsg</div>
}

<!-- Filters -->
<div class="bg-camp-accent-grey p-4 rounded-xl border border-gray-700 mb-6">
    <form method="get" class="flex flex-wrap gap-4 items-end">
        <div>
            <label class="block text-xs text-gray-400 mb-1">الحالة</label>
            <select name="status" class="bg-camp-dark-grey border border-gray-600 rounded p-2 text-sm outline-none focus:border-camp-gold">
                <option value="Pending" selected="@(currentStatus == "Pending")">قيد الانتظار</option>
                <option value="Approved" selected="@(currentStatus == "Approved")">تمت الموافقة</option>
                <option value="Rejected" selected="@(currentStatus == "Rejected")">مرفوض</option>
            </select>
        </div>
        <div>
            <label class="block text-xs text-gray-400 mb-1">القاطع</label>
            <select name="sector" class="bg-camp-dark-grey border border-gray-600 rounded p-2 text-sm outline-none focus:border-camp-gold">
                <option value="">جميع القواطع</option>
                @foreach (var s in ViewBag.Sectors)
                {
                    <option value="@s" selected="@(currentSector == s)">@s</option>
                }
            </select>
        </div>
        <button type="submit" class="bg-camp-gold text-black px-4 py-2 rounded font-bold text-sm hover:bg-yellow-500 transition">تصفية</button>
    </form>
</div>

<!-- Results -->
@if (!Model.Any())
{
    <div class="bg-camp-accent-grey p-8 rounded-xl border border-gray-700 text-center text-gray-400">
        لا توجد تسجيلات @(currentStatus == "Pending" ? "قيد الانتظار" : currentStatus == "Approved" ? "تمت الموافقة عليها" : "مرفوضة")
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="w-full bg-camp-accent-grey rounded-xl border border-gray-700">
            <thead>
                <tr class="border-b border-gray-700 text-camp-gold">
                    <th class="p-3 text-right">معرف التسجيل</th>
                    <th class="p-3 text-right">رب الأسرة</th>
                    <th class="p-3 text-right">رقم الهوية</th>
                    <th class="p-3 text-right">القاطع</th>
                    <th class="p-3 text-center">عدد الأفراد</th>
                    <th class="p-3 text-center">تاريخ التسجيل</th>
                    <th class="p-3 text-center">الحالة</th>
                    @if (currentStatus != "Pending")
                    {
                        <th class="p-3 text-center">تمت بواسطة</th>
                        <th class="p-3 text-center">تاريخ</th>
                    }
                    <th class="p-3 text-center">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in Model)
                {
                    <tr class="border-b border-gray-700 hover:bg-camp-dark-grey/50 transition">
                        <td class="p-3 font-mono text-camp-gold text-sm" dir="ltr">@reg.RecordId</td>
                        <td class="p-3 font-semibold text-white">@reg.HeadName</td>
                        <td class="p-3 font-mono text-sm text-gray-300" dir="ltr">@reg.IdNumber</td>
                        <td class="p-3 text-camp-gold">@reg.Sector</td>
                        <td class="p-3 text-center text-gray-300">@reg.MemberCount</td>
                        <td class="p-3 text-center text-gray-400">@reg.RegistrationDate.ToString("yyyy-MM-dd")</td>
                        <td class="p-3 text-center">
                            @if (reg.ApprovalStatus == RegistrationApprovalStatus.Pending)
                            {
                                <span class="bg-yellow-900/50 text-yellow-300 px-2 py-1 rounded font-semibold">قيد الانتظار</span>
                            }
                            else if (reg.ApprovalStatus == RegistrationApprovalStatus.Approved)
                            {
                                <span class="bg-green-900/50 text-green-300 px-2 py-1 rounded font-semibold">تمت الموافقة</span>
                            }
                            else
                            {
                                <span class="bg-red-900/50 text-red-300 px-2 py-1 rounded font-semibold">مرفوض</span>
                            }
                        </td>
                        @if (currentStatus != "Pending")
                        {
                            <td class="p-3 text-center text-gray-300">@reg.ApprovedByName</td>
                            <td class="p-3 text-center text-gray-400">@reg.ApprovedAt?.ToString("yyyy-MM-dd")</td>
                        }
                        <td class="p-3 text-center">
                            <a asp-action="AdminEditRegistration" asp-route-id="@reg.Id"
                               class="bg-camp-gold text-black px-3 py-1 rounded hover:bg-yellow-500 transition ml-1 font-semibold text-sm">
                                تعديل
                            </a>
                            @if (reg.ApprovalStatus == RegistrationApprovalStatus.Pending)
                            {
                                <form method="post" asp-action="ApproveRegistration" class="inline">
                                    <input type="hidden" name="id" value="@reg.Id" />
                                    <button type="submit" class="bg-green-700 text-white px-3 py-1 rounded hover:bg-green-600 transition ml-1 font-semibold">موافقة</button>
                                </form>
                                <form method="post" asp-action="RejectRegistration" class="inline">
                                    <input type="hidden" name="id" value="@reg.Id" />
                                    <button type="submit" class="bg-red-700 text-white px-3 py-1 rounded hover:bg-red-600 transition font-semibold">رفض</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
