@model Admin
@{
    ViewData["Title"] = "إضافة مسؤول جديد";
    var sectors = ViewBag.Sectors as List<Sector> ?? new();
}

<div class="max-w-lg mx-auto">
    <h1 class="text-2xl text-camp-gold font-bold mb-6">إضافة مسؤول جديد</h1>

    <form method="post" asp-action="Create" class="bg-camp-accent-grey p-6 rounded-2xl border border-gray-700 space-y-4">
        <div>
            <label class="block text-gray-300 text-sm mb-1">الاسم الكامل</label>
            <input asp-for="Name" required class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            <span asp-validation-for="Name" class="text-red-400 text-xs"></span>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">رقم الهوية</label>
            <input asp-for="NationalId" required class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            <span asp-validation-for="NationalId" class="text-red-400 text-xs"></span>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">رقم الجوال</label>
            <input asp-for="Mobile" required class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
            <span asp-validation-for="Mobile" class="text-red-400 text-xs"></span>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">كلمة المرور</label>
            <input type="password" name="password" required class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">الدور</label>
            <select asp-for="Role" class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
                <option value="Mandoob">مندوب</option>
                <option value="Admin">مدير</option>
            </select>
        </div>
        <div>
            <label class="block text-gray-300 text-sm mb-1">القاطع</label>
            <select asp-for="SectorId" class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-4 py-2 focus:border-camp-gold focus:outline-none">
                <option value="">— بدون —</option>
                @foreach (var s in sectors)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-camp-gold text-black font-bold px-6 py-2 rounded-lg hover:bg-yellow-500 transition">حفظ</button>
            <a asp-action="Index" class="bg-gray-700 text-gray-300 px-6 py-2 rounded-lg hover:bg-gray-600 transition">إلغاء</a>
        </div>
    </form>
</div>
