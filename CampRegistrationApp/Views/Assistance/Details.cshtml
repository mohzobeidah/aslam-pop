@model Assistance
@{
    ViewData["Title"] = "تفاصيل المساعدة";
    var isSuper = ViewBag.IsSuperAdmin as bool? ?? false;
    var isViewer = ViewBag.IsViewer as bool? ?? false;
}
<div class="mb-6">
    <a asp-action="Index" class="text-gray-400 hover:text-camp-gold transition">← العودة للمساعدات</a>
</div>

@if (TempData["Success"] is string sm) { <div class="bg-green-900/50 text-green-300 p-3 rounded-lg mb-4 text-sm">@sm</div> }
@if (TempData["Error"] is string em) { <div class="bg-red-900/50 text-red-300 p-3 rounded-lg mb-4 text-sm">@em</div> }

<div class="bg-camp-accent-grey p-6 rounded-xl border border-gray-700 mb-6">
    <div class="flex justify-between items-start">
        <div>
            <h1 class="text-2xl text-camp-gold font-bold">@Model.Name</h1>
            <p class="text-gray-400 text-sm mt-1">@Model.AssistanceType · @Model.Source · @Model.Sector?.Name</p>
        </div>
        <div class="flex gap-2">
            @if (!isViewer)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="bg-blue-700 text-white px-3 py-1 rounded text-sm hover:bg-blue-600">تعديل</a>
                @if (isSuper && Model.Status == AssistanceStatus.Draft)
                {
                    <form method="post" asp-action="Approve" asp-route-id="@Model.Id" class="inline">
                        <button type="submit" class="bg-green-700 text-white px-3 py-1 rounded text-sm hover:bg-green-600">اعتماد</button>
                    </form>
                    <form method="post" asp-action="Cancel" asp-route-id="@Model.Id" class="inline">
                        <button type="submit" class="bg-red-700 text-white px-3 py-1 rounded text-sm hover:bg-red-600">إلغاء</button>
                    </form>
                }
            }
            <a asp-action="ExportBeneficiaries" asp-route-id="@Model.Id" class="bg-camp-gold text-black px-3 py-1 rounded text-sm hover:bg-yellow-500">⬇ تصدير Excel</a>
        </div>
    </div>
    <hr class="border-gray-700 my-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
        <div><span class="text-gray-400">التاريخ:</span> <span class="text-white">@Model.AssistanceDate.ToString("yyyy/MM/dd")</span></div>
        <div><span class="text-gray-400">الحالة:</span>
            @if (Model.Status == AssistanceStatus.Approved) { <span class="text-green-400 font-bold">معتمدة</span> }
            else if (Model.Status == AssistanceStatus.Cancelled) { <span class="text-red-400 font-bold">ملغية</span> }
            else { <span class="text-yellow-400 font-bold">مسودة</span> }
        </div>
        <div><span class="text-gray-400">تاريخ الإضافة:</span> <span class="text-white">@Model.CreatedAt.ToString("yyyy/MM/dd")</span></div>
        <div><span class="text-gray-400">المستخدم:</span> <span class="text-white">@Model.CreatedBy?.Name</span></div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="mt-4 text-sm"><span class="text-gray-400">الوصف:</span><p class="text-white mt-1">@Model.Description</p></div>
    }
</div>

<!-- Beneficiaries -->
<div class="bg-camp-accent-grey p-6 rounded-xl border border-gray-700">
    <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl text-camp-gold font-bold">المستفيدون (@Model.Beneficiaries.Count)</h2>
        <div class="flex gap-2">
            @if (!isViewer)
            {
                <a asp-action="Import" asp-route-assistanceId="@Model.Id" class="bg-blue-700 text-white px-3 py-1 rounded text-sm hover:bg-blue-600">📥 استيراد</a>
            }
        </div>
    </div>

    @if (!isViewer)
    {
        <div class="bg-camp-dark-grey p-4 rounded-lg border border-gray-700 mb-4">
            <h3 class="text-camp-gold font-bold mb-3">إضافة مستفيد</h3>
            <div class="flex flex-col sm:flex-row gap-2 mb-3">
                <input type="text" id="personSearch" placeholder="ابحث برقم الهوية أو الاسم..."
                       class="w-full sm:flex-1 bg-gray-800 text-white border border-gray-600 rounded-lg p-2.5 focus:border-camp-gold focus:ring-1 focus:ring-camp-gold outline-none" />
                <button onclick="searchPerson()" class="w-full sm:w-auto bg-camp-gold text-black px-4 py-2 rounded-lg hover:bg-yellow-500 transition font-bold text-sm">بحث</button>
            </div>

            <div id="searchResults" class="hidden">
                <div class="bg-gray-800 p-4 rounded-lg border border-gray-700">
                    <div id="resultList" class="space-y-1 max-h-60 overflow-y-auto mb-3"></div>
                    <div id="selectedPersonInfo" class="hidden grid grid-cols-2 gap-2 text-sm mb-3 p-3 bg-gray-700/50 rounded">
                        <div><span class="text-gray-400">الاسم:</span> <span id="resultName" class="text-white"></span></div>
                        <div><span class="text-gray-400">رقم الهوية:</span> <span id="resultIdNumber" class="text-white"></span></div>
                        <div><span class="text-gray-400">الهاتف:</span> <span id="resultPhone" class="text-white"></span></div>
                    </div>
                    <form method="post" asp-action="AddBeneficiaryFromPerson" class="flex gap-3 items-end">
                        <input type="hidden" name="assistanceId" value="@Model.Id" />
                        <input type="hidden" name="personId" id="addPersonId" value="" />
                        <button type="submit" id="addBtn" disabled class="bg-camp-gold text-black px-4 py-2 rounded-lg hover:bg-yellow-500 transition font-bold text-sm disabled:opacity-50">
                            ➕ إضافة مستفيد
                        </button>
                    </form>
                </div>
            </div>
            <div id="notFound" class="hidden bg-red-900/30 text-red-300 p-3 rounded-lg text-sm">لم يتم العثور على الشخص. يجب أن يكون مسجلاً في النظام أولاً.</div>
        </div>
    }

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-700 text-camp-gold">
                    <th class="p-2 text-right">الاسم</th>
                    <th class="p-2 text-center">رقم الهوية</th>
                    <th class="p-2 text-center">الجوال</th>
                    <th class="p-2 text-center">نوع الاستفادة</th>
                    <th class="p-2 text-center">تاريخ الإضافة</th>
                    @if (!isViewer) { <th class="p-2 text-center">إجراءات</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model.Beneficiaries.OrderByDescending(b => b.CreatedAt))
                {
                    <tr class="border-b border-gray-700 hover:bg-camp-dark-grey/50 transition">
                        <td class="p-2 text-white font-bold">@b.FullName</td>
                        <td class="p-2 text-center text-gray-300 font-mono" dir="ltr">@b.NationalId</td>
                        <td class="p-2 text-center text-gray-300" dir="ltr">@b.Phone</td>
                        <td class="p-2 text-center text-gray-300">@b.BenefitType</td>
                        <td class="p-2 text-center text-gray-400 text-xs">@b.CreatedAt.ToString("yyyy/MM/dd")</td>
                        @if (!isViewer)
                        {
                            <td class="p-2 text-center">
                                <form method="post" asp-action="DeleteBeneficiary" class="inline" onsubmit="return confirm('حذف المستفيد؟')">
                                    <input type="hidden" name="id" value="@b.Id">
                                    <input type="hidden" name="assistanceId" value="@Model.Id">
                                    <button type="submit" class="text-red-400 hover:text-red-300 transition text-xs">حذف</button>
                                </form>
                            </td>
                        }
                    </tr>
                }
                @if (!Model.Beneficiaries.Any())
                {
                    <tr><td colspan="@(isViewer ? 6 : 7)" class="p-4 text-center text-gray-500">لا يوجد مستفيدون بعد</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        let selectedPersonId = null;

        async function searchPerson() {
            const query = document.getElementById('personSearch').value.trim();
            if (!query) return;

            const resultsDiv = document.getElementById('searchResults');
            const notFoundDiv = document.getElementById('notFound');
            const addBtn = document.getElementById('addBtn');
            const resultList = document.getElementById('resultList');
            const selectedInfo = document.getElementById('selectedPersonInfo');

            resultsDiv.classList.add('hidden');
            notFoundDiv.classList.add('hidden');
            addBtn.disabled = true;
            selectedInfo.classList.add('hidden');
            selectedPersonId = null;

            try {
                const res = await fetch(`/Assistance/SearchPerson?query=${encodeURIComponent(query)}`);
                const data = await res.json();

                if (data.length === 0) {
                    notFoundDiv.classList.remove('hidden');
                    return;
                }

                resultList.innerHTML = data.slice(0, 10).map(p => `
                    <div class="result-item cursor-pointer p-2 rounded hover:bg-gray-700 transition border border-transparent hover:border-camp-gold"
                         onclick="selectPerson(${p.id}, '${p.name.replace(/'/g, "\\'")}', '${p.idNumber}', '${(p.phone || '')}', this)">
                        <div class="flex justify-between items-center">
                            <div>
                                <span class="text-white font-bold">${p.name}</span>
                                <span class="text-gray-400 mr-2" dir="ltr">${p.idNumber}</span>
                            </div>
                            <span class="text-camp-gold text-xs">اختيار</span>
                        </div>
                        ${p.phone ? `<div class="text-gray-500 text-xs" dir="ltr">${p.phone}</div>` : ''}
                    </div>
                `).join('');

                resultsDiv.classList.remove('hidden');
            } catch {
                notFoundDiv.textContent = 'حدث خطأ في البحث';
                notFoundDiv.classList.remove('hidden');
            }
        }

        function selectPerson(id, name, idNumber, phone, el) {
            document.querySelectorAll('.result-item').forEach(item => {
                item.classList.remove('border-camp-gold', 'bg-gray-700');
                item.classList.add('border-transparent');
            });
            el.classList.add('border-camp-gold', 'bg-gray-700');
            el.classList.remove('border-transparent');

            selectedPersonId = id;
            document.getElementById('resultName').textContent = name;
            document.getElementById('resultIdNumber').textContent = idNumber;
            document.getElementById('resultPhone').textContent = phone || '—';
            document.getElementById('addPersonId').value = id;
            document.getElementById('selectedPersonInfo').classList.remove('hidden');
            document.getElementById('addBtn').disabled = false;
        }

        document.getElementById('personSearch')?.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                searchPerson();
            }
        });
    </script>
}
