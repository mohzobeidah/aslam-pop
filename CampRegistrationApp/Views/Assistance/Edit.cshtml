@model EditAssistanceViewModel
@{
    ViewData["Title"] = "تعديل مساعدة";
    var sectors = ViewBag.Sectors as List<Sector> ?? new();
}
<div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Index" class="text-gray-400 hover:text-camp-gold transition">← العودة</a>
        <h1 class="text-2xl text-camp-gold font-bold">تعديل المساعدة</h1>
    </div>

    <form method="post" class="bg-camp-accent-grey p-6 rounded-xl border border-gray-700 space-y-4">
        <input type="hidden" asp-for="Id">
        <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4"></div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm text-gray-400 mb-1">اسم المساعدة</label>
                <input asp-for="Name" class="w-full bg-camp-dark-grey border border-gray-600 rounded p-2 text-sm outline-none focus:border-camp-gold text-white" required>
                <span asp-validation-for="Name" class="text-red-400 text-xs"></span>
            </div>
            <div>
                <label class="block text-sm text-gray-400 mb-1">نوع المساعدة</label>
                <select asp-for="AssistanceType" class="w-full bg-camp-dark-grey border border-gray-600 rounded p-2 text-sm outline-none focus:border-camp-gold text-white">
                    <option value="">اختر النوع</option>
                    <option value="غذائية">غذائية</option>
                    <option value="طبية">طبية</option>
                    <option value="نقدية">نقدية</option>
                    <option value="ملابس">ملابس</option>
                    <option value="مواد إيواء">مواد إيواء</option>
                    <option value="تعليمية">تعليمية</option>
                    <option value="أخرى">أخرى</option>
                </select>
            </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm text-gray-400 mb-1">مصدر المساعدة</label>
                <input asp-for="Source" class="w-full bg-camp-dark-grey border border-gray-600 rounded p-2 text-sm outline-none focus:border-camp-gold text-white">
            </div>
            <div>
                <label class="block text-sm text-gray-400 mb-1">تاريخ المساعدة</label>
                <input asp-for="AssistanceDate" type="date" class="w-full bg-camp-dark-grey border border-gray-600 rounded p-2 text-sm outline-none focus:border-camp-gold text-white">
            </div>
        </div>
        <div>
            <label class="block text-sm text-gray-400 mb-1">القاطع</label>
            <select asp-for="SectorId" class="w-full bg-camp-dark-grey border border-gray-600 rounded p-2 text-sm outline-none focus:border-camp-gold text-white">
                <option value="">اختر القاطع</option>
                @foreach (var s in sectors) { <option value="@s.Id">@s.Name</option> }
            </select>
            <span asp-validation-for="SectorId" class="text-red-400 text-xs"></span>
        </div>
        <div>
            <label class="block text-sm text-gray-400 mb-1">وصف المساعدة</label>
            <textarea asp-for="Description" rows="3" class="w-full bg-camp-dark-grey border border-gray-600 rounded p-2 text-sm outline-none focus:border-camp-gold text-white"></textarea>
        </div>
        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-camp-gold text-black px-6 py-2 rounded-lg font-bold hover:bg-yellow-500 transition">حفظ التعديلات</button>
            <a asp-action="Index" class="bg-gray-700 text-white px-6 py-2 rounded-lg hover:bg-gray-600 transition">إلغاء</a>
        </div>
    </form>
</div>
@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}
