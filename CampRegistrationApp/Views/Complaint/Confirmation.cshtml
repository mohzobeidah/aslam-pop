@{
    ViewData["Title"] = "تم استلام الشكوى";
    var ticketId = ViewBag.TicketId as string;
}

<div class="max-w-lg mx-auto text-center">
    <div class="bg-camp-accent-grey p-8 rounded-xl border border-gray-700">
        <div class="text-6xl mb-4">✅</div>
        <h1 class="text-2xl text-camp-gold font-bold mb-2">تم استلام الشكوى بنجاح</h1>
        <p class="text-gray-400 mb-6">رقم التتبع الخاص بشكواك</p>
        <div class="bg-camp-dark-grey rounded-lg p-4 mb-6">
            <span class="text-3xl text-camp-gold font-bold font-mono tracking-widest">@ticketId</span>
        </div>
        <p class="text-gray-500 text-sm mb-6">يرجى حفظ رقم التتبع لمتابعة حالة شكواك</p>
        <a asp-controller="Home" asp-action="Index" class="text-camp-gold hover:text-yellow-500 transition text-sm">← العودة للرئيسية</a>
    </div>
</div>
