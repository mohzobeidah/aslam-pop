@model ComplaintDetailsViewModel
@{
    ViewData["Title"] = "تفاصيل الشكوى";
}

<div class="mb-6">
    <a asp-action="Index" class="text-gray-400 hover:text-camp-gold text-sm transition">← الشكاوى</a>
    <h1 class="text-2xl text-camp-gold font-bold mt-1">@Model.Subject</h1>
    <p class="text-gray-400 text-sm">رقم التتبع: <span class="font-mono text-camp-gold" dir="ltr">@Model.TicketId</span></p>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="bg-green-900/50 text-green-300 p-3 rounded-lg mb-4 text-sm">@successMsg</div>
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Complaint Details -->
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4">تفاصيل الشكوى</h2>
        <div class="space-y-3 text-sm">
            <div>
                <span class="text-gray-400">الحالة:</span>
                <span class="@(Model.Status == "Resolved" ? "text-green-400" : Model.Status == "InProgress" ? "text-blue-400" : "text-yellow-400") font-bold">
                    @(Model.Status switch { "Pending" => "قيد الانتظار", "InProgress" => "قيد المعالجة", "Resolved" => "تم الحل", _ => Model.Status })
                </span>
            </div>
            <div><span class="text-gray-400">تاريخ التقديم:</span> <span class="text-white">@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span></div>
            @if (!string.IsNullOrEmpty(Model.SenderName))
            {
                <div><span class="text-gray-400">مقدم الشكوى:</span> <span class="text-white">@Model.SenderName</span></div>
            }
            @if (!string.IsNullOrEmpty(Model.SenderPhone))
            {
                <div><span class="text-gray-400">الهاتف:</span> <span class="text-white" dir="ltr">@Model.SenderPhone</span></div>
            }
            @if (!string.IsNullOrEmpty(Model.ResolvedByName))
            {
                <div><span class="text-gray-400">تم الحل بواسطة:</span> <span class="text-white">@Model.ResolvedByName</span></div>
                <div><span class="text-gray-400">تاريخ الحل:</span> <span class="text-white">@Model.ResolvedAt?.ToString("yyyy/MM/dd HH:mm")</span></div>
            }
        </div>
        <div class="mt-4 pt-4 border-t border-gray-700">
            <label class="block text-sm text-gray-400 mb-2">الرسالة</label>
            <div class="bg-camp-dark-grey p-3 rounded text-sm text-white whitespace-pre-wrap">@Model.Message</div>
        </div>
    </div>

    <!-- Admin Response -->
    <div class="bg-camp-accent-grey p-5 rounded-xl border border-gray-700">
        <h2 class="text-lg text-camp-gold font-bold mb-4">الرد على الشكوى</h2>

        @if (!string.IsNullOrEmpty(Model.AdminResponse))
        {
            <div class="mb-4">
                <label class="block text-sm text-gray-400 mb-2">الرد السابق</label>
                <div class="bg-camp-dark-grey p-3 rounded text-sm text-white whitespace-pre-wrap">@Model.AdminResponse</div>
            </div>
        }

        <form method="post" asp-action="Respond" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div>
                <label class="block text-sm mb-1">الرد</label>
                <textarea name="adminResponse" rows="5" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none">@Model.AdminResponse</textarea>
            </div>
            <div>
                <label class="block text-sm mb-1">تحديث الحالة</label>
                <select name="newStatus" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none">
                    <option value="">— لا تغيير —</option>
                    <option value="InProgress" selected="@(Model.Status == "InProgress")">قيد المعالجة</option>
                    <option value="Resolved" selected="@(Model.Status == "Resolved")">تم الحل</option>
                </select>
            </div>
            <div class="flex gap-3">
                <button type="submit" class="bg-camp-gold text-black px-6 py-2 rounded-lg hover:bg-yellow-500 transition font-bold text-sm">
                    حفظ الرد
                </button>
                <form method="post" asp-action="Delete" asp-route-id="@Model.Id" class="inline"
                      onsubmit="return confirm('حذف الشكوى؟')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="bg-red-700 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition text-sm">
                        حذف
                    </button>
                </form>
            </div>
        </form>
    </div>
</div>
