@model PublicSubmitViewModel
@{
    ViewData["Title"] = "تقديم شكوى";
}

<div class="max-w-2xl mx-auto">
    <div class="text-center mb-8">
        <h1 class="text-3xl text-camp-gold font-bold">تقديم شكوى</h1>
        <p class="text-gray-400 mt-2">يمكنك تقديم شكوى أو ملاحظة وسيتم الرد عليها في أقرب وقت</p>
    </div>

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="bg-red-900/50 text-red-300 p-3 rounded-lg mb-4 text-sm">@errorMsg</div>
    }

    <div class="bg-blue-900/30 border border-blue-500/50 text-blue-300 p-4 rounded-lg mb-6 text-sm">
        <p class="font-bold mb-1">⚠️ ملاحظة هامة</p>
        <p>لتتمكن من متابعة حالة شكواك والتعرّف على الرد، يجب عليك <a href="@Url.Action("Login", "Record")" class="text-camp-gold hover:text-yellow-500 underline">تسجيل الدخول</a> أولاً كمسجل (رب أسرة) ثم تقديم الشكوى من داخل حسابك. الشكاوى المقدمة بدون تسجيل دخول لا يمكن تتبعها.</p>
    </div>

    <form method="post" class="bg-camp-accent-grey p-6 rounded-xl border border-gray-700 space-y-4">
        <div>
            <label class="block text-sm mb-1">الموضوع <span class="text-red-500">*</span></label>
            <input name="Subject" value="@Model.Subject" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required maxlength="200" />
            <span asp-validation-for="Subject" class="text-red-500 text-xs"></span>
        </div>
        <div>
            <label class="block text-sm mb-1">الرسالة <span class="text-red-500">*</span></label>
            <textarea name="Message" rows="6" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" required>@Model.Message</textarea>
            <span asp-validation-for="Message" class="text-red-500 text-xs"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm mb-1">الاسم (اختياري)</label>
                <input name="SenderName" value="@Model.SenderName" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" maxlength="100" />
            </div>
            <div>
                <label class="block text-sm mb-1">رقم الهاتف (اختياري)</label>
                <input name="SenderPhone" value="@Model.SenderPhone" class="w-full p-2 rounded bg-camp-dark-grey border border-gray-600 focus:border-camp-gold outline-none" maxlength="20" />
            </div>
        </div>
        <button type="submit" class="w-full bg-camp-gold text-black font-bold py-3 rounded-lg hover:bg-yellow-500 transition text-lg">
            إرسال الشكوى
        </button>
    </form>

    <div class="text-center mt-6">
        <a asp-controller="Home" asp-action="Index" class="text-gray-400 hover:text-camp-gold text-sm transition">← العودة للرئيسية</a>
    </div>
</div>
