<!DOCTYPE html>
<html lang="ar" dir="rtl" data-theme="dark">
<script>document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'dark');</script>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام تسجيل العائلات</title>

    <!-- Google Fonts: Cairo -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'camp-gold': '#D4AF37',
                        'camp-dark-grey': '#1A1A1A',
                        'camp-accent-grey': '#2D2D2D',
                    },
                    fontFamily: {
                        cairo: ['Cairo', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        body {
            font-family: 'Cairo', sans-serif;
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-camp-dark-grey">
    <header>
        <nav class="bg-camp-accent-grey border-b border-camp-gold p-4 shadow-lg">
            <div class="container mx-auto flex justify-between items-center">
                <a class="text-xl sm:text-2xl font-bold text-camp-gold" asp-area="" asp-controller="Home" asp-action="Index">
                    نظام تسجيل العائلات
                </a>

                @{
                    var isLoggedIn = Context.Session.GetInt32("AdminId").HasValue;
                }

                <!-- Hamburger button (mobile) -->
                <button id="menuBtn" class="sm:hidden text-gray-300 hover:text-camp-gold p-2" onclick="toggleMenu()">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path id="menuIcon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>

                <!-- Desktop nav -->
                <div class="hidden sm:flex gap-2 items-center">
                    <button id="themeToggle" onclick="toggleTheme()" class="text-gray-300 hover:text-camp-gold transition-colors px-2 py-2 rounded text-sm" title="تغيير السمة">
                        <span id="themeIcon">☀️</span>
                    </button>
                    <a class="text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Registration" asp-action="Index">تسجيل جديد</a>
                    <a class="text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Record" asp-action="Login">تسجيل الدخول</a>
                    <a class="text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Complaint" asp-action="Create">تقديم شكوى</a>
                    @if (isLoggedIn)
                    {
                        <a class="text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Complaint" asp-action="Index">الشكاوى</a>
                        <a class="text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Project" asp-action="Index">المشاريع</a>
                        <a class="text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Assistance" asp-action="Index">المساعدات</a>
                        <a class="text-camp-gold hover:text-yellow-500 transition-colors px-3 py-2 rounded text-sm font-bold" asp-controller="Admin" asp-action="Dashboard">لوحة التحكم</a>
                        <a class="text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Report" asp-action="Index">التقارير</a>
                        <a class="text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Admin" asp-action="AuditLogs">سجل التدقيق</a>
                        <a class="text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Admin" asp-action="DeletedRegistrations">المحذوفة</a>
                        <a class="text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Admin" asp-action="ChangePassword">تغيير كلمة المرور</a>
                        <a class="relative text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded" asp-controller="Admin" asp-action="Notifications" id="notificationBell">
                            🔔
                            <span id="notificationBadge" class="absolute -top-1 -right-1 bg-red-600 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center hidden" style="font-size:9px">0</span>
                        </a>
                        <a asp-controller="Admin" asp-action="Logout" method="post"
                           class="text-red-400 hover:text-red-300 transition-colors px-3 py-2 rounded text-sm"
                           onclick="event.preventDefault(); document.getElementById('logoutForm').submit();">
                            تسجيل خروج
                        </a>
                        <form id="logoutForm" asp-controller="Admin" asp-action="Logout" method="post" class="hidden"></form>
                    }
                    else
                    {
                        <a class="text-camp-gold hover:text-yellow-500 transition-colors px-3 py-2 rounded text-sm font-bold" asp-controller="Admin" asp-action="Login">دخول المشرفين</a>
                    }
                </div>
            </div>

            <!-- Mobile dropdown menu -->
            <div id="mobileMenu" class="hidden sm:hidden mt-4 space-y-1 border-t border-gray-700 pt-3">
                <a id="mobileThemeToggle" href="#" onclick="toggleTheme(); return false;" class="block text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm">
                    <span id="mobileThemeIcon">☀️</span> تغيير السمة
                </a>
                <a class="block text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Registration" asp-action="Index">تسجيل جديد</a>
                <a class="block text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Record" asp-action="Login">تسجيل الدخول</a>
                <a class="block text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Complaint" asp-action="Create">تقديم شكوى</a>
                @if (isLoggedIn)
                {
                    <a class="block text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Complaint" asp-action="Index">الشكاوى</a>
                    <a class="block text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Project" asp-action="Index">المشاريع</a>
                    <a class="block text-white hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Assistance" asp-action="Index">المساعدات</a>
                    <a class="block text-camp-gold hover:text-yellow-500 transition-colors px-3 py-2 rounded text-sm font-bold" asp-controller="Admin" asp-action="Dashboard">لوحة التحكم</a>
                    <a class="block text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Report" asp-action="Index">التقارير</a>
                    <a class="block text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Admin" asp-action="AuditLogs">سجل التدقيق</a>
                    <a class="block text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Admin" asp-action="DeletedRegistrations">المحذوفة</a>
                    <a class="block text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Admin" asp-action="ChangePassword">تغيير كلمة المرور</a>
                    <a class="block text-gray-300 hover:text-camp-gold transition-colors px-3 py-2 rounded text-sm" asp-controller="Admin" asp-action="Notifications">🔔 الإشعارات</a>
                    <a asp-controller="Admin" asp-action="Logout" method="post"
                       class="block text-red-400 hover:text-red-300 transition-colors px-3 py-2 rounded text-sm"
                       onclick="event.preventDefault(); document.getElementById('logoutFormMobile').submit();">
                        تسجيل خروج
                    </a>
                    <form id="logoutFormMobile" asp-controller="Admin" asp-action="Logout" method="post" class="hidden"></form>
                }
                else
                {
                    <a class="block text-camp-gold hover:text-yellow-500 transition-colors px-3 py-2 rounded text-sm font-bold" asp-controller="Admin" asp-action="Login">دخول المشرفين</a>
                }
            </div>
        </nav>
    </header>
    <div class="container mx-auto">
        <main role="main" class="py-8">
            @RenderBody()
        </main>
    </div>
    <footer class="border-t border-gray-800 text-center py-6 text-gray-500 text-sm">
        <div class="container mx-auto">
            &copy; 2026 - نظام تسجيل العائلات - جميع الحقوق محفوظة
        </div>
    </footer>
    <script>
        async function updateNotificationBadge() {
            try {
                const res = await fetch('/Admin/GetNotificationCount');
                const count = await res.json();
                const badge = document.getElementById('notificationBadge');
                if (badge) {
                    if (count > 0) {
                        badge.textContent = count > 99 ? '99+' : count;
                        badge.classList.remove('hidden');
                    } else {
                        badge.classList.add('hidden');
                    }
                }
            } catch {}
        }
        function toggleMenu() {
            var menu = document.getElementById('mobileMenu');
            menu.classList.toggle('hidden');
        }
        document.addEventListener('DOMContentLoaded', function() {
            updateNotificationBadge();
            setInterval(updateNotificationBadge, 30000);
        });
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <style>
        /* ===== THEME VARIABLES ===== */
        [data-theme] {
            --bg-primary: #1A1A1A;
            --bg-secondary: #2D2D2D;
            --text-primary: #FFFFFF;
            --text-secondary: #D1D5DB;
            --text-muted: #9CA3AF;
            --border-color: #374151;
            --border-light: #4B5563;
        }
        [data-theme="light"] {
            --bg-primary: #F3F4F6;
            --bg-secondary: #FFFFFF;
            --text-primary: #111827;
            --text-secondary: #374151;
            --text-muted: #6B7280;
            --border-color: #D1D5DB;
            --border-light: #E5E7EB;
        }
        /* Background overrides */
        [data-theme] .bg-camp-dark-grey { background-color: var(--bg-primary); }
        [data-theme] .bg-camp-accent-grey { background-color: var(--bg-secondary); }
        [data-theme] .bg-gray-800 { background-color: var(--bg-primary); }
        /* Text overrides */
        [data-theme] .text-white { color: var(--text-primary); }
        [data-theme] .text-gray-300 { color: var(--text-secondary); }
        [data-theme] .text-gray-400 { color: var(--text-muted); }
        [data-theme] .text-gray-500 { color: var(--text-muted); }
        [data-theme="dark"] .text-gray-600 { color: var(--text-muted); }
        /* Black/dark text — readable on dark backgrounds */
        [data-theme="dark"] .text-black,
        [data-theme="dark"] .text-camp-dark-grey { color: #E5E7EB; }
        /* But keep dark text on gold buttons (contrast on gold is fine) */
        [data-theme="dark"] .bg-camp-gold.text-black,
        [data-theme="dark"] .bg-camp-gold.text-camp-dark-grey { color: #1A1A1A; }
        /* Border overrides */
        [data-theme] .border-gray-600 { border-color: var(--border-light); }
        [data-theme] .border-gray-700 { border-color: var(--border-color); }
        [data-theme] .border-gray-800 { border-color: var(--border-color); }
        /* Hover states */
        [data-theme] .hover\:bg-gray-700:hover { background-color: var(--border-color); }
        [data-theme] .hover\:bg-gray-800\/50:hover,
        [data-theme] .hover\:bg-camp-dark-grey\/50:hover { background-color: color-mix(in srgb, var(--bg-primary) 50%, transparent); }
        [data-theme] .hover\:text-white:hover { color: var(--text-primary); }
        /* Semi-transparent backgrounds */
        [data-theme] .bg-gray-800\/50,
        [data-theme] .bg-camp-dark-grey\/50 { background-color: color-mix(in srgb, var(--bg-primary) 50%, transparent); }
        /* Darken gold text in light mode for readability */
        [data-theme="light"] .text-camp-gold { color: #9A7B0C; }
        /* Keep colored button text white in light mode */
        [data-theme="light"] .bg-green-600.text-white,
        [data-theme="light"] .bg-green-700.text-white,
        [data-theme="light"] .bg-red-700.text-white,
        [data-theme="light"] .bg-red-500.text-white,
        [data-theme="light"] .bg-black\/50.text-white,
        [data-theme="light"] .hover\:text-white:hover { color: #fff; }
        /* Safe area for mobile */
        [data-theme] .bg-black\/50 { background-color: rgba(0,0,0,0.5); }
        /* Select / input / textarea background for light mode */
        [data-theme="light"] select.bg-camp-dark-grey,
        [data-theme="light"] input.bg-camp-dark-grey,
        [data-theme="light"] textarea.bg-camp-dark-grey { background-color: #fff; }
        /* Input background for gray-700 used in admin forms */
        [data-theme="light"] .bg-gray-700 { background-color: #F3F4F6; }
        /* Input border text color on focus */
        [data-theme="light"] .focus\:border-camp-gold:focus { border-color: #D4AF37; }

        /* Smooth transition when toggling theme */
        html { transition: background-color 0.3s, color 0.3s; }
    </style>

    <script>
        function toggleTheme() {
            var current = document.documentElement.getAttribute('data-theme');
            var next = current === 'light' ? 'dark' : 'light';
            setTheme(next);
        }
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);
            var icon = document.getElementById('themeIcon');
            var mobileIcon = document.getElementById('mobileThemeIcon');
            if (icon) icon.textContent = theme === 'dark' ? '☀️' : '🌙';
            if (mobileIcon) mobileIcon.textContent = theme === 'dark' ? '☀️' : '🌙';
        }
        (function initTheme() {
            var saved = localStorage.getItem('theme') || 'dark';
            setTheme(saved);
        })();
    </script>
</body>
</html>
