@model NominationPageViewModel
@{
    ViewData["Title"] = $"ترشيحات - {Model.ProjectName}";
    var sectors = ViewBag.Sectors as List<Sector> ?? new();
}

<div class="mb-6">
    <div class="flex flex-col sm:flex-row justify-between items-start gap-2">
        <div class="w-full sm:w-auto">
            <a asp-controller="Project" asp-action="Index" class="text-gray-400 hover:text-camp-gold text-sm transition">← المشاريع</a>
            <div class="flex items-center gap-2 mt-1">
                <h1 class="text-xl sm:text-2xl text-camp-gold font-bold break-words">@Model.ProjectName</h1>
                <button onclick="document.getElementById('projectDetailModal').classList.remove('hidden')" class="text-gray-400 hover:text-camp-gold transition text-lg" title="تفاصيل المشروع">ⓘ</button>
            </div>
            <p class="text-gray-400 text-sm">
                العدد المطلوب: <span class="text-camp-gold font-bold">@Model.RequiredCount</span>
                | الترشيحات الحالية: <span class="@(Model.ExistingCount >= Model.RequiredCount ? "text-green-400" : "text-camp-gold") font-bold">@Model.ExistingCount</span>
            </p>
        </div>
        <div class="flex gap-2 self-start">
            <span class="px-3 py-1 rounded text-sm @(Model.ProjectStatus == ProjectStatus.Active ? "bg-green-900/50 text-green-300" : Model.ProjectStatus == ProjectStatus.Draft ? "bg-yellow-900/50 text-yellow-300" : "bg-red-900/50 text-red-300")">
                @(Model.ProjectStatus switch { ProjectStatus.Active => "نشط", ProjectStatus.Draft => "مسودة", ProjectStatus.Closed => "مغلق", _ => "" })
            </span>
        </div>
    </div>
</div>

<!-- Project Detail Modal -->
<div id="projectDetailModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-camp-accent-grey rounded-xl border border-gray-700 shadow-2xl max-w-lg w-full mx-4 max-h-[80vh] overflow-y-auto">
        <div class="flex justify-between items-center p-5 border-b border-gray-700">
            <h3 class="text-xl font-bold text-camp-gold">تفاصيل المشروع</h3>
            <button onclick="document.getElementById('projectDetailModal').classList.add('hidden')" class="text-gray-400 hover:text-white text-2xl leading-none">&times;</button>
        </div>
        <div class="p-5 space-y-4 text-sm">
            <div>
                <label class="text-gray-400 block mb-1">الاسم</label>
                <div class="text-white font-bold">@Model.ProjectName</div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-gray-400 block mb-1">تاريخ البداية</label>
                    <div class="text-white">@Model.StartDate.ToString("yyyy/MM/dd")</div>
                </div>
                <div>
                    <label class="text-gray-400 block mb-1">تاريخ النهاية</label>
                    <div class="text-white">@Model.EndDate.ToString("yyyy/MM/dd")</div>
                </div>
                <div>
                    <label class="text-gray-400 block mb-1">العدد المطلوب</label>
                    <div class="text-white">@Model.RequiredCount</div>
                </div>
                <div>
                    <label class="text-gray-400 block mb-1">التريشيحات الحالية</label>
                    <div class="text-white">@Model.ExistingCount</div>
                </div>
                <div>
                    <label class="text-gray-400 block mb-1">الحالة</label>
                    <span class="@(Model.ProjectStatus == ProjectStatus.Active ? "text-green-400" : Model.ProjectStatus == ProjectStatus.Draft ? "text-yellow-400" : "text-red-400") font-bold">
                        @(Model.ProjectStatus switch { ProjectStatus.Active => "نشط", ProjectStatus.Draft => "مسودة", ProjectStatus.Closed => "مغلق", _ => "" })
                    </span>
                </div>
                <div>
                    <label class="text-gray-400 block mb-1">بواسطة</label>
                    <div class="text-white">@Model.CreatedByName</div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div>
                    <label class="text-gray-400 block mb-1">الوصف</label>
                    <div class="text-white bg-gray-800 p-3 rounded">@Model.Description</div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div>
                    <label class="text-gray-400 block mb-1">ملاحظات</label>
                    <div class="text-white bg-gray-800 p-3 rounded">@Model.Notes</div>
                </div>
            }
            <div>
                <label class="text-gray-400 block mb-1">حصة القطاعات</label>
                <div class="grid grid-cols-2 gap-2">
                    @foreach (var sq in Model.SectorQuotas)
                    {
                        <div class="bg-gray-800 p-2 rounded text-center">
                            <div class="text-xs text-gray-400">@sq.SectorName</div>
                            <div class="text-sm font-bold @(sq.CurrentCount >= sq.MaxCount && sq.MaxCount > 0 ? "text-red-400" : "text-green-400")">@sq.CurrentCount / @(sq.MaxCount > 0 ? sq.MaxCount.ToString() : "∞")</div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="p-5 border-t border-gray-700 text-left">
            <button onclick="document.getElementById('projectDetailModal').classList.add('hidden')" class="bg-gray-700 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition text-sm">إغلاق</button>
        </div>
    </div>
</div>

<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    @foreach (var sq in Model.SectorQuotas)
    {
        var show = Model.IsAdmin || sq.SectorId == Model.DelegateSectorId;
        if (!show) continue;
        var pct = sq.MaxCount > 0 ? (sq.CurrentCount * 100 / sq.MaxCount) : 0;
        var color = sq.MaxCount > 0 ? (sq.CurrentCount >= sq.MaxCount ? "text-red-400" : sq.CurrentCount >= sq.MaxCount * 0.8 ? "text-yellow-400" : "text-green-400") : "text-gray-400";
        <div class="bg-camp-accent-grey p-3 rounded-xl border border-gray-700 text-center">
            <div class="text-xs text-gray-400 mb-1">@sq.SectorName</div>
            <div class="text-lg font-bold @color">@sq.CurrentCount / @(sq.MaxCount > 0 ? sq.MaxCount.ToString() : "∞")</div>
        </div>
    }
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="bg-green-900/50 text-green-300 p-3 rounded-lg mb-4 text-sm">@successMsg</div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="bg-red-900/50 text-red-300 p-3 rounded-lg mb-4 text-sm">@errorMsg</div>
}
@if (TempData["ImportErrors"] is string importErrors)
{
    <div class="bg-yellow-900/50 text-yellow-300 p-3 rounded-lg mb-4 text-sm">@importErrors</div>
}
@if (TempData["ImportWarnings"] is string importWarnings)
{
    <div class="bg-blue-900/50 text-blue-300 p-3 rounded-lg mb-4 text-sm">@importWarnings</div>
}

@if (!Model.IsPastEndDate && Model.ExistingCount < Model.RequiredCount)
{
    <div class="bg-camp-accent-grey p-4 rounded-xl border border-gray-700 mb-6">
        <h2 class="text-camp-gold font-bold mb-3">إضافة ترشيح</h2>
        <div class="flex flex-col sm:flex-row gap-2 mb-3">
            <input type="text" id="personSearch" placeholder="ابحث برقم الهوية أو الاسم..." 
                   class="w-full sm:flex-1 bg-gray-800 text-white border border-gray-600 rounded-lg p-2.5 focus:border-camp-gold focus:ring-1 focus:ring-camp-gold outline-none" />
            <button onclick="searchPerson()" class="w-full sm:w-auto bg-camp-gold text-black px-4 py-2 rounded-lg hover:bg-yellow-500 transition font-bold text-sm">بحث</button>
            <button onclick="openBulkModal()" class="w-full sm:w-auto bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-500 transition font-bold text-sm">إضافة متعددة</button>
            <button onclick="openExcelModal()" class="w-full sm:w-auto bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-500 transition font-bold text-sm">رفع Excel</button>
            <a asp-controller="Nomination" asp-action="ExportExcel" asp-route-projectId="@Model.ProjectId" class="w-full sm:w-auto bg-green-700 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition font-bold text-sm text-center">تصدير Excel</a>
        </div>

        <div id="searchResults" class="hidden">
            <div class="bg-gray-800 p-4 rounded-lg border border-gray-700">
                <div id="resultList" class="space-y-1 max-h-60 overflow-y-auto mb-3"></div>
                <div id="selectedPersonInfo" class="hidden grid grid-cols-2 gap-2 text-sm mb-3 p-3 bg-gray-700/50 rounded">
                    <div><span class="text-gray-400">الاسم:</span> <span id="resultName" class="text-white"></span></div>
                    <div><span class="text-gray-400">رقم الهوية:</span> <span id="resultIdNumber" class="text-white"></span></div>
                    <div><span class="text-gray-400">الهاتف:</span> <span id="resultPhone" class="text-white"></span></div>
                </div>
                <form method="post" asp-controller="Nomination" asp-action="AddRow" class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-end">
                    <input type="hidden" name="projectId" value="@Model.ProjectId" />
                    <input type="hidden" name="personId" id="addPersonId" value="" />
                    <div class="flex-1">
                        <label class="block text-camp-gold mb-1 text-xs">ملاحظات</label>
                        <input name="notes" placeholder="اختياري" class="w-full bg-gray-700 text-white border border-gray-600 rounded-lg p-2 text-sm focus:border-camp-gold outline-none" />
                    </div>
                    <button type="submit" id="addBtn" disabled class="w-full sm:w-auto bg-camp-gold text-black px-4 py-2 rounded-lg hover:bg-yellow-500 transition font-bold text-sm disabled:opacity-50">
                        إضافة
                    </button>
                </form>
            </div>
        </div>
        <div id="notFound" class="hidden bg-red-900/30 text-red-300 p-3 rounded-lg text-sm">لم يتم العثور على الشخص. يجب أن يكون مسجلاً في النظام أولاً.</div>
    </div>
}

<!-- Bulk Add Modal -->
<div id="bulkModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-camp-accent-grey rounded-xl border border-gray-700 shadow-2xl max-w-2xl w-full mx-4 max-h-[90vh] flex flex-col">
        <div class="flex justify-between items-center p-5 border-b border-gray-700">
            <h3 class="text-xl font-bold text-camp-gold">إضافة عدة مرشحين</h3>
            <button onclick="closeBulkModal()" class="text-gray-400 hover:text-white text-2xl leading-none">&times;</button>
        </div>
        <div class="p-5 overflow-y-auto flex-1">
            <div class="flex items-center gap-2 mb-3">
                <label class="text-gray-300 text-sm">القطاع:</label>
                <select id="bulkSectorFilter" onchange="filterBulkList()"
                        class="bg-gray-800 text-white border border-gray-600 rounded-lg p-2 text-sm focus:border-camp-gold outline-none">
                    <option value="">جميع القطاعات</option>
                    @foreach (var sec in sectors)
                    {
                        <option value="@sec.Name">@sec.Name</option>
                    }
                </select>
            </div>
            <div class="flex items-center gap-2 mb-4">
                <label class="text-gray-300 text-sm">بحث:</label>
                <input type="text" id="bulkSearch" placeholder="ابحث بالاسم أو رقم الهوية..."
                       class="flex-1 bg-gray-800 text-white border border-gray-600 rounded-lg p-2 text-sm focus:border-camp-gold outline-none"
                       oninput="filterBulkList()" />
            </div>
            <div class="flex items-center gap-3 mb-3 text-sm">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" id="selectAllCheck" onchange="toggleSelectAll()" class="accent-camp-gold" />
                    <span class="text-camp-gold">تحديد الكل</span>
                </label>
                <button onclick="clearSelection()" class="text-gray-400 hover:text-white transition">إلغاء التحديد</button>
                <span id="selectedCount" class="text-gray-400">0 مختار</span>
            </div>
            <div id="bulkList" class="space-y-1 max-h-96 overflow-y-auto"></div>
            <div id="bulkLoading" class="text-center text-gray-400 py-8">جاري التحميل...</div>
        </div>
        <div class="p-5 border-t border-gray-700 flex justify-between items-center">
            <div class="flex-1 ml-3">
                <input id="bulkNotes" placeholder="ملاحظات للمرشحين (اختياري)"
                       class="w-full bg-gray-700 text-white border border-gray-600 rounded-lg p-2 text-sm focus:border-camp-gold outline-none" />
            </div>
            <div class="flex gap-2">
                <button onclick="closeBulkModal()" class="bg-gray-700 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition text-sm">إلغاء</button>
                <button id="confirmBulkBtn" onclick="confirmBulkAdd()" disabled class="bg-camp-gold text-black px-4 py-2 rounded-lg hover:bg-yellow-500 transition font-bold text-sm disabled:opacity-50">
                    إضافة المختارين
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Excel Import Modal -->
<div id="excelModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-camp-accent-grey rounded-xl border border-gray-700 shadow-2xl max-w-lg w-full mx-4">
        <div class="flex justify-between items-center p-5 border-b border-gray-700">
            <h3 class="text-xl font-bold text-camp-gold">رفع ملف Excel</h3>
            <button onclick="closeExcelModal()" class="text-gray-400 hover:text-white text-2xl leading-none">&times;</button>
        </div>
        <div class="p-5 space-y-4">
            <p class="text-gray-300 text-sm">
                يجب أن يحتوي الملف على عمودين: <strong class="text-camp-gold">NationalId</strong> (رقم الهوية) و <strong class="text-camp-gold">Notes</strong> (ملاحظات).
                يتم استيراد أرباب الأسر وأفراد العوائل المسجلين في النظام.
            </p>
            <a asp-controller="Nomination" asp-action="DownloadImportTemplate"
               class="inline-block text-camp-gold hover:text-yellow-400 transition text-sm underline">
                تحميل قالب Excel
            </a>
            <form method="post" asp-controller="Nomination" asp-action="ImportExcel" enctype="multipart/form-data"
                  class="space-y-3" id="excelForm">
                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                <div>
                    <label class="block text-camp-gold mb-1 text-sm">اختر ملف Excel</label>
                    <input type="file" name="excelFile" accept=".xlsx"
                           class="w-full bg-gray-800 text-white border border-gray-600 rounded-lg p-2 text-sm file:bg-camp-gold file:text-black file:border-0 file:rounded file:px-3 file:py-1 file:font-bold file:cursor-pointer" />
                </div>
                <button type="submit" class="w-full bg-camp-gold text-black px-4 py-2 rounded-lg hover:bg-yellow-500 transition font-bold text-sm">
                    رفع واستيراد
                </button>
            </form>
        </div>
        <div class="p-5 border-t border-gray-700 text-left">
            <button onclick="closeExcelModal()" class="bg-gray-700 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition text-sm">إغلاق</button>
        </div>
    </div>
</div>

<div class="flex justify-between items-center mb-3">
    <div></div>
    @if (Model.IsAdmin && Model.Rows.Any())
    {
        <form method="post" asp-controller="Nomination" asp-action="DeleteAllNominations"
              onsubmit="return confirm('هل أنت متأكد من حذف جميع الترشيحات (@Model.ExistingCount) لهذا المشروع؟ لا يمكن التراجع عن هذا الإجراء.')">
            <input type="hidden" name="projectId" value="@Model.ProjectId" />
            <button type="submit" class="bg-red-800 hover:bg-red-700 text-white px-4 py-2 rounded-lg transition font-bold text-sm">
                حذف الكل
            </button>
        </form>
    }
</div>

<div class="overflow-x-auto">
    <table class="w-full bg-camp-accent-grey rounded-xl border border-gray-700">
        <thead>
            <tr class="border-b border-gray-700 text-camp-gold text-sm">
                <th class="p-3 text-center">#</th>
                <th class="p-3 text-right">الاسم</th>
                <th class="p-3 text-center">رقم الهوية</th>
                <th class="p-3 text-center">الهاتف</th>
                <th class="p-3 text-center">القاطع</th>
                <th class="p-3 text-center">ملاحظات</th>
                <th class="p-3 text-center">إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr class="border-b border-gray-700 hover:bg-gray-800/50 text-sm">
                    <td class="p-3 text-center text-gray-400">@row.RowNumber</td>
                    <td class="p-3 font-bold text-white">@row.PersonName</td>
                    <td class="p-3 text-center text-gray-300">@row.IdNumber</td>
                    <td class="p-3 text-center text-gray-300" dir="ltr">@row.Phone</td>
                    <td class="p-3 text-center text-gray-300">@row.Sector</td>
                    <td class="p-3 text-center text-gray-400 text-xs">@row.Notes</td>
                    <td class="p-3 text-center">
                        <form method="post" asp-controller="Nomination" asp-action="DeleteRow" asp-route-id="@row.Id" asp-route-projectId="@Model.ProjectId" class="inline"
                              onsubmit="return confirm('حذف ترشيح @row.PersonName؟')">
                            <button type="submit" class="text-red-400 hover:text-red-300 transition text-sm">حذف</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Rows.Any())
            {
                <tr>
                    <td colspan="7" class="p-6 text-center text-gray-500">لا توجد ترشيحات بعد</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        let selectedPersonId = null;
        let allHeads = [];
        let selectedHeadIds = new Set();

        async function searchPerson() {
            const query = document.getElementById('personSearch').value.trim();
            if (!query) return;

            const resultsDiv = document.getElementById('searchResults');
            const notFoundDiv = document.getElementById('notFound');
            const addBtn = document.getElementById('addBtn');
            const resultList = document.getElementById('resultList');
            const selectedInfo = document.getElementById('selectedPersonInfo');

            resultsDiv.classList.add('hidden');
            notFoundDiv.classList.add('hidden');
            addBtn.disabled = true;
            selectedInfo.classList.add('hidden');
            selectedPersonId = null;

            try {
                const res = await fetch(`/Nomination/SearchPerson?query=${encodeURIComponent(query)}`);
                const data = await res.json();

                if (data.length === 0) {
                    notFoundDiv.classList.remove('hidden');
                    return;
                }

                const items = data.slice(0, 100);

                const checkPromises = items.map(p =>
                    fetch(`/Nomination/CheckPersonInProject?projectId=@Model.ProjectId&personId=${p.id}`)
                        .then(r => r.json())
                        .then(d => ({ id: p.id, exists: d.exists }))
                );
                const checks = await Promise.all(checkPromises);
                const nominatedMap = Object.fromEntries(checks.map(c => [c.id, c.exists]));

                resultList.innerHTML = items.map(p => `
                    <div class="result-item cursor-pointer p-2 rounded hover:bg-gray-700 transition border border-transparent hover:border-camp-gold ${nominatedMap[p.id] ? 'opacity-50' : ''}"
                         onclick="${nominatedMap[p.id] ? '' : `selectPerson(${p.id}, '${p.name.replace(/'/g, "\\'")}', '${p.idNumber}', '${(p.phone || '')}', this)`}"
                         data-person-id="${p.id}">
                        <div class="flex justify-between items-center">
                            <div>
                                <span class="text-white font-bold">${p.name}</span>
                                <span class="text-gray-400 mr-2" dir="ltr">${p.idNumber}</span>
                            </div>
                            ${nominatedMap[p.id]
                                ? '<span class="text-yellow-400 text-xs">مرشح مسبقاً</span>'
                                : '<span class="text-camp-gold text-xs">اختيار</span>'}
                        </div>
                        ${p.phone ? `<div class="text-gray-500 text-xs" dir="ltr">${p.phone}</div>` : ''}
                    </div>
                `).join('');

                resultsDiv.classList.remove('hidden');
            } catch {
                notFoundDiv.textContent = 'حدث خطأ في البحث';
                notFoundDiv.classList.remove('hidden');
            }
        }

        function selectPerson(id, name, idNumber, phone, el) {
            document.querySelectorAll('.result-item').forEach(item => {
                item.classList.remove('border-camp-gold', 'bg-gray-700');
                item.classList.add('border-transparent');
            });
            el.classList.add('border-camp-gold', 'bg-gray-700');
            el.classList.remove('border-transparent');

            selectedPersonId = id;
            document.getElementById('resultName').textContent = name;
            document.getElementById('resultIdNumber').textContent = idNumber;
            document.getElementById('resultPhone').textContent = phone || '—';
            document.getElementById('addPersonId').value = id;
            document.getElementById('selectedPersonInfo').classList.remove('hidden');
            document.getElementById('addBtn').disabled = false;
        }

        document.getElementById('personSearch').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                searchPerson();
            }
        });

        /* ─── Bulk Add Modal ─── */

        async function openBulkModal() {
            document.getElementById('bulkModal').classList.remove('hidden');
            document.getElementById('bulkList').innerHTML = '';
            document.getElementById('bulkLoading').classList.remove('hidden');
            document.getElementById('selectAllCheck').checked = false;
            document.getElementById('bulkSearch').value = '';
            document.getElementById('bulkSectorFilter').value = '';
            selectedHeadIds = new Set();
            updateSelectedCount();

            try {
                const res = await fetch(`/Nomination/GetFamilyHeads?projectId=@Model.ProjectId`);
                allHeads = await res.json();
                renderBulkList(allHeads);
            } catch {
                document.getElementById('bulkList').innerHTML = '<div class="text-red-400 text-center py-4">فشل تحميل البيانات</div>';
            } finally {
                document.getElementById('bulkLoading').classList.add('hidden');
            }
        }

        function closeBulkModal() {
            document.getElementById('bulkModal').classList.add('hidden');
        }

        function renderBulkList(heads) {
            const list = document.getElementById('bulkList');
            if (heads.length === 0) {
                list.innerHTML = '<div class="text-gray-500 text-center py-4">لا توجد نتائج</div>';
                return;
            }
            list.innerHTML = heads.map(h => `
                <div class="flex items-center gap-3 p-2 rounded hover:bg-gray-800 transition ${h.alreadyNominated ? 'opacity-50' : ''}">
                    <input type="checkbox" class="head-check accent-camp-gold cursor-pointer"
                           data-id="${h.id}"
                           ${h.alreadyNominated ? 'disabled' : ''}
                           ${selectedHeadIds.has(h.id) ? 'checked' : ''}
                           onchange="toggleHead(${h.id}, this.checked)" />
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                            <span class="text-white font-bold text-sm truncate">${h.fullName}</span>
                            <span class="text-gray-400 text-xs" dir="ltr">${h.idNumber}</span>
                            ${h.alreadyNominated ? '<span class="text-yellow-400 text-xs">مرشح مسبقاً</span>' : ''}
                        </div>
                        <div class="text-gray-500 text-xs">
                            ${h.phone ? `<span dir="ltr">${h.phone}</span> · ` : ''}
                            ${h.sector || ''}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function filterBulkList() {
            const q = document.getElementById('bulkSearch').value.trim().toLowerCase();
            const sector = document.getElementById('bulkSectorFilter').value;
            const filtered = allHeads.filter(h => {
                if (sector && h.sector !== sector) return false;
                if (!q) return true;
                return h.fullName.toLowerCase().includes(q) ||
                       h.idNumber.includes(q) ||
                       (h.phone || '').includes(q);
            });
            renderBulkList(filtered);
        }

        function toggleHead(id, checked) {
            if (checked) selectedHeadIds.add(id);
            else selectedHeadIds.delete(id);
            updateSelectedCount();
        }

        function toggleSelectAll() {
            const checked = document.getElementById('selectAllCheck').checked;
            document.querySelectorAll('.head-check:not(:disabled)').forEach(cb => {
                cb.checked = checked;
                const id = parseInt(cb.dataset.id);
                if (checked) selectedHeadIds.add(id);
                else selectedHeadIds.delete(id);
            });
            updateSelectedCount();
        }

        function clearSelection() {
            selectedHeadIds.clear();
            document.querySelectorAll('.head-check').forEach(cb => cb.checked = false);
            document.getElementById('selectAllCheck').checked = false;
            updateSelectedCount();
        }

        function updateSelectedCount() {
            const count = selectedHeadIds.size;
            document.getElementById('selectedCount').textContent = count + ' مختار';
            document.getElementById('confirmBulkBtn').disabled = count === 0;
        }

        async function confirmBulkAdd() {
            if (selectedHeadIds.size === 0) return;

            const notes = document.getElementById('bulkNotes').value.trim();
            const ids = Array.from(selectedHeadIds);
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Nomination/AddMultipleRows';

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            const append = (name, val) => {
                const inp = document.createElement('input');
                inp.type = 'hidden';
                inp.name = name;
                inp.value = val;
                form.appendChild(inp);
            };

            append('projectId', '@Model.ProjectId');
            append('notes', notes);
            if (token) append('__RequestVerificationToken', token);
            ids.forEach(id => append('personIds', id));

            document.body.appendChild(form);
            form.submit();
        }

        /* ─── Excel Import Modal ─── */

        function openExcelModal() {
            document.getElementById('excelModal').classList.remove('hidden');
        }

        function closeExcelModal() {
            document.getElementById('excelModal').classList.add('hidden');
        }
    </script>
}
