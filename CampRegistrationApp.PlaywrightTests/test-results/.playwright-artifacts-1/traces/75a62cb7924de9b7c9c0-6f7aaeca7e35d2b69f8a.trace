or: var(--text-secondary); }\n        [data-theme] .text-gray-400 { color: var(--text-muted); }\n        [data-theme] .text-gray-500 { color: var(--text-muted); }\n        [data-theme=\"dark\"] .text-gray-600 { color: var(--text-muted); }\n        /* Black/dark text — readable on dark backgrounds */\n        [data-theme=\"dark\"] .text-black,\n        [data-theme=\"dark\"] .text-camp-dark-grey { color: #E5E7EB; }\n        /* But keep dark text on gold buttons (contrast on gold is fine) */\n        [data-theme=\"dark\"] .bg-camp-gold.text-black,\n        [data-theme=\"dark\"] .bg-camp-gold.text-camp-dark-grey { color: #1A1A1A; }\n        /* Border overrides */\n        [data-theme] .border-gray-600 { border-color: var(--border-light); }\n        [data-theme] .border-gray-700 { border-color: var(--border-color); }\n        [data-theme] .border-gray-800 { border-color: var(--border-color); }\n        /* Hover states */\n        [data-theme] .hover\\:bg-gray-700:hover { background-color: var(--border-color); }\n        [data-theme] .hover\\:bg-gray-800\\/50:hover,\n        [data-theme] .hover\\:bg-camp-dark-grey\\/50:hover { background-color: color-mix(in srgb, var(--bg-primary) 50%, transparent); }\n        [data-theme] .hover\\:text-white:hover { color: var(--text-primary); }\n        /* Semi-transparent backgrounds */\n        [data-theme] .bg-gray-800\\/50,\n        [data-theme] .bg-camp-dark-grey\\/50 { background-color: color-mix(in srgb, var(--bg-primary) 50%, transparent); }\n        /* Darken gold text in light mode for readability */\n        [data-theme=\"light\"] .text-camp-gold { color: #9A7B0C; }\n        /* Keep colored button text white in light mode */\n        [data-theme=\"light\"] .bg-green-600.text-white,\n        [data-theme=\"light\"] .bg-green-700.text-white,\n        [data-theme=\"light\"] .bg-red-700.text-white,\n        [data-theme=\"light\"] .bg-red-500.text-white,\n        [data-theme=\"light\"] .bg-black\\/50.text-white,\n        [data-them